@page "/contact"
@layout SympNet.WebDashboard.Components.Layout.EmptyLayout
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>SympNet - Contact Us</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Instrument Sans', sans-serif; background: #F8FAFC; color: #1F2937; line-height: 1.5; }
    
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    
    /* Navbar */
    .navbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; max-width: 1200px; margin: 0 auto; }
    .logo { font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 800; color: #0D9488; display: flex; align-items: center; gap: 8px; }
    .nav-links { display: flex; gap: 24px; font-weight: 500; font-size: 15px; }
    .nav-links a { text-decoration: none; color: #4B5563; transition: 0.2s; }
    .nav-links a:hover, .nav-links a.active { color: #0D9488; border-bottom: 2px solid #0D9488; padding-bottom: 2px; }
    .nav-actions { display: flex; align-items: center; gap: 16px; }
    
    .doctor-logo-icon {
        width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: white;
    }
    
    .btn-primary { 
        background: #0D9488; 
        color: white; 
        border: none; 
        padding: 10px 20px; 
        border-radius: 8px; 
        font-size: 14px; 
        font-weight: 600; 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        transition: 0.2s; 
    }
    .btn-primary:hover { background: #0F766E; }

    /* Hero Banner */
    .hero-banner {
        width: 100%;
        height: 350px;
        background-image: url('https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=2000');
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .hero-banner::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(13, 148, 136, 0.2);
    }

    /* Contact Form Section */
    .contact-section {
        max-width: 700px;
        margin: 60px auto 100px;
        padding: 0 20px;
    }
    
    .contact-header {
        text-align: center;
        margin-bottom: 40px;
    }
    
    .contact-header h4 {
        font-size: 14px;
        font-weight: 600;
        color: #4B5563;
        margin-bottom: 8px;
    }
    
    .contact-header h1 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 42px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 16px;
    }
    
    .contact-header p {
        color: #64748B;
        font-size: 16px;
    }

    .form-group {
        margin-bottom: 24px;
    }
    
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-bottom: 24px;
    }
    
    label {
        display: block;
        font-size: 14px;
        font-weight: 500;
        color: #374151;
        margin-bottom: 8px;
    }
    
    input[type="text"], input[type="email"], input[type="tel"], select, textarea {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid #0D9488;
        border-radius: 8px;
        outline: none;
        font-family: 'Instrument Sans', sans-serif;
        font-size: 15px;
        background: rgba(13, 148, 136, 0.03);
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    
    input::placeholder, textarea::placeholder {
        color: #9CA3AF;
    }
    
    input:focus, select:focus, textarea:focus {
        border-color: #0F766E;
        box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
    }
    
    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 32px;
    }
    
    .checkbox-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        accent-color: #0D9488;
        cursor: pointer;
    }
    
    .checkbox-group label {
        margin-bottom: 0;
        font-weight: 400;
        color: #4B5563;
        font-size: 14px;
        cursor: pointer;
    }

    .submit-btn {
        background: #0D9488;
        color: white;
        border: none;
        padding: 14px 40px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: block;
        margin: 0 auto;
        transition: 0.2s;
    }
    
    .submit-btn:hover {
        background: #0F766E;
        transform: translateY(-2px);
    }
    
    /* Newsletter */
    .newsletter-section {
        text-align: center;
        margin-bottom: 60px;
    }
    
    .newsletter-section h3 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 20px;
        margin-bottom: 20px;
        color: #111827;
    }
    
    .newsletter-input-group {
        display: flex;
        max-width: 400px;
        margin: 0 auto;
        background: white;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    
    .newsletter-input-group input {
        border: none;
        padding: 14px 24px;
        background: none;
        border-radius: 0;
    }
    .newsletter-input-group input:focus {
        box-shadow: none;
    }
    
    .newsletter-input-group button {
        background: #0D9488;
        color: white;
        border: none;
        padding: 0 24px;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
    }
    .newsletter-input-group button:hover {
        background: #0F766E;
    }

    /* Footer */
    .footer { background: #0D9488; color: white; padding: 60px 0 30px; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 60px; }
    .footer-col h4 { font-size: 18px; margin-bottom: 20px; font-weight: 600; }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 12px; }
    .footer-links a { color: #CCFBF1; text-decoration: none; font-size: 14px; transition: 0.2s; }
    .footer-links a:hover { color: white; }
    .footer-newsletter-form { display: flex; margin-top: 16px; }
    .footer-newsletter-form input { padding: 12px 16px; border: none; border-radius: 8px 0 0 8px; outline: none; width: 100%; }
    .footer-newsletter-form button { background: #111827; color: white; border: none; padding: 0 20px; border-radius: 0 8px 8px 0; font-weight: 600; cursor: pointer; }
    
    .footer-bottom { text-align: center; padding-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); color: #CCFBF1; font-size: 14px; }
</style>

<header>
    <nav class="navbar">
        <div class="logo">
           <div class="doctor-logo-icon"><i class="fas fa-stethoscope"></i></div>
            SympNet
        </div>
        <div class="nav-links">
            <a href="/">Accueil</a>
            <a href="#">Services</a>
            <a href="/contact" class="active">Contactez-nous</a>
            <a href="#">Aide</a>
            <a href="#">Blog</a>
        </div>
        <div class="nav-actions">
            <button class="btn-primary" @onclick="GoToLogin">Connexion</button>
        </div>
    </nav>
</header>

<div class="hero-banner"></div>

<main>
    <section class="contact-section">
        <div class="contact-header">
            <h4>Entrons en Contact</h4>
            <h1>Contactez-nous</h1>
            <p>N'hésitez pas à nous contacter pour toute question ou demande.</p>
        </div>
        
        <form @onsubmit="SubmitContact">
            <div class="form-row">
                <div>
                    <label>Prénom</label>
                    <input type="text" placeholder="Entrez votre prénom" @bind="firstName" required />
                </div>
                <div>
                    <label>Nom</label>
                    <input type="text" placeholder="Entrez votre nom" @bind="lastName" required />
                </div>
            </div>
            
            <div class="form-row">
                <div>
                    <label>Email</label>
                    <input type="email" placeholder="Entrez votre email" @bind="email" required />
                </div>
                <div>
                    <label>Numéro de téléphone</label>
                    <input type="tel" placeholder="Entrez votre numéro de téléphone" @bind="phone" />
                </div>
            </div>
            
            <div class="form-group">
                <label>Choisissez un sujet</label>
                <select @bind="topic">
                    <option value="">Sélectionnez le domaine...</option>
                    <option value="support">Support Technique</option>
                    <option value="billing">Facturation & Abonnements</option>
                    <option value="partnership">Partenariat</option>
                    <option value="other">Autre</option>
                </select>
            </div>
            
            <div class="form-group">
                <label>Message</label>
                <textarea rows="5" placeholder="Tapez votre message..." @bind="message" required></textarea>
            </div>
            
            <div class="checkbox-group">
                <input type="checkbox" id="terms" @bind="acceptTerms" required />
                <label for="terms">J'accepte les conditions</label>
            </div>
            
            <button type="submit" class="submit-btn">Envoyer</button>
        </form>
    </section>

    <section class="newsletter-section">
        <h3>Abonnez-vous à notre newsletter !</h3>
        <div class="newsletter-input-group">
            <input type="email" placeholder="Entrez votre email" @bind="newsletterEmail" />
            <button @onclick="SubscribeNewsletter">S'abonner</button>
        </div>
    </section>
</main>

<footer class="footer">
    <div class="container">
        <div class="footer-grid">
            <div class="footer-col" style="padding-right: 40px;">
                <div class="logo" style="color: white; margin-bottom: 20px;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                    HealthCare
                </div>
                <p style="color: #CCFBF1; font-size: 14px; margin-bottom: 20px;">Abonnez-vous à notre newsletter !</p>
                <div class="footer-newsletter-form">
                    <input type="email" placeholder="Entrez votre email" @bind="newsletterEmail" />
                    <button @onclick="SubscribeNewsletter">S'abonner</button>
                </div>
            </div>
            <div class="footer-col">
                <h4>Produit</h4>
                <ul class="footer-links">
                    <li><a href="#">Fonctionnalités</a></li>
                    <li><a href="#">Tarifs</a></li>
                    <li><a href="#">Études de cas</a></li>
                    <li><a href="#">Avis</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Entreprise</h4>
                <ul class="footer-links">
                    <li><a href="#">À propos</a></li>
                    <li><a href="/contact">Contactez-nous</a></li>
                    <li><a href="#">Carrières</a></li>
                    <li><a href="#">Culture</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <ul class="footer-links">
                    <li><a href="#">Démarrage</a></li>
                    <li><a href="#">Centre d'aide</a></li>
                    <li><a href="#">État des serveurs</a></li>
                    <li><a href="#">Signaler un bug</a></li>
                </ul>
            </div>
            <div class="footer-col">
                <h4>Suivez-nous</h4>
                <ul class="footer-links">
                    <li><a href="#">Facebook</a></li>
                    <li><a href="#">Twitter</a></li>
                    <li><a href="#">Instagram</a></li>
                    <li><a href="#">LinkedIn</a></li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            Copyright © 2024 HealthCare. Tous droits réservés.
        </div>
    </div>
</footer>

@code {
    private string firstName = "";
    private string lastName = "";
    private string email = "";
    private string phone = "";
    private string topic = "";
    private string message = "";
    private bool acceptTerms = false;
    private string newsletterEmail = "";

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task SubmitContact()
    {
        if (acceptTerms)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Merci {firstName} ! Votre message a été envoyé avec succès.");
            // Reset form
            firstName = ""; lastName = ""; email = ""; phone = ""; topic = ""; message = ""; acceptTerms = false;
        }
    }

    private async Task SubscribeNewsletter()
    {
        if (!string.IsNullOrWhiteSpace(newsletterEmail))
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Abonnement réussi avec {newsletterEmail} !");
            newsletterEmail = "";
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Veuillez entrer une adresse email valide.");
        }
    }
}
