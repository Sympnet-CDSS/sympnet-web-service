@page "/blog/{Id:int}"
@layout SympNet.WebDashboard.Components.Layout.EmptyLayout
@inject HttpClient Http
@inject IConfiguration Config
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(post?.Title ?? "Article") - SympNet</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Instrument Sans', sans-serif; background: white; color: #1F2937; line-height: 1.6; }
    .container { max-width: 800px; margin: 0 auto; padding: 0 24px; }
    
    .navbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; max-width: 1200px; margin: 0 auto; }
    .logo { font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 800; color: #0D9488; display: flex; align-items: center; gap: 8px; cursor: pointer; }
    .doctor-logo-icon { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; }

    .article-header { padding: 60px 0 40px; }
    .back-btn { display: flex; align-items: center; gap: 8px; color: #6B7280; text-decoration: none; font-size: 14px; font-weight: 600; margin-bottom: 32px; }
    .back-btn:hover { color: #0D9488; }
    
    .cat-badge { background: #F0FDF4; color: #10B981; padding: 4px 12px; border-radius: 99px; font-size: 12px; font-weight: 700; display: inline-block; margin-bottom: 16px; }
    h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 42px; font-weight: 800; line-height: 1.2; color: #111827; margin-bottom: 24px; }
    
    .meta-row { display: flex; align-items: center; gap: 24px; color: #6B7280; font-size: 14px; padding-bottom: 40px; border-bottom: 1px solid #E5E7EB; margin-bottom: 40px; }
    .author-info { display: flex; align-items: center; gap: 10px; color: #111827; font-weight: 600; }
    .author-avatar { width: 32px; height: 32px; border-radius: 50%; background: #0D9488; color: white; display: flex; align-items: center; justify-content: center; font-size: 12px; }

    .cover-img { width: 100%; border-radius: 24px; margin-bottom: 40px; max-height: 500px; object-fit: cover; }
    
    .article-content { font-size: 18px; color: #374151; white-space: pre-wrap; }
    .article-content h2 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; margin-top: 40px; margin-bottom: 16px; color: #111827; }
    
    .share-section { margin-top: 60px; padding-top: 40px; border-top: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; margin-bottom: 80px; }
    .share-btns { display: flex; gap: 12px; }
    .share-btn { width: 40px; height: 40px; border-radius: 50%; border: 1px solid #E5E7EB; display: flex; align-items: center; justify-content: center; color: #6B7280; cursor: pointer; transition: 0.2s; }
    .share-btn:hover { border-color: #0D9488; color: #0D9488; background: #F0FDF4; }
</style>

<header>
    <nav class="navbar">
        <div class="logo" @onclick='() => Navigation.NavigateTo("/")'>
           <div class="doctor-logo-icon"><i class="fas fa-stethoscope"></i></div>
            SympNet
        </div>
        <div class="nav-links" style="display: flex; gap: 24px;">
            <a href="/" style="text-decoration: none; color: #4B5563;">Accueil</a>
            <a href="/blog" style="text-decoration: none; color: #0D9488; font-weight: 600;">Blog</a>
        </div>
    </nav>
</header>

<main>
    @if (post == null)
    {
        <div class="container" style="padding: 100px 0; text-align: center;">
            <div class="spinner" style="width: 40px; height: 40px; border: 4px solid rgba(13, 148, 136, 0.1); border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto;"></div>
        </div>
    }
    else
    {
        <article class="container">
            <div class="article-header">
                <a href="/blog" class="back-btn"><i class="fas fa-arrow-left"></i> Retour au blog</a>
                <span class="cat-badge">@post.Category</span>
                <h1>@post.Title</h1>
                <div class="meta-row">
                    <div class="author-info">
                        <div class="author-avatar">@post.AuthorName[0]</div>
                        <span>@post.AuthorName</span>
                    </div>
                    <span><i class="far fa-calendar"></i> @post.CreatedAt.ToString("d MMMM yyyy")</span>
                    <span><i class="far fa-clock"></i> @post.ReadingTime min de lecture</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(post.ImageUrl))
            {
                <img src="@post.ImageUrl" class="cover-img" alt="" />
            }

            <div class="article-content">
                @post.Content
            </div>

            <div class="share-section">
                <div style="font-weight: 700;">Partager cet article</div>
                <div class="share-btns">
                    <div class="share-btn"><i class="fab fa-twitter"></i></div>
                    <div class="share-btn"><i class="fab fa-facebook-f"></i></div>
                    <div class="share-btn"><i class="fab fa-linkedin-in"></i></div>
                    <div class="share-btn"><i class="fas fa-link"></i></div>
                </div>
            </div>
        </article>
    }
</main>

<style>
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private BlogPost? post;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            post = await Http.GetFromJsonAsync<BlogPost>($"{baseUrl}/api/blogposts/{Id}");
            
            if (post != null)
            {
                // Track view if not already viewed in this session
                var sessionKey = $"viewed_blog_{Id}";
                var alreadyViewed = await JS.InvokeAsync<string>("sessionStorage.getItem", sessionKey);
                
                if (string.IsNullOrEmpty(alreadyViewed))
                {
                    await Http.PostAsync($"{baseUrl}/api/blogposts/{Id}/increment-view", null);
                    await JS.InvokeVoidAsync("sessionStorage.setItem", sessionKey, "true");
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
    }

    public class BlogPost
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Category { get; set; } = "";
        public string AuthorName { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public int ReadingTime { get; set; }
    }
}
