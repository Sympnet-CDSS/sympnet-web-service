    private void FilterDoctors()
    {
        filteredDoctors = allDoctors.Where(d => 
            (string.IsNullOrWhiteSpace(searchName) || (d.FirstName + " " + d.LastName).Contains(searchName, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(searchSpecialty) || d.Specialty.Contains(searchSpecialty, StringComparison.OrdinalIgnoreCase)) &&
            (!isAvailable || d.IsAvailable == true)
        ).ToList();
        StateHasChanged();
    }

    private void ToggleAvailable()
    {
        isAvailable = !isAvailable;
        FilterDoctors();
    }
    
    private void SetSpecialty(string spec)
    {
        if (searchSpecialty == spec)
            searchSpecialty = ""; // Toggle off
        else
            searchSpecialty = spec;
        FilterDoctors();
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private double GenerateRandomRating(int id)
    {
        // Generates a stable random rating between 4.0 and 5.0 based on ID
        var random = new Random(id * 100);
        return Math.Round(4.0 + random.NextDouble(), 1);
    }

