@page "/doctor-profile/{Id:int}"
@layout EmptyLayout
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Nav
@inject IConfiguration Config
@using System.Text.Json

<PageTitle>Profil Médecin - SympNet</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
    :root {
        --primary: #0D9488;
        --primary-hover: #0F766E;
        --bg: #F8FAFC;
        --card-bg: #FFFFFF;
        --text-main: #1E293B;
        --text-muted: #64748B;
        --border: #E2E8F0;
    }

    body { font-family: 'Instrument Sans', sans-serif; background: var(--bg); margin: 0; color: var(--text-main); }
    
    header { background: white; border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
    .navbar { display: flex; justify-content: space-between; align-items: center; padding: 16px 5%; max-width: 1400px; margin: 0 auto; }
    .logo { display: flex; align-items: center; gap: 12px; font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 800; color: #111827; cursor: pointer; text-decoration: none; }
    .doctor-logo-icon { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: white; }
    .nav-actions .btn-primary { background: var(--primary); color: white; padding: 10px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; border: none; cursor: pointer; transition: all 0.3s; }
    .nav-actions .btn-primary:hover { background: var(--primary-hover); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(13,148,136,0.2); }

    .profile-container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
    .btn-back { display: inline-flex; align-items: center; gap: 8px; color: var(--text-muted); text-decoration: none; font-weight: 600; margin-bottom: 24px; transition: color 0.2s; cursor: pointer; border: none; background: none; font-size: 15px; }
    .btn-back:hover { color: var(--primary); }

    .profile-card { background: var(--card-bg); border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid var(--border); display: flex; gap: 40px; margin-bottom: 32px; }
    .profile-avatar-wrap { flex-shrink: 0; width: 140px; }
    .profile-avatar { width: 140px; height: 140px; border-radius: 20px; background: linear-gradient(135deg, #E2E8F0, #F1F5F9); display: flex; align-items: center; justify-content: center; font-size: 48px; color: #94A3B8; font-weight: 700; overflow: hidden; }
    .profile-avatar img { width: 100%; height: 100%; object-fit: cover; }
    
    .profile-info { flex: 1; }
    .profile-name { font-family: 'Bricolage Grotesque', sans-serif; font-size: 32px; font-weight: 800; margin: 0 0 8px 0; color: var(--text-main); }
    .profile-spec { display: inline-block; background: #F0FDF4; color: #10B981; padding: 6px 16px; border-radius: 99px; font-weight: 600; font-size: 14px; margin-bottom: 16px; }
    
    .profile-stats { display: flex; gap: 24px; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
    .stat-item { display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 15px; }
    .stat-item i { color: var(--primary); }
    .stat-item strong { color: var(--text-main); }
    .star-rating { color: #F59E0B; }

    .profile-section-title { font-family: 'Bricolage Grotesque', sans-serif; font-size: 20px; font-weight: 700; margin: 0 0 16px 0; color: var(--text-main); }
    .profile-bio { color: var(--text-muted); line-height: 1.6; font-size: 15px; margin: 0; }

    .ratings-section { background: var(--card-bg); border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.03); border: 1px solid var(--border); }
    .rating-list { display: flex; flex-direction: column; gap: 24px; margin-top: 24px; }
    .rating-item { padding-bottom: 24px; border-bottom: 1px solid var(--border); }
    .rating-item:last-child { border-bottom: none; padding-bottom: 0; }
    .rating-header { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .rating-author { font-weight: 600; color: var(--text-main); }
    .rating-date { color: #94A3B8; font-size: 13px; }
    .rating-stars { color: #F59E0B; font-size: 14px; margin-bottom: 12px; }
    .rating-comment { color: var(--text-muted); font-size: 15px; line-height: 1.5; margin: 0; }

    .loading-state { text-align: center; padding: 60px; color: var(--text-muted); }
    .spinner { border: 3px solid rgba(13,148,136,0.1); border-top-color: var(--primary); border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    
    .error-state { text-align: center; padding: 60px; color: #EF4444; background: #FEF2F2; border-radius: 16px; margin: 40px auto; max-width: 600px; }
</style>

<header>
    <div class="navbar">
        <a href="/" class="logo">
           <div class="doctor-logo-icon"><i class="fas fa-stethoscope"></i></div>
            SympNet
        </a>
        <div class="nav-actions">
            <a href="/login" class="btn-primary">Se connecter</a>
        </div>
    </div>
</header>

<main class="profile-container">
    <button class="btn-back" @onclick="GoBack">
        <i class="fas fa-arrow-left"></i> Retour à l'accueil
    </button>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement du profil...</p>
        </div>
    }
    else if (errorMessage != null)
    {
        <div class="error-state">
            <i class="fas fa-exclamation-circle fa-2x mb-3"></i>
            <h3>Erreur</h3>
            <p>@errorMessage</p>
            <button class="btn-primary mt-3" @onclick="GoBack">Retourner à l'accueil</button>
        </div>
    }
    else if (doctor != null)
    {
        <div class="profile-card">
            <div class="profile-avatar-wrap">
                <div class="profile-avatar">
                    @if (!string.IsNullOrEmpty(doctor.PhotoUrl))
                    {
                        <img src="@doctor.PhotoUrl" alt="@doctor.FirstName @doctor.LastName" />
                    }
                    else
                    {
                        @doctor.FirstName.Substring(0, 1)@doctor.LastName.Substring(0, 1)
                    }
                </div>
            </div>
            
            <div class="profile-info">
                <h1 class="profile-name">Dr. @doctor.FirstName @doctor.LastName</h1>
                <div class="profile-spec">@doctor.Speciality</div>
                
                <div class="profile-stats">
                    <div class="stat-item">
                        <i class="fas fa-star star-rating"></i>
                        <span><strong>@doctor.AverageRating.ToString("0.0")</strong> (@doctor.TotalRatings avis)</span>
                    </div>
                    @if (doctor.GraduationYear.HasValue)
                    {
                        <div class="stat-item">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Diplômé en <strong>@doctor.GraduationYear</strong></span>
                        </div>
                    }
                    <div class="stat-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>@(string.IsNullOrEmpty(doctor.Address) ? "Adresse non précisée" : doctor.Address)</span>
                    </div>
                </div>

                <h3 class="profile-section-title">À propos</h3>
                <p class="profile-bio">
                    @(string.IsNullOrEmpty(doctor.Bio) ? "Aucune biographie disponible pour ce médecin." : doctor.Bio)
                </p>
            </div>
        </div>

        <div class="ratings-section">
            <h3 class="profile-section-title">Avis des patients (@doctor.TotalRatings)</h3>
            
            @if (doctor.Ratings != null && doctor.Ratings.Any())
            {
                <div class="rating-list">
                    @foreach (var rating in doctor.Ratings)
                    {
                        <div class="rating-item">
                            <div class="rating-header">
                                <span class="rating-author">Patient anonyme</span>
                                <span class="rating-date">@rating.CreatedAt.ToString("dd MMMM yyyy")</span>
                            </div>
                            <div class="rating-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= rating.Score ? "" : "text-gray-300" )" style="color: @(i <= rating.Score ? "#F59E0B" : "#E2E8F0")"></i>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(rating.Comment))
                            {
                                <p class="rating-comment">"@rating.Comment"</p>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color: var(--text-muted); margin-top: 20px;">Aucun avis pour le moment.</p>
            }
        </div>
    }
</main>

@code {
    [Parameter]
    public int Id { get; set; }

    private DoctorProfileDto? doctor;
    private bool isLoading = true;
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadDoctor();
    }

    private async Task LoadDoctor()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.GetAsync($"{baseUrl}/api/doctors/{Id}");
            
            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                doctor = JsonSerializer.Deserialize<DoctorProfileDto>(content, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else
            {
                errorMessage = "Le profil du médecin est introuvable.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur lors de la connexion au serveur.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/");
    }

    private class DoctorProfileDto
    {
        public int Id { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Speciality { get; set; } = string.Empty;
        public string? Bio { get; set; }
        public int? GraduationYear { get; set; }
        public string? Address { get; set; }
        public double AverageRating { get; set; }
        public int TotalRatings { get; set; }
        public string? PhotoUrl { get; set; }
        public List<DoctorRatingDto> Ratings { get; set; } = new();
    }

    private class DoctorRatingDto
    {
        public int Id { get; set; }
        public int Score { get; set; }
        public string? Comment { get; set; }
        public string PatientName { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
    }
}
