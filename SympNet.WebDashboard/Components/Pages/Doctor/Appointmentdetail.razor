@page "/doctor/appointments/{Id:int}"
@layout SympNet.WebDashboard.Components.Layout.DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>Détails du rendez-vous — SympNet</PageTitle>

<div class="appointment-detail-page">
    <div class="page-header">
        <button class="btn-back" @onclick='() => Navigation.NavigateTo("/doctor/notifications")'>
            <i class="fas fa-arrow-left"></i>
        </button>
        <div class="header-text">
            <h1>Détails de la notification</h1>
            <p>@appointment?.DateTime.ToString("dd MMMM yyyy à HH:mm", new System.Globalization.CultureInfo("fr-FR"))</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement des détails...</p>
        </div>
    }
    else if (appointment == null)
    {
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <h3>Rendez-vous introuvable</h3>
            <p>Ce rendez-vous n'existe pas ou a été supprimé.</p>
        </div>
    }
    else
    {
        <!-- Profil Patient -->
        <div class="profile-card">
            <div class="profile-main">
                <div class="avatar-box">
                    @if (!string.IsNullOrEmpty(appointment.PatientPhotoUrl))
                    {
                        <img src="@appointment.PatientPhotoUrl" alt="Patient" />
                    }
                    else
                    {
                        <div class="avatar-placeholder">
                            <i class="fas fa-user"></i>
                        </div>
                    }
                </div>
                <div class="profile-info">
                    <h2>@appointment.PatientName</h2>
                    <div class="info-badges">
                        <div class="info-badge">
                            <div class="badge-icon"><i class="fas fa-user"></i></div>
                            <div class="badge-text">
                                <label>Âge</label>
                                <span>@appointment.PatientAge ans</span>
                            </div>
                        </div>
                        <div class="info-badge">
                            <div class="badge-icon"><i class="fas fa-phone-alt"></i></div>
                            <div class="badge-text">
                                <label>Téléphone</label>
                                <span>@appointment.PatientPhone</span>
                            </div>
                        </div>
                        <div class="info-badge">
                            <div class="badge-icon"><i class="fas fa-envelope"></i></div>
                            <div class="badge-text">
                                <label>Email</label>
                                <span>@appointment.PatientEmail</span>
                            </div>
                        </div>
                        <div class="info-badge">
                            <div class="badge-icon"><i class="fas fa-map-marker-alt"></i></div>
                            <div class="badge-text">
                                <label>Localisation</label>
                                <span>@appointment.PatientLocation</span>
                            </div>
                        </div>
                        <div class="info-badge">
                            <div class="badge-icon"><i class="far fa-clock"></i></div>
                            <div class="badge-text">
                                <label>Dernière visite</label>
                                <span>12 Avril 2026</span>
                            </div>
                        </div>
                    </div>
                    <div class="conditions">
                        <span class="label">Conditions:</span>
                        @foreach (var cond in appointment.PatientConditions.Split(','))
                        {
                            <span class="condition-tag">@cond.Trim()</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Détails du RDV -->
        <div class="detail-card">
            <div class="card-header">
                <div class="card-icon"><i class="far fa-calendar-alt"></i></div>
                <div class="card-title">
                    <h3>Nouvelle demande de rendez-vous</h3>
                    <p>@appointment.PatientName souhaite prendre rendez-vous pour une consultation. @appointment.Reason</p>
                </div>
            </div>
            <div class="card-grid">
                <div class="grid-item">
                    <label>Date souhaitée:</label>
                    <span>@appointment.DateTime.ToString("dd Mai 2026")</span>
                </div>
                <div class="grid-item">
                    <label>Heure:</label>
                    <span>@appointment.DateTime.ToString("HH:mm")</span>
                </div>
                <div class="grid-item">
                    <label>Type:</label>
                    <span>Consultation</span>
                </div>
                <div class="grid-item">
                    <label>Durée estimée:</label>
                    <span>30 min</span>
                </div>
            </div>
        </div>

        <!-- Boutons d'Action -->
        <div class="action-buttons">
            <button class="btn-action btn-accept" @onclick='() => UpdateStatus("Confirmé")'>
                <i class="far fa-check-circle"></i> Accepter
            </button>
            <button class="btn-action btn-refuse" @onclick='() => UpdateStatus("Annulé")'>
                <i class="far fa-times-circle"></i> Refuser
            </button>
            <button class="btn-action btn-message" @onclick='() => showReplyForm = !showReplyForm'>
                <i class="far fa-comment-dots"></i> Envoyer un message
            </button>
            <button class="btn-action btn-video" @onclick='() => Navigation.NavigateTo("/doctor/video-call")'>
                <i class="fas fa-video"></i> Démarrer vidéo consultation
            </button>
        </div>

        <!-- Formulaire de Réponse -->
        <div class="reply-section">
            <h4>Votre réponse</h4>
            <div class="reply-box">
                <textarea placeholder="Écrivez votre réponse au patient..." @bind="replyMessage"></textarea>
                <div class="reply-footer">
                    <button class="btn-send" @onclick="SendReply">
                        <i class="far fa-paper-plane"></i> Envoyer la réponse
                    </button>
                    <button class="btn-cancel" @onclick='() => replyMessage = ""'>Annuler</button>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .appointment-detail-page { padding: 30px; max-width: 900px; margin: 0 auto; }
    
    .page-header { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
    .btn-back { background: white; border: 1px solid #E5E7EB; width: 40px; height: 40px; border-radius: 12px; cursor: pointer; transition: 0.2s; }
    .btn-back:hover { background: #F9FAFB; }
    .header-text h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 20px; font-weight: 800; color: #111827; margin: 0; }
    .header-text p { font-size: 14px; color: #6B7280; margin: 0; }

    /* Profile Card */
    .profile-card { background: white; border-radius: 20px; border: 1px solid #E5E7EB; padding: 24px; margin-bottom: 24px; }
    .profile-main { display: flex; gap: 24px; }
    .avatar-box { width: 80px; height: 80px; border-radius: 50%; overflow: hidden; background: #F0FDF4; border: 3px solid #F0FDF4; flex-shrink: 0; }
    .avatar-box img { width: 100%; height: 100%; object-fit: cover; }
    .avatar-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 32px; color: #0D9488; }
    
    .profile-info h2 { font-size: 22px; font-weight: 800; color: #111827; margin: 0 0 16px; }
    .info-badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 16px; }
    .info-badge { display: flex; align-items: center; gap: 10px; }
    .badge-icon { width: 36px; height: 36px; border-radius: 10px; background: #F9FAFB; display: flex; align-items: center; justify-content: center; color: #0D9488; font-size: 14px; flex-shrink: 0; }
    .badge-text label { display: block; font-size: 11px; color: #9CA3AF; margin-bottom: 2px; }
    .badge-text span { font-size: 13px; font-weight: 700; color: #111827; }
    
    .conditions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .conditions .label { font-size: 12px; color: #9CA3AF; }
    .condition-tag { background: #F3F4F6; color: #4B5563; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 8px; }

    /* Detail Card */
    .detail-card { background: white; border-radius: 20px; border: 1px solid #E5E7EB; padding: 24px; margin-bottom: 24px; }
    .card-header { display: flex; gap: 16px; margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid #F3F4F6; }
    .card-icon { width: 44px; height: 44px; border-radius: 12px; background: #EBF5FF; display: flex; align-items: center; justify-content: center; color: #2563EB; font-size: 20px; }
    .card-title h3 { font-size: 18px; font-weight: 800; color: #111827; margin: 0 0 4px; }
    .card-title p { font-size: 14px; color: #4B5563; margin: 0; }
    
    .card-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .grid-item { display: flex; justify-content: space-between; align-items: center; padding: 12px; background: #F9FAFB; border-radius: 12px; }
    .grid-item label { font-size: 13px; color: #6B7280; }
    .grid-item span { font-size: 14px; font-weight: 700; color: #111827; }

    /* Action Buttons */
    .action-buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 30px; }
    .btn-action { height: 50px; border-radius: 14px; border: none; font-weight: 700; font-size: 15px; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .btn-action:hover { transform: translateY(-2px); opacity: 0.9; }
    
    .btn-accept { background: #10B981; color: white; }
    .btn-refuse { background: white; border: 1px solid #FECACA; color: #EF4444; }
    .btn-message { background: #0D9488; color: white; }
    .btn-video { background: #2563EB; color: white; }

    /* Reply Section */
    .reply-section h4 { font-size: 16px; font-weight: 800; color: #111827; margin: 0 0 16px; }
    .reply-box { background: white; border-radius: 20px; border: 1px solid #E5E7EB; padding: 16px; }
    .reply-box textarea { width: 100%; min-height: 140px; border: 1.5px solid #F3F4F6; border-radius: 12px; padding: 16px; font-size: 15px; resize: none; margin-bottom: 16px; font-family: inherit; }
    .reply-box textarea:focus { outline: none; border-color: #0D9488; background: #F0FDF4; }
    
    .reply-footer { display: flex; justify-content: space-between; align-items: center; }
    .btn-send { background: #8FD1C8; color: white; border: none; padding: 12px 30px; border-radius: 12px; font-weight: 700; cursor: pointer; display: flex; align-items: center; gap: 10px; }
    .btn-cancel { background: none; border: 1px solid #E5E7EB; color: #6B7280; padding: 10px 24px; border-radius: 10px; font-weight: 600; cursor: pointer; }

    .loading-state { text-align: center; padding: 100px 0; }
    .spinner { width: 40px; height: 40px; border: 3px solid #F3F4F6; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto 20px; animation: spin 1s linear infinite; }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private AppointmentDto? appointment;
    private bool isLoading = true;
    private string replyMessage = "";
    private bool showReplyForm = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAppointment();
    }

    private async Task LoadAppointment()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                appointment = await Http.GetFromJsonAsync<AppointmentDto>($"{baseUrl}/api/appointments/{Id}");
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
        finally { isLoading = false; }
    }

    private async Task UpdateStatus(string status)
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PatchAsJsonAsync($"{baseUrl}/api/appointments/{Id}/status", new { Status = status });
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", $"Rendez-vous {status.ToLower()} avec succès");
                Navigation.NavigateTo("/doctor/notifications");
            }
        }
        catch (Exception ex) { Console.WriteLine(ex.Message); }
    }

    private async Task SendReply()
    {
        if (string.IsNullOrWhiteSpace(replyMessage)) return;
        
        // Simuler l'envoi d'une réponse
        await JS.InvokeVoidAsync("alert", "Réponse envoyée au patient !");
        replyMessage = "";
    }

    public class AppointmentDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string PatientEmail { get; set; } = "";
        public string PatientPhone { get; set; } = "";
        public int PatientAge { get; set; }
        public string PatientLocation { get; set; } = "";
        public string PatientConditions { get; set; } = "";
        public string PatientPhotoUrl { get; set; } = "";
        public DateTime DateTime { get; set; }
        public string Reason { get; set; } = "";
    }
}