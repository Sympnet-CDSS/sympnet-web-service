@page "/doctor/consultation/{id:int}"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>SympNet — Détail Consultation</PageTitle>

<style>
    .detail-container { max-width: 900px; margin: 0 auto; }
    .card { background: white; border-radius: 24px; padding: 28px; margin-bottom: 24px; border: 1px solid rgba(13,148,136,0.1); }
    .card-title { font-size: 20px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; color: #0D9488; }
    .info-row { display: flex; padding: 12px 0; border-bottom: 1px solid #F3F4F6; }
    .info-label { width: 150px; font-weight: 600; color: #6B7280; }
    .info-value { flex: 1; color: #1F2937; }
    .confidence-bar { height: 8px; background: #E5E7EB; border-radius: 4px; overflow: hidden; margin: 10px 0; }
    .confidence-fill { height: 100%; background: linear-gradient(90deg, #0D9488, #14B8A6); border-radius: 4px; }
    .btn-back { background: #F3F4F6; color: #6B7280; border: none; padding: 10px 20px; border-radius: 10px; cursor: pointer; transition: all 0.2s; }
    .btn-back:hover { background: #E5E7EB; }
    .loading-spinner { text-align: center; padding: 60px; }
    .spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto; animation: spin 1s linear infinite; }
    .status-completed { background: #D1FAE5; color: #10B981; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; display: inline-block; }
    .status-pending { background: #FEF3C7; color: #F59E0B; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; display: inline-block; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="detail-container">
    @if (isLoading)
    {
        <div class="loading-spinner"><div class="spinner"></div></div>
    }
    else if (consultation != null)
    {
        <div class="card">
            <div class="card-title"><i class="fas fa-user-circle"></i> Informations patient</div>
            <div class="info-row"><div class="info-label">Nom</div><div class="info-value">@consultation.PatientName</div></div>
            <div class="info-row"><div class="info-label">Email</div><div class="info-value">@consultation.PatientEmail</div></div>
            <div class="info-row"><div class="info-label">Date</div><div class="info-value">@consultation.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div></div>
            <div class="info-row"><div class="info-label">Statut</div><div class="info-value"><span class="@(consultation.Status == "Terminée" ? "status-completed" : "status-pending")">@consultation.Status</span></div></div>
        </div>

        <div class="card">
            <div class="card-title"><i class="fas fa-notes-medical"></i> Symptômes</div>
            <p style="white-space: pre-wrap;">@consultation.Symptoms</p>
        </div>

        <div class="card">
            <div class="card-title"><i class="fas fa-diagnoses"></i> Diagnostic IA</div>
            <div class="info-row"><div class="info-label">Diagnostic</div><div class="info-value" style="font-weight: 700; color: #0D9488;">@consultation.Diagnosis</div></div>
            <div class="info-row"><div class="info-label">Score de confiance</div>
                <div class="info-value">
                    <div class="confidence-bar"><div class="confidence-fill" style="width: @(consultation.ConfidenceScore * 100)%"></div></div>
                    <span>@(consultation.ConfidenceScore * 100)%</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-title"><i class="fas fa-list-check"></i> Recommandations</div>
            <ul style="margin: 0; padding-left: 20px;">
                @foreach (var rec in consultation.Recommendations.Split('\n'))
                {
                    <li style="margin: 8px 0;">@rec</li>
                }
            </ul>
        </div>

        <div style="text-align: center;">
            <button class="btn-back" @onclick="GoBack">
                <i class="fas fa-arrow-left"></i> Retour aux consultations
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }
    private ConsultationDetailDto? consultation;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadConsultation();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/doctor/consultations");
    }

    private async Task LoadConsultation()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                consultation = await Http.GetFromJsonAsync<ConsultationDetailDto>($"http://localhost:5000/api/consultations/{Id}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class ConsultationDetailDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string PatientEmail { get; set; } = "";
        public string Symptoms { get; set; } = "";
        public string Diagnosis { get; set; } = "";
        public string Recommendations { get; set; } = "";
        public double ConfidenceScore { get; set; }
        public string Status { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}