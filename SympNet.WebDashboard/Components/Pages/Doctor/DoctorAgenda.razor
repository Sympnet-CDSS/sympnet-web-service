@page "/doctor/agenda"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Mon Agenda</PageTitle>

<style>
    .agenda-container { max-width: 1600px; margin: 0 auto; }
    .agenda-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
    .agenda-header h1 { font-size: 28px; font-weight: 800; color: #1F2937; margin: 0; }
    .agenda-header h1 i { color: #0D9488; margin-right: 12px; }
    .view-controls { display: flex; gap: 12px; align-items: center; }
    .view-btn { padding: 10px 20px; border-radius: 12px; border: 1px solid #E5E7EB; background: white; cursor: pointer; transition: all 0.2s; font-weight: 500; }
    .view-btn.active { background: #0D9488; color: white; border-color: #0D9488; }
    .nav-btn { padding: 10px 16px; border-radius: 12px; border: 1px solid #E5E7EB; background: white; cursor: pointer; }
    .nav-btn:hover { background: #F3F4F6; }
    .current-date { font-size: 20px; font-weight: 600; color: #1F2937; }
    .calendar-container { background: white; border-radius: 24px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    .calendar-header { display: grid; grid-template-columns: repeat(7, 1fr); background: #F9FAFB; border-bottom: 1px solid #E5E7EB; }
    .calendar-day-header { padding: 16px; text-align: center; font-weight: 600; color: #6B7280; font-size: 14px; }
    .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
    .calendar-day { min-height: 120px; border-right: 1px solid #F3F4F6; border-bottom: 1px solid #F3F4F6; padding: 8px; cursor: pointer; transition: all 0.2s; position: relative; }
    .calendar-day:hover { background: #F9FAFB; }
    .calendar-day.today { background: rgba(13,148,136,0.05); }
    .calendar-day.other-month { background: #F9FAFB; color: #9CA3AF; }
    .day-number { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
    .event-item { font-size: 11px; padding: 4px 6px; border-radius: 6px; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: pointer; transition: all 0.2s; }
    .event-item:hover { transform: translateX(2px); }
    .event-appointment { background: rgba(13,148,136,0.1); color: #0D9488; border-left: 3px solid #0D9488; }
    .event-appointment-urgent { background: rgba(239,68,68,0.1); color: #EF4444; border-left: 3px solid #EF4444; animation: pulse 2s infinite; }
    .event-blocked { background: rgba(239,68,68,0.1); color: #EF4444; border-left: 3px solid #EF4444; text-decoration: line-through; }
    .more-events { font-size: 11px; color: #6B7280; margin-top: 4px; cursor: pointer; }
    .time-slots-view { display: flex; flex-direction: column; gap: 12px; max-height: 600px; overflow-y: auto; padding: 16px; }
    .time-slot { display: flex; align-items: center; padding: 12px; border-radius: 12px; background: white; border: 1px solid #E5E7EB; transition: all 0.2s; }
    .time-slot.available { cursor: pointer; border-left: 4px solid #10B981; }
    .time-slot.available:hover { background: #ECFDF5; transform: translateX(4px); }
    .time-slot.unavailable { opacity: 0.5; background: #F9FAFB; }
    .time-label { width: 100px; font-weight: 600; color: #1F2937; }
    .slot-status { flex: 1; font-size: 13px; }
    .slot-available { color: #10B981; }
    .slot-unavailable { color: #EF4444; }
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 2000; }
    .modal-content { background: white; border-radius: 24px; width: 500px; max-width: 90%; max-height: 85vh; overflow-y: auto; }
    .modal-header { padding: 20px 24px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; }
    .modal-header h3 { font-size: 20px; font-weight: 700; margin: 0; }
    .modal-body { padding: 24px; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid #E5E7EB; display: flex; justify-content: flex-end; gap: 12px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 8px; color: #374151; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px 12px; border: 1.5px solid #E5E7EB; border-radius: 10px; font-size: 14px; }
    .form-group input:focus { outline: none; border-color: #0D9488; }
    .btn-primary { background: #0D9488; color: white; padding: 10px 20px; border: none; border-radius: 10px; cursor: pointer; font-weight: 600; }
    .btn-secondary { background: #F3F4F6; color: #6B7280; padding: 10px 20px; border: none; border-radius: 10px; cursor: pointer; }
    .btn-danger { background: #EF4444; color: white; padding: 10px 20px; border: none; border-radius: 10px; cursor: pointer; }
    @@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
    @@media (max-width: 768px) { .calendar-day { min-height: 80px; } .event-item { display: none; } }
</style>

<div class="agenda-container">
    <div class="agenda-header">
        <h1><i class="fas fa-calendar-alt"></i> Mon Agenda</h1>
        <div class="view-controls">
            <button class="view-btn @(viewMode == "day" ? "active" : "")" @onclick="SetViewDay">Jour</button>
            <button class="view-btn @(viewMode == "week" ? "active" : "")" @onclick="SetViewWeek">Semaine</button>
            <button class="view-btn @(viewMode == "month" ? "active" : "")" @onclick="SetViewMonth">Mois</button>
            <button class="view-btn" @onclick="OpenWorkingHoursModal">⚙️ Horaires</button>
            <button class="view-btn" @onclick="OpenBlockSlotModal">🚫 Bloquer créneau</button>
        </div>
    </div>

    <!-- Month View -->
    @if (viewMode == "month")
    {
        <div class="calendar-container">
            <div style="padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                <button class="nav-btn" @onclick="PreviousPeriod">◀ Mois précédent</button>
                <span class="current-date">@currentDate.ToString("MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</span>
                <button class="nav-btn" @onclick="NextPeriod">Mois suivant ▶</button>
                <button class="nav-btn" @onclick="GoToToday">Aujourd'hui</button>
            </div>
            <div class="calendar-header">
                @foreach (var day in weekDays)
                {
                    <div class="calendar-day-header">@day</div>
                }
            </div>
            <div class="calendar-grid">
                @foreach (var day in monthDays)
                {
                    <div class="calendar-day @(day.Date.Date == DateTime.Today ? "today" : "") @(day.Month != currentDate.Month ? "other-month" : "")"
                         @onclick="() => SelectDate(day.Date)">
                        <div class="day-number">@day.Day</div>
                        @if (dayEvents.ContainsKey(day.Date))
                        {
                            @foreach (var evt in dayEvents[day.Date].Take(3))
                            {
                                <div class="event-item @GetEventClass(evt)" @onclick:stopPropagation @onclick="() => OpenEventDetail(evt)">
                                    <i class="fas @GetEventIcon(evt)"></i> @evt.Title
                                </div>
                            }
                            @if (dayEvents[day.Date].Count > 3)
                            {
                                <div class="more-events" @onclick:stopPropagation @onclick="() => ShowAllEvents(day.Date)">
                                    + @(dayEvents[day.Date].Count - 3) autres...
                                </div>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    }

    <!-- Day/Week View with Time Slots -->
    @if (viewMode == "day" || viewMode == "week")
    {
        <div class="calendar-container">
            <div style="padding: 16px; display: flex; justify-content: space-between; align-items: center;">
                <button class="nav-btn" @onclick="PreviousPeriod">◀</button>
                <span class="current-date">@currentDate.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</span>
                <button class="nav-btn" @onclick="NextPeriod">▶</button>
                <button class="nav-btn" @onclick="GoToToday">Aujourd'hui</button>
            </div>
            <div class="time-slots-view">
                @foreach (var slot in availableSlots)
                {
                    @if (slot.IsAvailable)
                    {
                        <div class="time-slot available" @onclick="() => OpenNewAppointmentModal(slot.StartTime)">
                            <div class="time-label">@slot.StartTime.ToString("HH:mm") - @slot.EndTime.ToString("HH:mm")</div>
                            <div class="slot-status">
                                <span class="slot-available"><i class="fas fa-check-circle"></i> Disponible</span>
                            </div>
                            <i class="fas fa-chevron-right" style="color: #9CA3AF;"></i>
                        </div>
                    }
                    else
                    {
                        <div class="time-slot unavailable">
                            <div class="time-label">@slot.StartTime.ToString("HH:mm") - @slot.EndTime.ToString("HH:mm")</div>
                            <div class="slot-status">
                                <span class="slot-unavailable"><i class="fas fa-times-circle"></i> Indisponible</span>
                            </div>
                            <i class="fas fa-chevron-right" style="color: #9CA3AF;"></i>
                        </div>
                    }
                }
                @if (!availableSlots.Any())
                {
                    <div style="text-align: center; padding: 60px; color: #6B7280;">
                        <i class="fas fa-calendar-times" style="font-size: 48px; margin-bottom: 16px;"></i>
                        <p>Aucun créneau disponible pour cette journée</p>
                        <button class="btn-primary" @onclick="OpenWorkingHoursModal">Configurer mes horaires</button>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Rendez-vous -->
@if (showAppointmentModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Nouveau rendez-vous</h3>
                <button style="background:none;border:none;font-size:24px;cursor:pointer;" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Patient</label>
                    <input type="text"
                           value="@newAppointment.PatientEmail"
                           @onchange="@(e => newAppointment.PatientEmail = e.Value?.ToString() ?? string.Empty)"
                           placeholder="Email du patient" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-calendar"></i> Date et heure</label>
                    <input type="datetime-local"
                           value="@newAppointment.DateTimeStr"
                           @onchange="@(e => newAppointment.DateTimeStr = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-clock"></i> Durée (minutes)</label>
                    <select value="@newAppointment.Duration"
                            @onchange="@(e => newAppointment.Duration = int.TryParse(e.Value?.ToString(), out var d) ? d : 30)">
                        <option value="15">15 min</option>
                        <option value="30">30 min</option>
                        <option value="45">45 min</option>
                        <option value="60">60 min</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-stethoscope"></i> Type</label>
                    <select value="@newAppointment.Type"
                            @onchange="@(e => newAppointment.Type = e.Value?.ToString() ?? string.Empty)">
                        <option value="Consultation">Consultation standard</option>
                        <option value="Téléconsultation">Téléconsultation</option>
                        <option value="Urgence">Urgence</option>
                        <option value="Contrôle">Contrôle</option>
                    </select>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-comment"></i> Notes</label>
                    <textarea rows="3"
                              @onchange="@(e => newAppointment.Notes = e.Value?.ToString())"
                              placeholder="Motif, notes supplémentaires...">@newAppointment.Notes</textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Annuler</button>
                <button class="btn-primary" @onclick="CreateAppointment" disabled="@isSaving">
                    @(isSaving ? "Création..." : "Créer le rendez-vous")
                </button>
            </div>
        </div>
    </div>
}

<!-- Modal Horaires de travail -->
@if (showWorkingHoursModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" style="width: 600px;" @onclick:stopPropagation>
            <div class="modal-header">
                <h3><i class="fas fa-clock"></i> Mes horaires de travail</h3>
                <button style="background:none;border:none;font-size:24px;cursor:pointer;" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                @foreach (var wh in workingHoursList)
                {
                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; padding: 12px; background: #F9FAFB; border-radius: 12px;">
                        <div style="width: 100px; font-weight: 600;">@wh.DayName</div>
                        <div style="flex: 1;">
                            <input type="time"
                                   value="@wh.StartTime"
                                   @onchange="@(e => wh.StartTime = e.Value?.ToString() ?? wh.StartTime)"
                                   style="width: 100px; padding: 4px; border: 1px solid #E5E7EB; border-radius: 6px; margin-right: 8px;" />
                            <span>→</span>
                            <input type="time"
                                   value="@wh.EndTime"
                                   @onchange="@(e => wh.EndTime = e.Value?.ToString() ?? wh.EndTime)"
                                   style="width: 100px; padding: 4px; border: 1px solid #E5E7EB; border-radius: 6px; margin-left: 8px;" />
                        </div>
                        <div>
                            <label style="display: flex; align-items: center; gap: 6px;">
                                <input type="checkbox"
                                       checked="@wh.IsActive"
                                       @onchange="@(e => wh.IsActive = e.Value is bool b && b)" />
                                Actif
                            </label>
                        </div>
                    </div>
                }
                <div style="margin-top: 16px;">
                    <label>Durée par défaut des créneaux (minutes)</label>
                    <select value="@defaultSlotDuration"
                            @onchange="@(e => defaultSlotDuration = int.TryParse(e.Value?.ToString(), out var d) ? d : 30)"
                            style="width: 100%; padding: 10px; border-radius: 10px; border: 1px solid #E5E7EB;">
                        <option value="15">15 minutes</option>
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                        <option value="60">60 minutes</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Annuler</button>
                <button class="btn-primary" @onclick="SaveWorkingHours">Enregistrer</button>
            </div>
        </div>
    </div>
}

<!-- Modal Bloquer créneau -->
@if (showBlockSlotModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3><i class="fas fa-ban"></i> Bloquer un créneau</h3>
                <button style="background:none;border:none;font-size:24px;cursor:pointer;" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label><i class="fas fa-calendar"></i> Date de début</label>
                    <input type="datetime-local"
                           value="@newBlock.StartDateTimeStr"
                           @onchange="@(e => newBlock.StartDateTimeStr = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-calendar"></i> Date de fin</label>
                    <input type="datetime-local"
                           value="@newBlock.EndDateTimeStr"
                           @onchange="@(e => newBlock.EndDateTimeStr = e.Value?.ToString() ?? string.Empty)" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-tag"></i> Motif</label>
                    <select value="@newBlock.Reason"
                            @onchange="@(e => newBlock.Reason = e.Value?.ToString() ?? string.Empty)">
                        <option value="Congé">Congé</option>
                        <option value="Formation">Formation</option>
                        <option value="Réunion">Réunion</option>
                        <option value="RTT">RTT</option>
                        <option value="Autre">Autre</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                        <input type="checkbox"
                               checked="@newBlock.IsRecurring"
                               @onchange="@(e => newBlock.IsRecurring = e.Value is bool b && b)" />
                        Créneau récurrent (toutes les semaines)
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Annuler</button>
                <button class="btn-primary" @onclick="CreateBlockedSlot">Bloquer</button>
            </div>
        </div>
    </div>
}

@code {
    private string viewMode = "month";
    private DateTime currentDate = DateTime.Today;
    private List<string> weekDays = new() { "Lun", "Mar", "Mer", "Jeu", "Ven", "Sam", "Dim" };
    private List<DateTime> monthDays = new();
    private Dictionary<DateTime, List<AgendaCalendarEvent>> dayEvents = new();
    private List<AgendaAvailableSlot> availableSlots = new();
    private List<AgendaWorkingHour> workingHoursList = new();
    private int defaultSlotDuration = 30;
    private bool isSaving = false;

    private bool showAppointmentModal = false;
    private bool showWorkingHoursModal = false;
    private bool showBlockSlotModal = false;

    private AgendaNewAppointmentDto newAppointment = new();
    private AgendaNewBlockDto newBlock = new();

    // Named wrappers — avoids Razor parser breaking on string literals inside inline lambdas
    private async Task SetViewDay() => await SetViewMode("day");
    private async Task SetViewWeek() => await SetViewMode("week");
    private async Task SetViewMonth() => await SetViewMode("month");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadData();
    }

    private async Task LoadData()
    {
        await LoadWorkingHours();
        await LoadEvents();
        await LoadAvailableSlots();
        StateHasChanged();
    }

    private async Task LoadWorkingHours()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        try
        {
            var hours = await Http.GetFromJsonAsync<List<AgendaWorkingHour>>($"{baseUrl}/api/workinghours");
            if (hours != null && hours.Any())
            {
                workingHoursList = hours;
            }
            else
            {
                InitDefaultWorkingHours();
            }
        }
        catch
        {
            InitDefaultWorkingHours();
        }
    }

    private void InitDefaultWorkingHours()
    {
        workingHoursList.Clear();
        for (int i = 1; i <= 5; i++)
        {
            workingHoursList.Add(new AgendaWorkingHour
            {
                DayOfWeek = i,
                DayName = weekDays[i - 1],
                StartTime = "09:00",
                EndTime = "17:00",
                IsActive = true
            });
        }
    }

    private async Task LoadEvents()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        var startDate = new DateTime(currentDate.Year, currentDate.Month, 1);
        var endDate = startDate.AddMonths(1).AddDays(-1);
        try
        {
            var events = await Http.GetFromJsonAsync<List<AgendaCalendarEvent>>(
                $"{baseUrl}/api/agenda/events?start={startDate:yyyy-MM-dd}&end={endDate:yyyy-MM-dd}");
            dayEvents.Clear();
            foreach (var evt in events ?? new())
            {
                if (!dayEvents.ContainsKey(evt.Start.Date))
                    dayEvents[evt.Start.Date] = new();
                dayEvents[evt.Start.Date].Add(evt);
            }
        }
        catch { }
        GenerateMonthDays();
    }

    private async Task LoadAvailableSlots()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        try
        {
            availableSlots = await Http.GetFromJsonAsync<List<AgendaAvailableSlot>>(
                $"{baseUrl}/api/agenda/available-slots?date={currentDate:yyyy-MM-dd}") ?? new();
        }
        catch { availableSlots = new(); }
    }

    private void GenerateMonthDays()
    {
        monthDays.Clear();
        var firstOfMonth = new DateTime(currentDate.Year, currentDate.Month, 1);
        // Monday-first: Sun=0 in .NET, adjust so Mon=0
        int offset = ((int)firstOfMonth.DayOfWeek + 6) % 7;
        var startDate = firstOfMonth.AddDays(-offset);
        for (int i = 0; i < 42; i++)
            monthDays.Add(startDate.AddDays(i));
    }

    private async Task SetViewMode(string mode)
    {
        viewMode = mode;
        if (mode == "day" || mode == "week")
            await LoadAvailableSlots();
        else
            await LoadEvents();
        StateHasChanged();
    }

    private async Task SelectDate(DateTime date)
    {
        currentDate = date;
        await SetViewMode("day");
    }

    private async Task PreviousPeriod()
    {
        if (viewMode == "month")
        {
            currentDate = currentDate.AddMonths(-1);
            await LoadEvents();
        }
        else
        {
            currentDate = currentDate.AddDays(-1);
            await LoadAvailableSlots();
        }
        StateHasChanged();
    }

    private async Task NextPeriod()
    {
        if (viewMode == "month")
        {
            currentDate = currentDate.AddMonths(1);
            await LoadEvents();
        }
        else
        {
            currentDate = currentDate.AddDays(1);
            await LoadAvailableSlots();
        }
        StateHasChanged();
    }

    private async Task GoToToday()
    {
        currentDate = DateTime.Today;
        if (viewMode == "month")
            await LoadEvents();
        else
            await LoadAvailableSlots();
        StateHasChanged();
    }

    private void OpenNewAppointmentModal(DateTime startTime)
    {
        newAppointment = new AgendaNewAppointmentDto
        {
            DateTimeStr = startTime.ToString("yyyy-MM-ddTHH:mm"),
            Duration = defaultSlotDuration,
            Type = "Consultation"
        };
        showAppointmentModal = true;
        StateHasChanged();
    }

    private void OpenWorkingHoursModal()
    {
        showWorkingHoursModal = true;
        StateHasChanged();
    }

    private void OpenBlockSlotModal()
    {
        newBlock = new AgendaNewBlockDto();
        showBlockSlotModal = true;
        StateHasChanged();
    }

    private void OpenEventDetail(AgendaCalendarEvent evt) { /* TODO */ }
    private void ShowAllEvents(DateTime date) { /* TODO */ }

    private async Task CreateAppointment()
    {
        isSaving = true;
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        try
        {
            await Http.PostAsJsonAsync($"{baseUrl}/api/appointments", newAppointment);
            showAppointmentModal = false;
            await LoadAvailableSlots();
            await LoadEvents();
            await ShowToast("Rendez-vous créé avec succès");
        }
        catch (Exception ex)
        {
            await ShowToast($"Erreur: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveWorkingHours()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        try
        {
            foreach (var wh in workingHoursList.Where(h => h.IsActive))
            {
                await Http.PostAsJsonAsync($"{baseUrl}/api/workinghours", new
                {
                    DayOfWeek = wh.DayOfWeek,
                    StartTime = wh.StartTime,
                    EndTime = wh.EndTime,
                    SlotDuration = defaultSlotDuration
                });
            }
            showWorkingHoursModal = false;
            await ShowToast("Horaires enregistrés");
        }
        catch (Exception ex)
        {
            await ShowToast($"Erreur: {ex.Message}");
        }
    }

    private async Task CreateBlockedSlot()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        try
        {
            await Http.PostAsJsonAsync($"{baseUrl}/api/blockedslots", new
            {
                StartDateTime = DateTime.Parse(newBlock.StartDateTimeStr),
                EndDateTime = DateTime.Parse(newBlock.EndDateTimeStr),
                Reason = newBlock.Reason,
                IsRecurring = newBlock.IsRecurring
            });
            showBlockSlotModal = false;
            await LoadEvents();
            await ShowToast("Créneau bloqué");
        }
        catch (Exception ex)
        {
            await ShowToast($"Erreur: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        showAppointmentModal = false;
        showWorkingHoursModal = false;
        showBlockSlotModal = false;
        StateHasChanged();
    }

    private async Task ShowToast(string message)
        => await JS.InvokeVoidAsync("alert", message);

    private string GetEventClass(AgendaCalendarEvent evt) => evt.Type switch
    {
        "appointment" when evt.IsUrgent => "event-appointment-urgent",
        "appointment" => "event-appointment",
        "blocked" => "event-blocked",
        _ => "event-appointment"
    };

    private string GetEventIcon(AgendaCalendarEvent evt) => evt.Type switch
    {
        "appointment" => "fa-calendar-check",
        "blocked" => "fa-ban",
        _ => "fa-calendar"
    };

