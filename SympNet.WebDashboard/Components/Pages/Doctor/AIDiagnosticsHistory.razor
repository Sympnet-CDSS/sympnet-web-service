@page "/doctor/ai-diagnostics"
@layout SympNet.WebDashboard.Components.Layout.DoctorLayout
@using System.Text
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Historique IA</PageTitle>

<div class="page-container">
    <div class="page-header-controls">
        <div class="header-text">
            <h1>Historique des Diagnostics <span class="highlight-badge">IA</span></h1>
            <p>Retrouvez toutes les analyses effectuées par le système multi-agents.</p>
        </div>
        <div class="header-actions">
            <button class="btn-outline" @onclick="ExportCsv">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                Exporter (CSV)
            </button>
        </div>
    </div>

    <div class="table-container">
        <div class="table-controls">
            <div class="search-box">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input type="text" placeholder="Rechercher par patient ou condition..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <button class="filter-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                Filtrer
            </button>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Chargement de l'historique IA...</p>
            </div>
        }
        else if (filteredDiagnostics.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-brain"></i></div>
                <h3>Aucun diagnostic IA</h3>
                <p>@(string.IsNullOrEmpty(searchTerm) ? "Vous n'avez pas encore utilisé l'IA pour diagnostiquer des patients." : "Aucun résultat pour cette recherche.")</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>DATE</th>
                        <th>PATIENT</th>
                        <th>SYMPTÔMES / ZONE</th>
                        <th>PRÉDICTION PRINCIPALE</th>
                        <th>CONFIANCE</th>
                        <th>URGENCE</th>
                        <th style="text-align: right;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var diag in filteredDiagnostics)
                    {
                        var urgency = GetUrgencyFromScore(diag.ConfidenceScore);
                        var uClass = urgency == "Haute" ? "badge-danger" : (urgency == "Moyenne" ? "badge-warning" : "badge-success");
                        
                        <tr>
                            <td>
                                <div class="c-date">@diag.CreatedAt.ToString("dd MMM yyyy")</div>
                                <div class="c-time">@diag.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div class="patient-avatar">@GetInitials(diag.PatientName)</div>
                                    <div class="p-name"><strong>@diag.PatientName</strong></div>
                                </div>
                            </td>
                            <td>
                                <div class="symptom-text" title="@diag.Symptoms">@(string.IsNullOrEmpty(diag.Symptoms) ? "Non spécifié" : (diag.Symptoms.Length > 30 ? diag.Symptoms.Substring(0, 30) + "..." : diag.Symptoms))</div>
                            </td>
                            <td>
                                <div class="d-value">@(!string.IsNullOrEmpty(diag.Diagnosis) ? diag.Diagnosis : "Non déterminé")</div>
                            </td>
                            <td>
                                <div class="score-container">
                                    <div class="score-bar-bg"><div class="score-bar-fill" style="width: @(diag.ConfidenceScore)%"></div></div>
                                    <span class="score-text">@diag.ConfidenceScore.ToString("0")%</span>
                                </div>
                            </td>
                            <td>
                                <span class="urgency-badge @uClass">@urgency</span>
                            </td>
                            <td style="text-align: right;">
                                <div class="action-icons">
                                    <button class="icon-btn" title="Voir les détails" @onclick="() => GoToDetails(diag.Id)">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<style>
    .page-container { padding: 24px; max-width: 1200px; margin: 0 auto; animation: fadeIn 0.4s ease; }
    
    .page-header-controls { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
    .header-text h1 { margin: 0 0 4px; font-size: 24px; font-weight: 700; color: #111827; display: flex; align-items: center; gap: 8px; }
    .highlight-badge { background: #3B82F6; color: white; padding: 4px 8px; border-radius: 6px; font-size: 18px; }
    .header-text p { margin: 0; color: #6B7280; font-size: 14px; }
    
    .btn-outline { background: white; color: #374151; border: 1px solid #D1D5DB; padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: 0.2s; }
    .btn-outline:hover { background: #F9FAFB; color: #111827; }
    
    .table-container { background: white; border-radius: 16px; border: 1px solid #E5E7EB; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); }
    .table-controls { padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #F3F4F6; }
    
    .search-box { position: relative; width: 300px; }
    .search-box svg { position: absolute; left: 14px; top: 11px; }
    .search-box input { width: 100%; padding: 10px 14px 10px 40px; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; outline: none; transition: 0.2s; }
    .search-box input:focus { border-color: #0D9488; box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1); }
    
    .filter-btn { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: white; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; font-weight: 600; color: #374151; cursor: pointer; transition: 0.2s; }
    .filter-btn:hover { background: #F9FAFB; }
    
    .data-table { width: 100%; border-collapse: collapse; }
    .data-table th { text-align: left; padding: 16px 24px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; color: #6B7280; background: #F9FAFB; border-bottom: 1px solid #E5E7EB; }
    .data-table td { padding: 16px 24px; border-bottom: 1px solid #F3F4F6; vertical-align: middle; }
    .data-table tr:hover td { background: #F9FAFB; }
    
    .c-date { font-size: 14px; font-weight: 600; color: #111827; }
    .c-time { font-size: 13px; color: #6B7280; }
    
    .patient-avatar { width: 36px; height: 36px; border-radius: 50%; background: #0D9488; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .p-name { font-size: 14px; color: #111827; }
    
    .symptom-text { font-size: 13px; color: #4B5563; }
    .d-value { font-size: 14px; font-weight: 600; color: #111827; }
    
    .score-container { display: flex; align-items: center; gap: 8px; }
    .score-bar-bg { flex: 1; max-width: 60px; height: 6px; background: #E5E7EB; border-radius: 4px; overflow: hidden; }
    .score-bar-fill { height: 100%; background: #0D9488; border-radius: 4px; }
    .score-text { font-size: 12px; font-weight: 600; color: #374151; min-width: 30px; }
    
    .urgency-badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .badge-danger { background: #FEF2F2; color: #DC2626; border: 1px solid #FEE2E2; }
    .badge-warning { background: #FFF7ED; color: #EA580C; border: 1px solid #FFEDD5; }
    .badge-success { background: #F0FDF4; color: #16A34A; border: 1px solid #DCFCE7; }
    
    .action-icons { display: flex; align-items: center; justify-content: flex-end; gap: 8px; }
    .icon-btn { background: none; border: none; padding: 6px; color: #6B7280; cursor: pointer; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
    .icon-btn:hover { background: #E5E7EB; color: #111827; }
    
    .loading-state { text-align: center; padding: 60px; color: #6B7280; }
    .spinner { width: 40px; height: 40px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto 16px; animation: spin 1s linear infinite; }
    
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-icon { font-size: 48px; color: #D1D5DB; margin-bottom: 16px; }
    .empty-state h3 { margin: 0 0 8px; font-size: 18px; color: #111827; }
    .empty-state p { margin: 0; color: #6B7280; font-size: 14px; }

    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<DiagDto> diagnostics = new();
    private string searchTerm = "";
    private bool isLoading = true;

    private List<DiagDto> filteredDiagnostics => diagnostics
        .Where(d => string.IsNullOrEmpty(searchTerm) ||
                   d.PatientName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   d.Diagnosis.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   d.Symptoms.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDiagnostics();
        }
    }

    private async Task LoadDiagnostics()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                
                // Pour l'historique IA, on récupère les consultations qui ont un score de confiance (ce qui indique que l'IA a été utilisée)
                var consultations = await Http.GetFromJsonAsync<List<ConsultationDto>>($"{baseUrl}/api/consultations") ?? new();
                
                diagnostics = consultations
                    .Where(c => c.ConfidenceScore > 0)
                    .Select(c => new DiagDto
                    {
                        Id = c.Id,
                        PatientName = c.PatientName,
                        Symptoms = c.Diagnosis, // Use diagnosis as symptoms or just map it 
                        Diagnosis = c.Diagnosis,
                        ConfidenceScore = c.ConfidenceScore,
                        CreatedAt = c.CreatedAt
                    })
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GoToDetails(int id)
    {
        Navigation.NavigateTo($"/doctor/ai-diagnostic-details/{id}");
    }

    private string GetUrgencyFromScore(double score)
    {
        if (score > 85) return "Haute";
        if (score > 60) return "Moyenne";
        return "Basse";
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "IA";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[parts.Length - 1].Substring(0, 1)).ToUpper();
    }

    private async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("Date,Patient,Symptômes,Diagnostic,Confiance,Urgence");
        
        foreach (var diag in filteredDiagnostics)
        {
            var date = diag.CreatedAt.ToString("yyyy-MM-dd HH:mm");
            var patient = $"\"{diag.PatientName.Replace("\"", "\"\"")}\"";
            var symptoms = $"\"{diag.Symptoms.Replace("\"", "\"\"")}\"";
            var diagnosis = $"\"{diag.Diagnosis.Replace("\"", "\"\"")}\"";
            var urgency = GetUrgencyFromScore(diag.ConfidenceScore);
            
            sb.AppendLine($"{date},{patient},{symptoms},{diagnosis},{diag.ConfidenceScore},{urgency}");
        }

        var csvContent = sb.ToString();
        var bytes = Encoding.UTF8.GetBytes(csvContent);
        // JS interop to download file
        await JS.InvokeVoidAsync("downloadFileFromBytes", "historique_ia.csv", "text/csv", bytes);
    }

    public class ConsultationDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string Diagnosis { get; set; } = "";
        public double ConfidenceScore { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    public class DiagDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string Symptoms { get; set; } = "";
        public string Diagnosis { get; set; } = "";
        public double ConfidenceScore { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
