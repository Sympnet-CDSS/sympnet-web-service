@page "/doctor/video-call"
@page "/doctor/video-call/{targetUserId:guid}"
@layout DoctorLayout
@using Microsoft.AspNetCore.SignalR.Client
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config
@implements IAsyncDisposable

<PageTitle>SympNet — Téléconsultation</PageTitle>

<style>
    .video-call-container {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #0F172A;
        z-index: 1000;
        display: flex;
        flex-direction: column;
    }
    .videos-area {
        flex: 1;
        display: flex;
        gap: 20px;
        padding: 24px;
        position: relative;
    }
    .remote-video-wrapper {
        flex: 2;
        background: #1E293B;
        border-radius: 28px;
        overflow: hidden;
        position: relative;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        border: 1px solid rgba(13,148,136,0.3);
    }
    .remote-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .local-video-wrapper {
        position: absolute;
        bottom: 24px;
        right: 24px;
        width: 240px;
        background: #0F172A;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.5);
        border: 2px solid #0D9488;
        cursor: pointer;
        transition: all 0.3s;
        z-index: 10;
    }
    .local-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .video-label {
        position: absolute;
        bottom: 12px;
        left: 12px;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(8px);
        padding: 6px 14px;
        border-radius: 24px;
        font-size: 12px;
        font-weight: 500;
        color: white;
    }
    .connection-status {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(0,0,0,0.7);
        backdrop-filter: blur(8px);
        padding: 8px 16px;
        border-radius: 24px;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    .status-dot.connected { background: #10B981; }
    .call-controls {
        background: rgba(15,23,42,0.95);
        backdrop-filter: blur(20px);
        padding: 20px 40px;
        display: flex;
        justify-content: center;
        gap: 24px;
        border-top: 1px solid rgba(255,255,255,0.1);
    }
    .control-btn {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        border: none;
        cursor: pointer;
        transition: all 0.2s;
        font-size: 24px;
        color: white;
    }
    .control-btn:hover {
        transform: scale(1.08);
        background: rgba(255,255,255,0.2);
    }
    .control-btn.active {
        background: #0D9488;
    }
    .control-btn.end-call {
        background: #EF4444;
    }
    @@keyframes ring {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }
</style>

<div class="video-call-container">
    @if (isLoading)
    {
        <div style="position: absolute; inset: 0; background: #0F172A; z-index: 2000; display: flex; flex-direction: column; align-items: center; justify-content: center; color: white;">
            <div style="width: 60px; height: 60px; border: 4px solid rgba(13,148,136,0.1); border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 20px;"></div>
            <p style="font-size: 18px; font-weight: 500; color: #94A3B8;">Initialisation de la caméra...</p>
        </div>
        <style>
            @@keyframes spin { to { transform: rotate(360deg); } }
        </style>
    }

    <div class="videos-area">
        <div class="remote-video-wrapper">
            <video id="remoteVideo" class="remote-video" autoplay playsinline></video>
            <div class="video-label">Patient</div>
            <div class="connection-status">
                <div class="status-dot connected"></div>
                <span>Connecté</span>
            </div>
        </div>
        <div class="local-video-wrapper">
            <video id="localVideo" class="local-video" autoplay playsinline muted></video>
            <div class="video-label">Dr. Médecin</div>
        </div>
    </div>
    <div class="call-controls">
        <button class="control-btn active" id="btnMic" title="Microphone" @onclick="ToggleMicrophone">
            <i class="fas fa-microphone-alt"></i>
        </button>
        <button class="control-btn active" id="btnCamera" title="Caméra" @onclick="ToggleVideo">
            <i class="fas fa-video"></i>
        </button>
        <button class="control-btn" id="btnScreen" title="Partage d'écran" @onclick="ToggleScreenShare">
            <i class="fas fa-desktop"></i>
        </button>
        <button class="control-btn end-call" id="btnEndCall" title="Raccrocher" @onclick="EndCall">
            <i class="fas fa-phone-slash"></i>
        </button>
    </div>
</div>

@code {
    [Parameter] public Guid? TargetUserId { get; set; }
    
    // Paramètres venant du popup de layout
    private string? querySessionId;
    private string? queryCallerId;
    private string? querySdp;

    private string token = "";
    private bool isLoading = true;
    private HubConnection? hubConnection;
    private DotNetObjectReference<VideoCall>? objRef;

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        
        if (query.TryGetValue("sessionId", out var sid)) querySessionId = sid;
        if (query.TryGetValue("callerId", out var cid)) queryCallerId = cid;
        if (query.TryGetValue("sdp", out var sdp)) querySdp = sdp;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // Petit délai de sécurité pour le DOM
            token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token") ?? "";
            
            if (string.IsNullOrEmpty(querySdp))
            {
                querySdp = await JS.InvokeAsync<string>("sessionStorage.getItem", "pending_sdp");
                await JS.InvokeVoidAsync("sessionStorage.removeItem", "pending_sdp");
            }

            await InitializeSignalR();
            await InitializeWebRTC();
            
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitializeSignalR()
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        Console.WriteLine($"[SignalR] Connecting to {baseUrl}/hubs/chat");
        
        hubConnection = new HubConnectionBuilder()
            .WithUrl($"{baseUrl}/hubs/chat", options =>
            {
                options.AccessTokenProvider = () => Task.FromResult<string?>(token);
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string, string, string, string>("IncomingCall", async (sessionId, callerId, callerName, sdp) =>
        {
            Console.WriteLine($"[SignalR] Incoming call from {callerName} ({callerId})");
            // Si on est déjà sur la page d'appel et que c'est la bonne personne qui appelle
            if (TargetUserId != null && TargetUserId.ToString() == callerId)
            {
                await JS.InvokeVoidAsync("webrtc.handleOffer", callerId, sdp);
            }
        });

        hubConnection.On<string, string>("ReceiveAnswer", async (fromUserId, sdp) =>
        {
            Console.WriteLine($"[SignalR] Answer received from {fromUserId}");
            await JS.InvokeVoidAsync("webrtc.handleAnswer", fromUserId, sdp);
        });

        hubConnection.On<string, string, string, int>("ReceiveIceCandidate", async (fromUserId, candidate, sdpMid, sdpMLineIndex) =>
        {
            await JS.InvokeVoidAsync("webrtc.handleIceCandidate", fromUserId, candidate, sdpMid, sdpMLineIndex);
        });

        hubConnection.On<string>("CallRejected", async (sessionId) =>
        {
            await JS.InvokeVoidAsync("webrtc.endCall");
            await JS.InvokeVoidAsync("alert", "Appel rejeté");
            Navigation.NavigateTo("/doctor/dashboard");
        });

        hubConnection.On<string>("CallEnded", async (sessionId) =>
        {
            await JS.InvokeVoidAsync("webrtc.endCall");
            await JS.InvokeVoidAsync("alert", $"Appel terminé");
            Navigation.NavigateTo("/doctor/dashboard");
        });

        await hubConnection.StartAsync();
        Console.WriteLine("[SignalR] Connection established");
    }

    private async Task InitializeWebRTC()
    {
        objRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("webrtc.init", objRef, hubConnection);
        
        if (querySdp != null && queryCallerId != null)
        {
            // ✅ On vient d'un appel accepté via le popup
            if (hubConnection != null)
            {
                await hubConnection.SendAsync("AcceptCall", queryCallerId, querySessionId);
            }
            await JS.InvokeVoidAsync("webrtc.handleOffer", queryCallerId, querySdp);
        }
        else if (TargetUserId != null)
        {
            // ✅ On initie l'appel
            await JS.InvokeVoidAsync("webrtc.startCall", TargetUserId.ToString());
        }
    }

    [JSInvokable]
    public async Task SendOffer(string targetUserId, string sdp)
    {
        if (hubConnection != null)
        {
            await hubConnection.SendAsync("SendOffer", targetUserId, sdp);
        }
    }

    [JSInvokable]
    public async Task SendAnswer(string targetUserId, string sdp)
    {
        if (hubConnection != null)
        {
            await hubConnection.SendAsync("SendAnswer", targetUserId, sdp);
        }
    }

    [JSInvokable]
    public async Task SendIceCandidate(string targetUserId, string candidate, string sdpMid, int sdpMLineIndex)
    {
        if (hubConnection != null)
        {
            await hubConnection.SendAsync("SendIceCandidate", targetUserId, candidate, sdpMid, sdpMLineIndex);
        }
    }

    private async Task ToggleMicrophone()
    {
        await JS.InvokeVoidAsync("webrtc.toggleMicrophone");
    }

    private async Task ToggleVideo()
    {
        await JS.InvokeVoidAsync("webrtc.toggleVideo");
    }

    private async Task ToggleScreenShare()
    {
        await JS.InvokeVoidAsync("webrtc.toggleScreenShare");
    }

    private async Task EndCall()
    {
        if (hubConnection != null && TargetUserId != null)
        {
            await hubConnection.SendAsync("EndCall", TargetUserId.ToString(), querySessionId ?? "");
        }
        await JS.InvokeVoidAsync("webrtc.endCall");
        Navigation.NavigateTo("/doctor/dashboard");
    }

    public async ValueTask DisposeAsync()
    {
        objRef?.Dispose();
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // Classes pour les données
    public class IncomingCallData
    {
        public Guid SessionId { get; set; }
        public Guid CallerId { get; set; }
        public string CallerName { get; set; } = "";
        public Guid ConversationId { get; set; }
    }

    public class CallEndData
    {
        public Guid SessionId { get; set; }
        public int Duration { get; set; }
    }
}
