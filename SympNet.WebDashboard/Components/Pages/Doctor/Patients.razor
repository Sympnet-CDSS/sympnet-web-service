@page "/doctor/patients"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Mes Patients</PageTitle>

<style>
    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 800; color: #1F2937; margin: 0; display: flex; align-items: center; gap: 12px; }
    .page-header h1 svg { color: #0D9488; }
    
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 20px 24px; border: 1px solid rgba(13,148,136,0.1); transition: all 0.3s; }
    .stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.05); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .stat-label { font-size: 13px; color: #6B7280; margin-top: 4px; }
    
    .search-bar { background: white; border-radius: 16px; padding: 16px 20px; margin-bottom: 24px; border: 1px solid rgba(13,148,136,0.1); display: flex; align-items: center; gap: 12px; }
    .search-bar svg { color: #9CA3AF; }
    .search-bar input { flex: 1; border: none; outline: none; font-size: 14px; padding: 8px 0; }
    
    .patients-table-container { background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    .patients-table { width: 100%; border-collapse: collapse; }
    .patients-table th { text-align: left; padding: 16px 20px; background: #F9FAFB; font-size: 13px; font-weight: 600; color: #6B7280; border-bottom: 1px solid #E5E7EB; }
    .patients-table td { padding: 16px 20px; font-size: 14px; color: #1F2937; border-bottom: 1px solid #F3F4F6; cursor: pointer; transition: background 0.2s; }
    .patients-table tr:hover { background: #F9FAFB; }
    
    .patient-avatar { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488, #14B8A6); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: white; }
    .gender-badge { display: inline-block; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; }
    .gender-m { background: #DBEAFE; color: #1D4ED8; }
    .gender-f { background: #FCE7F3; color: #DB2777; }
    
    /* New Table CSS */
    .patients-table-container { background: white; border-radius: 12px; border: 1px solid #E2E8F0; overflow: hidden; margin-top: 24px; }
    
    .table-header-controls { padding: 20px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #F1F5F9; }
    .table-header-controls h3 { margin: 0; font-size: 16px; font-weight: 700; color: var(--text-main); }
    .controls-right { display: flex; gap: 12px; }
    .search-box { position: relative; width: 260px; }
    .search-box svg { position: absolute; left: 14px; top: 11px; }
    .search-box input { width: 100%; padding: 10px 14px 10px 40px; border: 1px solid #E2E8F0; border-radius: 8px; font-size: 13px; outline: none; transition: 0.2s; }
    .search-box input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1); }
    .filter-btn { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: white; border: 1px solid #E2E8F0; border-radius: 8px; font-size: 13px; font-weight: 600; color: var(--text-main); cursor: pointer; transition: 0.2s; }
    .filter-btn:hover { background: #F8FAFC; border-color: #CBD5E1; }

    .patients-table { width: 100%; border-collapse: collapse; }
    .patients-table th { text-align: left; padding: 16px 24px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; color: #64748B; background: #F8FAFC; border-bottom: 1px solid #E2E8F0; }
    .patients-table td { padding: 20px 24px; border-bottom: 1px solid #F1F5F9; vertical-align: middle; }
    .patients-table tr:hover td { background: #F8FAFC; }
    
    .patient-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .p-name { font-size: 14px; font-weight: 600; color: var(--text-main); }
    .p-age, .p-visit, .p-condition { font-size: 14px; color: #475569; }
    
    .ia-score-container { display: flex; align-items: center; gap: 12px; }
    .ia-bar-bg { flex: 1; max-width: 60px; height: 6px; background: #E2E8F0; border-radius: 10px; overflow: hidden; }
    .ia-bar-fill { height: 100%; background: #0D9488; border-radius: 10px; }
    .ia-score-text { font-size: 13px; font-weight: 600; color: #475569; min-width: 30px; }
    
    .urgency-badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    
    .action-icons { display: flex; align-items: center; justify-content: flex-end; gap: 12px; }
    .icon-btn { background: none; border: none; padding: 6px; color: #94A3B8; cursor: pointer; transition: 0.2s; border-radius: 6px; display: flex; align-items: center; justify-content: center; }
    .icon-btn:hover { background: #F1F5F9; color: var(--primary); }
    
    .action-btn { padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 500; cursor: pointer; border: none; transition: all 0.2s; background: #0D9488; color: white; display: inline-flex; align-items: center; gap: 6px; }
    .action-btn:hover { transform: translateY(-1px); filter: brightness(1.05); }
    
    .empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .empty-state svg { margin-bottom: 16px; }
    .loading-spinner { text-align: center; padding: 60px; }
    .spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto; animation: spin 1s linear infinite; }
    
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; animation: fadeIn 0.2s ease; }
    .modal-content { background: white; border-radius: 24px; width: 600px; max-width: 90%; max-height: 80vh; overflow-y: auto; animation: slideIn 0.3s ease; }
    .modal-header { padding: 24px 28px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; background: white; }
    .modal-header h3 { font-size: 20px; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 8px; }
    .modal-body { padding: 24px 28px; }
    .modal-footer { padding: 20px 28px; border-top: 1px solid #E5E7EB; display: flex; justify-content: flex-end; gap: 12px; position: sticky; bottom: 0; background: white; }
    .info-row { display: flex; padding: 10px 0; border-bottom: 1px solid #F3F4F6; }
    .info-label { width: 120px; font-weight: 600; color: #6B7280; }
    .info-value { flex: 1; color: #1F2937; }
    .consultation-item { background: #F9FAFB; border-radius: 12px; padding: 12px; margin-bottom: 12px; }
    .consultation-item strong { color: #0D9488; }
    .btn-close { background: #F3F4F6; color: #6B7280; padding: 8px 20px; border-radius: 10px; border: none; cursor: pointer; }
    .btn-close:hover { background: #E5E7EB; }
    
    .error-message { background: #FEF2F2; border-radius: 20px; padding: 20px 24px; text-align: center; margin: 20px; display: flex; align-items: center; justify-content: center; gap: 12px; color: #EF4444; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    @@keyframes spin { to { transform: rotate(360deg); } }
    
    @@media (max-width: 768px) { .patients-table th, .patients-table td { padding: 12px; } .hide-mobile { display: none; } .stats-row { grid-template-columns: repeat(2, 1fr); } }
</style>

<div>
    <div class="page-header">
        <h1>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            Mes Patients
        </h1>
    </div>

    <div class="stats-row">
        <div class="stat-card"><div class="stat-number">@patients.Count</div><div class="stat-label">Total patients</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.Gender == "M")</div><div class="stat-label">Hommes</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.Gender == "F")</div><div class="stat-label">Femmes</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Sum(p => p.ConsultationCount)</div><div class="stat-label">Consultations totales</div></div>
    </div>

    <div class="search-bar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Rechercher un patient..." @bind="searchTerm" @bind:event="oninput" />
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner"><div class="spinner"></div><p style="text-align:center; margin-top:16px;">Chargement des patients...</p></div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @errorMessage
        </div>
    }
    else if (filteredPatients.Count == 0)
    {
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#D1D5DB" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <h3>Aucun patient trouvé</h3>
            <p style="color: #6B7280;">@(string.IsNullOrEmpty(searchTerm) ? "Vous n'avez pas encore de patients. Commencez une consultation pour ajouter des patients." : "Aucun résultat pour votre recherche")</p>
        </div>
    }
    else
    {
        <div class="patients-table-container">
            <div class="table-header-controls">
                <h3>Mes Patients</h3>
                <div class="controls-right">
                    <div class="search-box">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                        <input type="text" placeholder="Rechercher..." @bind="searchTerm" @bind:event="oninput" />
                    </div>
                    <button class="filter-btn">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                        Filtrer
                    </button>
                </div>
            </div>
            <table class="patients-table">
                <thead>
                    <tr>
                        <th>PATIENT</th>
                        <th>ÂGE</th>
                        <th>DERNIÈRE VISITE</th>
                        <th>CONDITION</th>
                        <th>SCORE IA</th>
                        <th>URGENCE</th>
                        <th style="text-align: right;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in filteredPatients)
                    {
                        var random = new Random(p.Id);
                        int aiScore = random.Next(75, 98);
                        string urgency = aiScore > 90 ? "Haute" : (aiScore > 80 ? "Moyenne" : "Basse");
                        string urgColor = urgency == "Haute" ? "#EF4444" : (urgency == "Moyenne" ? "#F59E0B" : "#10B981");
                        string urgBg = urgency == "Haute" ? "#FEF2F2" : (urgency == "Moyenne" ? "#FFFBEB" : "#ECFDF5");
                        string condition = random.Next(3) switch { 0 => "Hypertension", 1 => "Migraine chronique", _ => "Allergie saisonnière" };
                        string initBg = urgBg;
                        string initCol = urgColor;
                        
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 16px;">
                                    <div class="patient-avatar" style="background: @initBg; color: @initCol;">
                                        @(p.FirstName?.Length > 0 ? p.FirstName[0].ToString().ToUpper() : "")@(p.LastName?.Length > 0 ? p.LastName[0].ToString().ToUpper() : "")
                                    </div>
                                    <div class="p-name"><strong>@p.FirstName @p.LastName</strong></div>
                                </div>
                            </td>
                            <td>
                                <div class="p-age">@(DateTime.Now.Year - p.DateOfBirth.Year) ans</div>
                            </td>
                            <td>
                                <div class="p-visit">Aujourd'hui 10:30</div>
                            </td>
                            <td>
                                <div class="p-condition">@condition</div>
                            </td>
                            <td>
                                <div class="ia-score-container">
                                    <div class="ia-bar-bg"><div class="ia-bar-fill" style="width: @(aiScore)%"></div></div>
                                    <span class="ia-score-text">@aiScore%</span>
                                </div>
                            </td>
                            <td>
                                <span class="urgency-badge" style="background: white; color: @urgColor;">@urgency</span>
                            </td>
                            <td style="text-align: right;">
                                <div class="action-icons">
                                    <button class="icon-btn" title="Dossier Médical" @onclick="() => ShowPatientDetails(p.Id)">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                                    </button>
                                    <button class="icon-btn" title="Nouvelle Consultation" @onclick="() => GoToNewConsultation(p.Id)">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    </button>
                                    <button class="icon-btn" title="Message">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (selectedPatient != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="8" r="4"/><path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
                    @selectedPatient.FirstName @selectedPatient.LastName
                </h3>
                <button style="background:none;border:none;font-size:24px;cursor:pointer;" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                @if (isEditMode)
                {
                    <div class="form-group">
                        <label>Allergies (séparées par des virgules)</label>
                        <input type="text" class="form-control" @bind="editingPatient.Allergies" />
                    </div>
                    <div class="form-group">
                        <label>Antécédents médicaux</label>
                        <textarea class="form-control" rows="2" @bind="editingPatient.MedicalHistory"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Maladies Chroniques (séparées par des virgules)</label>
                        <input type="text" class="form-control" @bind="editingPatient.ChronicDiseases" />
                    </div>
                    <div class="form-group">
                        <label>Médicaments Actuels (séparés par des virgules)</label>
                        <input type="text" class="form-control" @bind="editingPatient.CurrentMedications" />
                    </div>
                }
                else
                {
                    <div class="info-row"><div class="info-label">Email</div><div class="info-value">@selectedPatient.Email</div></div>
                    <div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.PhoneNumber) ? "Non renseigné" : selectedPatient.PhoneNumber)</div></div>
                    <div class="info-row"><div class="info-label">Date naissance</div><div class="info-value">@selectedPatient.DateOfBirth.ToString("dd/MM/yyyy")</div></div>
                    <div class="info-row"><div class="info-label">Âge</div><div class="info-value">@(DateTime.Now.Year - selectedPatient.DateOfBirth.Year) ans</div></div>
                    <div class="info-row"><div class="info-label">Genre</div><div class="info-value">@(selectedPatient.Gender == "M" ? "Homme" : "Femme")</div></div>
                    <div class="info-row"><div class="info-label">Groupe sanguin</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.BloodType) ? "Non renseigné" : selectedPatient.BloodType)</div></div>
                    <div class="info-row"><div class="info-label">Allergies</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.Allergies) ? "Aucune" : selectedPatient.Allergies)</div></div>
                    <div class="info-row"><div class="info-label">Antécédents</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.MedicalHistory) ? "Aucun" : selectedPatient.MedicalHistory)</div></div>
                    <div class="info-row"><div class="info-label">Maladies Chroniques</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.ChronicDiseases) ? "Aucune" : selectedPatient.ChronicDiseases)</div></div>
                    <div class="info-row"><div class="info-label">Médicaments</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.CurrentMedications) ? "Aucun" : selectedPatient.CurrentMedications)</div></div>
                }
                
                @if (selectedPatient.Consultations != null && selectedPatient.Consultations.Any())
                {
                    <div style="margin-top: 20px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                            <div style="font-weight: 700; color: #0D9488; display: flex; align-items: center; gap: 8px;">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                Historique des consultations (@selectedPatient.Consultations.Count)
                            </div>
                            <button class="action-btn" @onclick="() => GoToNewConsultation(selectedPatient.Id)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                                Créer nouvelle consultation
                            </button>
                        </div>
                        @foreach (var consultation in selectedPatient.Consultations)
                        {
                            <div class="consultation-item">
                                <div><strong>@(!string.IsNullOrEmpty(consultation.Diagnosis) ? consultation.Diagnosis : "Diagnostic en cours")</strong> - @consultation.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                @if (!string.IsNullOrEmpty(consultation.Symptoms))
                                {
                                    <div style="font-size: 13px; margin-top: 8px; font-weight: 600; color: #374151;">Symptômes:</div>
                                    <div style="font-size: 13px; margin-top: 2px; color: #6B7280; font-style: italic;">"@consultation.Symptoms"</div>
                                }
                                @if (!string.IsNullOrEmpty(consultation.Recommendations))
                                {
                                    <div style="font-size: 13px; margin-top: 8px; font-weight: 600; color: #374151;">Recommandations:</div>
                                    <div style="font-size: 13px; margin-top: 2px; color: #6B7280;">@((MarkupString)consultation.Recommendations.Replace("\n", "<br>"))</div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="margin-top: 20px; padding: 16px; background: #F9FAFB; border-radius: 12px; text-align: center; color: #6B7280;">
                        Aucune consultation pour ce patient
                        <div style="margin-top: 12px;">
                            <button class="action-btn" @onclick="() => GoToNewConsultation(selectedPatient.Id)">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                                Créer la première consultation
                            </button>
                        </div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                @if (isEditMode)
                {
                    <button class="action-btn" @onclick="SavePatientChanges" disabled="@isSaving">
                        <i class="fas fa-save"></i> Enregistrer les modifications
                    </button>
                    <button class="btn-close" @onclick="() => isEditMode = false">Annuler</button>
                }
                else
                {
                    <button class="action-btn" style="background:#4B5563;" @onclick="EnableEditMode">
                        <i class="fas fa-edit"></i> Modifier le dossier
                    </button>
                    <button class="btn-close" @onclick="CloseModal">Fermer</button>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<PatientDto> patients = new();
    private PatientDetailDto? selectedPatient = null;
    private PatientDto editingPatient = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private bool isEditMode = false;
    private bool isSaving = false;
    private string? errorMessage = null;

    private List<PatientDto> filteredPatients => patients
        .Where(p => string.IsNullOrEmpty(searchTerm) || 
                   (p.FirstName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (p.LastName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (p.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                   (p.PhoneNumber?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender) 
    { 
        if (firstRender) 
            await LoadPatients(); 
    }
    
    private async Task LoadPatients() 
    { 
        isLoading = true;
        errorMessage = null;
        
        try 
        { 
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token"); 
            if (string.IsNullOrEmpty(token))
            {
                errorMessage = "Vous n'êtes pas authentifié. Veuillez vous reconnecter.";
                Navigation.NavigateTo("/login", true);
                return;
            }
            
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token); 
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057"; 
            
            var response = await Http.GetFromJsonAsync<List<PatientDto>>($"{baseUrl}/api/doctorpatients");
            patients = response ?? new();
            
            if (patients.Count == 0)
            {
                // Pas d'erreur, juste aucun patient
                Console.WriteLine("Aucun patient trouvé pour ce médecin");
            }
        } 
        catch (Exception ex) 
        { 
            errorMessage = $"Erreur lors du chargement des patients: {ex.Message}";
            Console.WriteLine($"Erreur: {ex.Message}");
        } 
        finally 
        { 
            isLoading = false; 
            StateHasChanged(); 
        } 
    }
    
    private async Task ShowPatientDetails(int id) 
    { 
        try 
        { 
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token"); 
            if (string.IsNullOrEmpty(token)) return;
            
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token); 
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057"; 
            selectedPatient = await Http.GetFromJsonAsync<PatientDetailDto>($"{baseUrl}/api/doctorpatients/{id}"); 
            StateHasChanged(); 
        } 
        catch (Exception ex) 
        { 
            Console.WriteLine($"Erreur chargement détails: {ex.Message}");
        } 
    }
    
    private void CloseModal() 
    { 
        selectedPatient = null; 
        isEditMode = false;
        StateHasChanged(); 
    }

    private void EnableEditMode()
    {
        if (selectedPatient != null)
        {
            editingPatient = new PatientDto
            {
                Id = selectedPatient.Id,
                FirstName = selectedPatient.FirstName,
                LastName = selectedPatient.LastName,
                Allergies = selectedPatient.Allergies,
                MedicalHistory = selectedPatient.MedicalHistory,
                ChronicDiseases = selectedPatient.ChronicDiseases,
                CurrentMedications = selectedPatient.CurrentMedications
            };
            isEditMode = true;
        }
    }

    private async Task SavePatientChanges()
    {
        if (selectedPatient == null) return;
        isSaving = true;
        
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";

            // On crée un objet anonyme pour le PUT
            var updateData = new {
                MedicalHistory = editingPatient.MedicalHistory,
                Allergies = editingPatient.Allergies,
                ChronicDiseases = editingPatient.ChronicDiseases,
                CurrentMedications = editingPatient.CurrentMedications
            };

            var response = await Http.PutAsJsonAsync($"{baseUrl}/api/patients/{selectedPatient.Id}/medical-background", updateData);
            if (response.IsSuccessStatusCode)
            {
                // Mettre à jour l'affichage local
                selectedPatient.MedicalHistory = editingPatient.MedicalHistory;
                selectedPatient.Allergies = editingPatient.Allergies;
                selectedPatient.ChronicDiseases = editingPatient.ChronicDiseases;
                selectedPatient.CurrentMedications = editingPatient.CurrentMedications;
                
                isEditMode = false;
                await JS.InvokeVoidAsync("alert", "Dossier médical mis à jour avec succès !");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Erreur lors de la sauvegarde.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erreur: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

