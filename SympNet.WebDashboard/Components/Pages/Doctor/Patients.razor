@page "/doctor/patients"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Mes patients</PageTitle>

<style>
    .patients-container { max-width: 1400px; margin: 0 auto; padding: 20px; }
    .page-header h1 { font-size: 28px; font-weight: 800; color: #1F2937; margin-bottom: 28px; }
    .page-header h1 i { color: #0D9488; margin-right: 12px; }
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 20px 24px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .stat-label { font-size: 13px; color: #6B7280; margin-top: 4px; }
    .search-bar { background: white; border-radius: 16px; padding: 16px 20px; margin-bottom: 24px; border: 1px solid rgba(13,148,136,0.1); display: flex; align-items: center; gap: 12px; }
    .search-bar i { color: #9CA3AF; font-size: 18px; }
    .search-bar input { flex: 1; border: none; outline: none; font-size: 14px; padding: 8px 0; }
    .patients-table { background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; width: 100%; border-collapse: collapse; }
    .patients-table th { text-align: left; padding: 16px 20px; background: #F9FAFB; font-size: 13px; font-weight: 600; color: #6B7280; border-bottom: 1px solid #E5E7EB; }
    .patients-table td { padding: 16px 20px; font-size: 14px; color: #1F2937; border-bottom: 1px solid #F3F4F6; cursor: pointer; }
    .patients-table tr:hover { background: #F9FAFB; }
    .patient-avatar { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488, #14B8A6); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: white; }
    .gender-badge { display: inline-block; padding: 4px 10px; border-radius: 100px; font-size: 11px; font-weight: 600; }
    .gender-m { background: #DBEAFE; color: #1D4ED8; }
    .gender-f { background: #FCE7F3; color: #DB2777; }
    .empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .loading-spinner { text-align: center; padding: 60px; }
    .spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto; animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-content { background: white; border-radius: 24px; width: 600px; max-width: 90%; max-height: 80vh; overflow-y: auto; }
    .modal-header { padding: 24px 28px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; }
    .modal-header h3 { font-size: 20px; font-weight: 700; margin: 0; }
    .modal-body { padding: 24px 28px; }
    .modal-footer { padding: 20px 28px; border-top: 1px solid #E5E7EB; display: flex; justify-content: flex-end; gap: 12px; }
    .btn-close { background: #F3F4F6; color: #6B7280; padding: 8px 20px; border-radius: 10px; border: none; cursor: pointer; }
</style>

<div class="patients-container">
    <div class="page-header">
        <h1><i class="fas fa-users"></i> Mes patients</h1>
    </div>

    <div class="stats-row">
        <div class="stat-card"><div class="stat-number">@patients.Count</div><div class="stat-label">Total patients</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.Gender == "M")</div><div class="stat-label">Hommes</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Count(p => p.Gender == "F")</div><div class="stat-label">Femmes</div></div>
        <div class="stat-card"><div class="stat-number">@patients.Sum(p => p.ConsultationCount)</div><div class="stat-label">Total consultations</div></div>
    </div>

    <div class="search-bar">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Rechercher un patient..." @bind="searchTerm" @bind:event="oninput" />
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner"><div class="spinner"></div></div>
    }
    else if (filteredPatients.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-user-slash" style="font-size: 64px; color: #D1D5DB; margin-bottom: 16px;"></i>
            <h3>Aucun patient trouvé</h3>
            <p style="color: #6B7280;">@(string.IsNullOrEmpty(searchTerm) ? "Aucun patient pour le moment" : "Aucun résultat pour votre recherche")</p>
        </div>
    }
    else
    {
        <table class="patients-table">
            <thead>
                <tr><th>Patient</th><th>Contact</th><th>Âge</th><th>Genre</th><th>Consultations</th></tr>
            </thead>
            <tbody>
                @foreach (var p in filteredPatients)
                {
                    <tr @onclick="() => ShowPatientDetails(p)">
                        <td>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="patient-avatar">@(p.FirstName?.Length > 0 ? p.FirstName[0].ToString().ToUpper() : "P")</div>
                                <div><strong>@p.FirstName @p.LastName</strong></div>
                            </div>
                        </td>
                        <td>
                            <div style="font-size: 13px;">@p.Email</div>
                            <div style="font-size: 12px; color: #9CA3AF;">@p.PhoneNumber</div>
                        </td>
                        <td>@(DateTime.Now.Year - p.DateOfBirth.Year) ans</td>
                        <td><span class="gender-badge gender-@(p.Gender == "M" ? "m" : "f")">@(p.Gender == "M" ? "Homme" : "Femme")</span></td>
                        <td>@p.ConsultationCount</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- Modal Détails Patient -->
@if (selectedPatient != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3><i class="fas fa-user-circle"></i> @selectedPatient.FirstName @selectedPatient.LastName</h3>
                <button style="background:none;border:none;font-size:24px;cursor:pointer;" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="info-row"><div class="info-label">Email</div><div class="info-value">@selectedPatient.Email</div></div>
                <div class="info-row"><div class="info-label">Téléphone</div><div class="info-value">@selectedPatient.PhoneNumber</div></div>
                <div class="info-row"><div class="info-label">Date de naissance</div><div class="info-value">@selectedPatient.DateOfBirth.ToString("dd/MM/yyyy")</div></div>
                <div class="info-row"><div class="info-label">Groupe sanguin</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.BloodType) ? "Non renseigné" : selectedPatient.BloodType)</div></div>
                <div class="info-row"><div class="info-label">Allergies</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.Allergies) ? "Aucune" : selectedPatient.Allergies)</div></div>
                <div class="info-row"><div class="info-label">Antécédents</div><div class="info-value">@(string.IsNullOrEmpty(selectedPatient.MedicalHistory) ? "Aucun" : selectedPatient.MedicalHistory)</div></div>
                
                @if (selectedPatient.Consultations != null && selectedPatient.Consultations.Any())
                {
                    <div style="margin-top: 20px;">
                        <div style="font-weight: 700; margin-bottom: 12px; color: #0D9488;">📋 Historique des consultations</div>
                        @foreach (var consultation in selectedPatient.Consultations)
                        {
                            <div style="background: #F9FAFB; border-radius: 12px; padding: 12px; margin-bottom: 12px;">
                                <div><strong>@consultation.Diagnosis</strong> - @consultation.CreatedAt.ToString("dd/MM/yyyy")</div>
                                <div style="font-size: 13px; margin-top: 6px;">@consultation.Recommendations</div>
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-close" @onclick="CloseModal">Fermer</button>
            </div>
        </div>
    </div>
}

<style>
    .info-row { display: flex; padding: 8px 0; border-bottom: 1px solid #F3F4F6; }
    .info-label { width: 120px; font-weight: 600; color: #6B7280; }
    .info-value { flex: 1; color: #1F2937; }
</style>

@code {
    private List<PatientDto> patients = new();
    private PatientDetailDto? selectedPatient = null;
    private string searchTerm = "";
    private bool isLoading = true;

    private List<PatientDto> filteredPatients => patients
        .Where(p => string.IsNullOrEmpty(searchTerm) ||
                   p.FirstName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   p.LastName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   p.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   p.PhoneNumber.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadPatients();
        }
    }

    private async Task LoadPatients()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                patients = await Http.GetFromJsonAsync<List<PatientDto>>($"{baseUrl}/api/doctorpatients") ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ShowPatientDetails(PatientDto patient)
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            selectedPatient = await Http.GetFromJsonAsync<PatientDetailDto>($"{baseUrl}/api/doctorpatients/{patient.Id}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
    }

    private void CloseModal()
    {
        selectedPatient = null;
        StateHasChanged();
    }

    public class PatientDto
    {
        public int Id { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
        public DateTime DateOfBirth { get; set; }
        public string Gender { get; set; } = "";
        public string BloodType { get; set; } = "";
        public string Allergies { get; set; } = "";
        public string MedicalHistory { get; set; } = "";
        public int ConsultationCount { get; set; }
    }

    public class PatientDetailDto : PatientDto
    {
        public List<ConsultationBriefDto> Consultations { get; set; } = new();
    }

    public class ConsultationBriefDto
    {
        public int Id { get; set; }
        public string Diagnosis { get; set; } = "";
        public string Recommendations { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
