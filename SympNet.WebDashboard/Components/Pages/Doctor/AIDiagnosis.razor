@page "/doctor/ai-diagnosis"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>SympNet — Diagnostic IA</PageTitle>

<style>
    .diagnosis-container { max-width: 1200px; margin: 0 auto; }
    .card { background: white; border-radius: 24px; padding: 28px; margin-bottom: 24px; border: 1px solid rgba(13,148,136,0.1); }
    .card-title { font-size: 20px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; color: #0D9488; }
    .symptom-badge { background: #E6F8F7; color: #0D6E6A; padding: 8px 16px; border-radius: 20px; font-size: 14px; margin: 4px; display: inline-block; }
    .hypothesis-card { background: #F9FAFB; border-radius: 16px; padding: 20px; margin-bottom: 16px; border-left: 4px solid #0D9488; }
    .confidence-bar { height: 8px; background: #E5E7EB; border-radius: 4px; overflow: hidden; margin: 10px 0; }
    .confidence-fill { height: 100%; background: linear-gradient(90deg, #0D9488, #14B8A6); border-radius: 4px; transition: width 0.5s; }
    .voice-btn { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; border: none; padding: 12px 24px; border-radius: 12px; cursor: pointer; margin-right: 12px; font-size: 14px; transition: all 0.2s; }
    .voice-btn.recording { background: linear-gradient(135deg, #EF4444, #DC2626); animation: pulse 1.5s infinite; }
    .voice-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(13,148,136,0.3); }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.6; } 100% { opacity: 1; } }
    .loading-spinner { width: 40px; height: 40px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 20px auto; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    textarea { width: 100%; padding: 16px; border: 1.5px solid #E5E7EB; border-radius: 16px; font-size: 14px; resize: vertical; font-family: inherit; transition: all 0.2s; }
    textarea:focus { outline: none; border-color: #0D9488; box-shadow: 0 0 0 3px rgba(13,148,136,0.1); }
    .btn-diagnose { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; padding: 14px 28px; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 16px; font-size: 16px; transition: all 0.2s; }
    .btn-diagnose:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(13,148,136,0.3); }
    .btn-diagnose:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    .btn-save { background: linear-gradient(135deg, #10B981, #059669); color: white; padding: 14px 28px; border: none; border-radius: 12px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 16px; font-size: 16px; transition: all 0.2s; }
    .btn-save:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(16,185,129,0.3); }
    
    /* Modal design */
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 2000; animation: fadeIn 0.2s ease; }
    .modal-content { background: white; border-radius: 24px; width: 450px; max-width: 90%; overflow: hidden; animation: slideIn 0.3s ease; }
    .modal-header { padding: 24px 28px 0 28px; text-align: center; }
    .modal-icon { width: 64px; height: 64px; border-radius: 50%; background: #E0F2FE; color: #0D9488; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .modal-icon i { font-size: 32px; }
    .modal-header h3 { font-size: 20px; font-weight: 700; color: #1F2937; margin: 0 0 8px; }
    .modal-body { padding: 16px 28px; }
    .form-group { margin-bottom: 20px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 8px; color: #374151; }
    .form-group input { width: 100%; padding: 12px 14px; border: 1.5px solid #E5E7EB; border-radius: 12px; font-size: 14px; transition: all 0.2s; }
    .form-group input:focus { outline: none; border-color: #0D9488; box-shadow: 0 0 0 3px rgba(13,148,136,0.1); }
    .modal-footer { padding: 20px 28px 28px; display: flex; gap: 12px; justify-content: center; }
    .btn-cancel { background: #F3F4F6; color: #6B7280; border: none; padding: 10px 24px; border-radius: 12px; font-weight: 500; cursor: pointer; transition: all 0.2s; }
    .btn-cancel:hover { background: #E5E7EB; }
    .btn-confirm { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; border: none; padding: 10px 28px; border-radius: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-confirm:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(13,148,136,0.3); }
    .btn-confirm:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
    
    /* Toast notification */
    .toast-container { position: fixed; bottom: 30px; right: 30px; z-index: 10000; display: flex; flex-direction: column; gap: 12px; }
    .toast { background: white; border-radius: 16px; padding: 16px 24px; display: flex; align-items: center; gap: 14px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.15), 0 8px 10px -6px rgba(0,0,0,0.05); min-width: 320px; animation: slideInRight 0.3s ease; border-left: 5px solid; }
    .toast.success { border-left-color: #10B981; }
    .toast.error { border-left-color: #EF4444; }
    .toast.info { border-left-color: #0D9488; }
    .toast-icon { width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .toast.success .toast-icon { background: #D1FAE5; color: #10B981; }
    .toast.error .toast-icon { background: #FEE2E2; color: #EF4444; }
    .toast.info .toast-icon { background: #E0F2FE; color: #0D9488; }
    .toast-icon i { font-size: 18px; }
    .toast-content { flex: 1; }
    .toast-title { font-weight: 700; font-size: 14px; margin-bottom: 2px; }
    .toast-message { font-size: 13px; color: #6B7280; }
    .toast-close { background: none; border: none; color: #9CA3AF; cursor: pointer; font-size: 16px; padding: 4px; }
    .toast-close:hover { color: #6B7280; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideIn { from { transform: scale(0.95); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    @@keyframes slideInRight { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    
    .example-card { background: #F9FAFB; border-radius: 12px; padding: 12px 16px; margin: 8px 0; cursor: pointer; transition: all 0.2s; border: 1px solid #E5E7EB; }
    .example-card:hover { background: #E6F8F7; border-color: #0D9488; transform: translateX(4px); }
    .example-text { font-size: 13px; color: #4B5563; }
    .example-title { font-weight: 600; color: #0D9488; margin-bottom: 4px; font-size: 14px; }
    .record-status { display: inline-block; width: 12px; height: 12px; border-radius: 50%; background-color: #10B981; margin-left: 12px; animation: blink 1s infinite; }
    .record-status.recording { background-color: #EF4444; }
    @@keyframes blink { 0% { opacity: 1; } 50% { opacity: 0.3; } 100% { opacity: 1; } }
</style>

<div class="diagnosis-container">
    <div class="card">
        <div class="card-title">
            <i class="fas fa-microphone-alt"></i> 
            Diagnostic Assisté par IA Multi-Agents
            <span class="record-status @(isRecording ? "recording" : "")"></span>
        </div>
        
        <div style="margin-bottom: 20px;">
            <button class="voice-btn @(isRecording ? "recording" : "")" @onclick="ToggleRecording">
                <i class="fas @(isRecording ? "fa-stop" : "fa-microphone")"></i>
                @(isRecording ? "Arrêter l'enregistrement" : "🎙️ Décrire les symptômes (voix)")
            </button>
            <button class="voice-btn" @onclick="ClearText">
                <i class="fas fa-trash-alt"></i> Effacer
            </button>
        </div>
        
        <textarea rows="5" @bind="patientText" placeholder="Décrivez les symptômes du patient...&#10;Exemple: 'Le patient a de la fièvre à 39°C, une toux grasse et des difficultés respiratoires depuis 3 jours'"></textarea>
        
        <button class="btn-diagnose" @onclick="AnalyzeDiagnosis" disabled="@isLoading">
            @if (isLoading) 
            {
                <span class="loading-spinner" style="width:20px;height:20px;display:inline-block;margin-right:10px;"></span>
                <span>Analyse en cours...</span>
            }
            else
            {
                <span><i class="fas fa-stethoscope"></i> Analyser avec l'IA Multi-Agents</span>
            }
        </button>
    </div>

    <div class="card">
        <div class="card-title"><i class="fas fa-lightbulb"></i> Exemples de descriptions</div>
        <div class="example-card" @onclick="() => SetExample(1)">
            <div class="example-title">🔴 Pneumonie</div>
            <div class="example-text">"Fièvre à 39.5°C, toux grasse avec expectorations verdâtres, douleur thoracique droite à l'inspiration, difficulté respiratoire"</div>
        </div>
        <div class="example-card" @onclick="() => SetExample(2)">
            <div class="example-title">🟠 Grippe</div>
            <div class="example-text">"Fièvre soudaine à 38.8°C, frissons, courbatures généralisées, maux de tête sévères, fatigue extrême"</div>
        </div>
        <div class="example-card" @onclick="() => SetExample(3)">
            <div class="example-title">🟡 COVID-19</div>
            <div class="example-text">"Fièvre modérée, toux sèche, fatigue intense, perte totale du goût et de l'odorat, essoufflement à l'effort"</div>
        </div>
    </div>
    
    @if (diagnosisResult != null)
    {
        <div class="card">
            <div class="card-title"><i class="fas fa-notes-medical"></i> Symptômes détectés</div>
            <div>
                @foreach (var symptom in symptoms)
                {
                    <span class="symptom-badge">@symptom</span>
                }
            </div>
        </div>
        
        <div class="card">
            <div class="card-title"><i class="fas fa-diagnoses"></i> Hypothèses diagnostiques</div>
            @foreach (var hyp in hypotheses)
            {
                <div class="hypothesis-card">
                    <h3 style="margin: 0 0 10px 0; color: #0D9488;">@hyp.Diagnosis</h3>
                    <div class="confidence-bar">
                        <div class="confidence-fill" style="width: @(hyp.Confidence * 100)%"></div>
                    </div>
                    <p style="margin: 10px 0; color: #6B7280;">Score de confiance: @(hyp.Confidence * 100)%</p>
                    <p style="margin: 10px 0;">@hyp.Explanation</p>
                </div>
            }
        </div>
        
        <div class="card">
            <div class="card-title"><i class="fas fa-chart-line"></i> Score de confiance global</div>
            <div class="confidence-bar" style="height: 12px;">
                <div class="confidence-fill" style="width: @(confidenceLevel * 100)%"></div>
            </div>
            <p style="text-align: center; margin-top: 10px; font-size: 24px; font-weight: 700; color: #0D9488;">@(confidenceLevel * 100)%</p>
        </div>
        
        @if (recommendations.Any())
        {
            <div class="card">
                <div class="card-title"><i class="fas fa-list-check"></i> Recommandations cliniques</div>
                <ul style="margin: 0; padding-left: 20px;">
                    @foreach (var rec in recommendations)
                    {
                        <li style="margin: 8px 0; color: #4B5563;">@rec</li>
                    }
                </ul>
            </div>
        }
        
        <div class="card" style="text-align: center;">
            <button class="btn-save" @onclick="OpenSaveModal">
                <i class="fas fa-save"></i> Enregistrer cette consultation
            </button>
        </div>
    }
</div>

<!-- Modal pour enregistrer la consultation -->
@if (showSaveModal)
{
    <div class="modal-overlay" @onclick="CloseSaveModal">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <div class="modal-icon">
                    <i class="fas fa-save"></i>
                </div>
                <h3>Enregistrer la consultation</h3>
                <p style="color: #6B7280; font-size: 14px; margin-top: 8px;">Saisissez les informations du patient</p>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Nom complet du patient</label>
                    <input type="text" @bind="patientName" placeholder="Ex: Jean Dupont" />
                </div>
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email du patient</label>
                    <input type="email" @bind="patientEmail" placeholder="Ex: jean.dupont@email.com" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" @onclick="CloseSaveModal">Annuler</button>
                <button class="btn-confirm" @onclick="SaveConsultation" disabled="@isSaving">
                    @if (isSaving) { <span class="loading-spinner" style="width:16px;height:16px;margin-right:8px;"></span> }
                    @(isSaving ? "Enregistrement..." : "Enregistrer")
                </button>
            </div>
        </div>
    </div>
}

<!-- Toast Container -->
<div class="toast-container">
    @foreach (var toast in toasts)
    {
        <div class="toast @toast.Type">
            <div class="toast-icon">
                <i class="fas @toast.Icon"></i>
            </div>
            <div class="toast-content">
                <div class="toast-title">@toast.Title</div>
                <div class="toast-message">@toast.Message</div>
            </div>
            <button class="toast-close" @onclick="() => RemoveToast(toast.Id)">×</button>
        </div>
    }
</div>

@code {
    private string patientText = "";
    private bool isLoading = false;
    private bool isRecording = false;
    private bool showSaveModal = false;
    private bool isSaving = false;
    private string patientName = "";
    private string patientEmail = "";
    private List<string> symptoms = new();
    private List<Hypothesis> hypotheses = new();
    private double confidenceLevel = 0;
    private List<string> recommendations = new();
    private object? diagnosisResult = null;
    
    private List<ToastMessage> toasts = new();
    private int nextToastId = 1;

    private void ShowToast(string title, string message, string type = "success")
    {
        var toast = new ToastMessage
        {
            Id = nextToastId++,
            Title = title,
            Message = message,
            Type = type,
            Icon = type == "success" ? "fa-check-circle" : type == "error" ? "fa-exclamation-circle" : "fa-info-circle"
        };
        toasts.Add(toast);
        StateHasChanged();
        
        // Auto-remove after 4 seconds
        Task.Delay(4000).ContinueWith(_ => 
        {
            InvokeAsync(() => RemoveToast(toast.Id));
        });
    }
    
    private void RemoveToast(int id)
    {
        var toast = toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null)
        {
            toasts.Remove(toast);
            StateHasChanged();
        }
    }

    public class ToastMessage
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "success";
        public string Icon { get; set; } = "fa-check-circle";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initAudioRecorder");
        }
    }

    private void OpenSaveModal()
    {
        patientName = "";
        patientEmail = "";
        showSaveModal = true;
        StateHasChanged();
    }

    private void CloseSaveModal()
    {
        showSaveModal = false;
        StateHasChanged();
    }

    private void SetExample(int exampleNumber)
    {
        switch (exampleNumber)
        {
            case 1:
                patientText = "Le patient présente une forte fièvre à 39.5°C depuis 3 jours, une toux grasse avec des expectorations verdâtres, une douleur thoracique du côté droit qui s'aggrave à l'inspiration profonde, et une difficulté respiratoire même au repos.";
                break;
            case 2:
                patientText = "Patient de 35 ans avec apparition soudaine de fièvre à 38.8°C, frissons intenses, courbatures généralisées, maux de tête sévères et fatigue extrême. Toux sèche irritative.";
                break;
            case 3:
                patientText = "La patiente présente depuis 4 jours une fièvre modérée à 38.2°C, une toux sèche persistante, une grande fatigue, une perte totale du goût et de l'odorat.";
                break;
        }
        StateHasChanged();
    }

    private async Task ToggleRecording()
    {
        if (isRecording)
        {
            await JS.InvokeVoidAsync("stopRecording");
            isRecording = false;
            var transcribedText = await JS.InvokeAsync<string>("getTranscribedText");
            if (!string.IsNullOrEmpty(transcribedText))
            {
                patientText = transcribedText;
                StateHasChanged();
            }
        }
        else
        {
            await JS.InvokeVoidAsync("startRecording");
            isRecording = true;
            StateHasChanged();
        }
    }

    private void ClearText()
    {
        patientText = "";
        diagnosisResult = null;
        symptoms.Clear();
        hypotheses.Clear();
        recommendations.Clear();
        confidenceLevel = 0;
        StateHasChanged();
    }

    private async Task AnalyzeDiagnosis()
    {
        if (string.IsNullOrWhiteSpace(patientText))
        {
            ShowToast("Information manquante", "Veuillez décrire les symptômes du patient.", "error");
            return;
        }
        
        isLoading = true;
        StateHasChanged();
        
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            var request = new { patient_text = patientText, symptoms = new List<string>() };
            var response = await Http.PostAsJsonAsync("http://localhost:8000/diagnose", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<DiagnosisApiResponse>();
                if (result != null)
                {
                    symptoms = result.Hypotheses.SelectMany(h => h.SupportingEvidence ?? new List<string>()).Distinct().ToList();
                    hypotheses = result.Hypotheses.Select(h => new Hypothesis
                    {
                        Diagnosis = h.Diagnosis,
                        Confidence = h.Confidence,
                        Explanation = h.Explanation
                    }).ToList();
                    confidenceLevel = result.ConfidenceScores?.OverallConfidence ?? 0.5;
                    recommendations = result.Recommendations ?? new List<string>();
                    diagnosisResult = result;
                }
            }
            else
            {
                ShowToast("Erreur d'analyse", "L'analyse IA a échoué. Veuillez réessayer.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Erreur de connexion", $"Impossible de contacter le service IA: {ex.Message}", "error");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task SaveConsultation()
    {
        if (string.IsNullOrWhiteSpace(patientName))
        {
            ShowToast("Information manquante", "Veuillez saisir le nom du patient", "error");
            return;
        }
        
        if (string.IsNullOrWhiteSpace(patientEmail))
        {
            ShowToast("Information manquante", "Veuillez saisir l'email du patient", "error");
            return;
        }
        
        isSaving = true;
        StateHasChanged();
        
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            var consultation = new
            {
                patientName = patientName,
                patientEmail = patientEmail,
                symptoms = patientText,
                diagnosis = hypotheses.FirstOrDefault()?.Diagnosis ?? "",
                recommendations = string.Join("\n", recommendations),
                confidenceScore = confidenceLevel
            };
            
            var response = await Http.PostAsJsonAsync($"{Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057"}/api/consultations", consultation);
            
            if (response.IsSuccessStatusCode)
            {
                ShowToast("Consultation enregistrée", $"✓ La consultation pour {patientName} a été sauvegardée avec succès", "success");
                showSaveModal = false;
                patientName = "";
                patientEmail = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                ShowToast("Erreur d'enregistrement", $"Impossible d'enregistrer: {error}", "error");
            }
        }
        catch (Exception ex)
        {
            ShowToast("Erreur de connexion", $"Erreur: {ex.Message}", "error");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    public class Hypothesis
    {
        public string Diagnosis { get; set; } = "";
        public double Confidence { get; set; }
        public string Explanation { get; set; } = "";
    }

    public class DiagnosisApiResponse
    {
        public List<HypothesisApi> Hypotheses { get; set; } = new();
        public ConfidenceScoresApi? ConfidenceScores { get; set; }
        public List<string> Recommendations { get; set; } = new();
    }

    public class HypothesisApi
    {
        public string Diagnosis { get; set; } = "";
        public double Confidence { get; set; }
        public string Explanation { get; set; } = "";
        public List<string>? SupportingEvidence { get; set; }
    }

    public class ConfidenceScoresApi
    {
        public double OverallConfidence { get; set; }
    }
}
