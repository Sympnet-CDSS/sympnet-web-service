        flex-shrink: 0;
        background: #F3F4F6;
        color: #6B7280;
    }

    .unread .notif-icon-wrapper {
        background: rgba(13, 148, 136, 0.1);
        color: #0D9488;
    }

    .urgent .notif-icon-wrapper {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
    }

    .notif-body {
        flex: 1;
    }

    .notif-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
    }

    .notif-header h3 {
        font-size: 16px;
        font-weight: 700;
        color: #1F2937;
        margin: 0;
    }

    .notif-time {
        font-size: 12px;
        color: #9CA3AF;
    }

    .notif-message {
        font-size: 14px;
        color: #4B5563;
        line-height: 1.6;
        margin-bottom: 12px;
    }

    .notif-actions {
        display: flex;
        gap: 12px;
    }

    .btn-action {
        background: #F3F4F6;
        border: none;
        color: #4B5563;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
    }

    .btn-action:hover {
        background: #E5E7EB;
        color: #1F2937;
    }

    .notif-controls {
        display: flex;
        align-items: center;
    }

    .btn-icon-check {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid #E5E7EB;
        background: white;
        color: #9CA3AF;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-icon-check:hover {
        border-color: #0D9488;
        color: #0D9488;
        background: rgba(13, 148, 136, 0.05);
    }

    .loading-state, .empty-state {
        padding: 80px 40px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 16px;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid rgba(13, 148, 136, 0.1);
        border-top-color: #0D9488;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .empty-icon {
        width: 80px;
        height: 80px;
        background: #F9FAFB;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        color: #D1D5DB;
        margin-bottom: 8px;
    }

    .empty-state h3 {
        font-size: 20px;
        font-weight: 700;
        color: #374151;
        margin: 0;
    }

    .empty-state p {
        color: #6B7280;
        max-width: 300px;
        line-height: 1.5;
    }

    @@media (max-width: 640px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
        
        .filter-bar {
            flex-direction: column;
            gap: 16px;
            align-items: stretch;
        }

        .search-box {
            width: 100%;
        }
    }
</style>

@code {
    private List<DoctorNotification> notifications = new();
    private bool isLoading = true;
    private string filter = "all";
    private string searchQuery = "";

    private IEnumerable<DoctorNotification> FilteredNotifications => 
        notifications.Where(n => 
            (filter == "all" || !n.IsRead) &&
            (string.IsNullOrWhiteSpace(searchQuery) || 
             n.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
             n.Message.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))
        ).OrderByDescending(n => n.SentAt);

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                var result = await Http.GetFromJsonAsync<List<DoctorNotification>>($"{baseUrl}/api/notifications");
                if (result != null)
                {
                    notifications = result;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading notifications: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task MarkAsRead(int id)
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PatchAsync($"{baseUrl}/api/notifications/{id}/read", null);
            if (response.IsSuccessStatusCode)
            {
                var notif = notifications.FirstOrDefault(n => n.Id == id);
                if (notif != null) notif.IsRead = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as read: {ex.Message}");
        }
    }

    private async Task MarkAllAsRead()
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PatchAsync($"{baseUrl}/api/notifications/read-all", null);
            if (response.IsSuccessStatusCode)
            {
                foreach (var n in notifications) n.IsRead = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking all as read: {ex.Message}");
        }
    }

    private async Task ClearAll()
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.DeleteAsync($"{baseUrl}/api/notifications");
            if (response.IsSuccessStatusCode)
            {
                notifications.Clear();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error clearing notifications: {ex.Message}");
        }
    }

    private string GetIcon(DoctorNotification notif)
    {
        if (notif.IsUrgent) return "fas fa-exclamation-triangle";
        if (notif.AppointmentId > 0) return "far fa-calendar-check";
        if (notif.Message.Contains("ordonnance", StringComparison.OrdinalIgnoreCase)) return "fas fa-file-prescription";
        return "far fa-bell";
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.UtcNow - dateTime;
        if (diff.TotalDays >= 1) return $"Il y a {Math.Floor(diff.TotalDays)} jour(s)";
        if (diff.TotalHours >= 1) return $"Il y a {Math.Floor(diff.TotalHours)} heure(s)";
        if (diff.TotalMinutes >= 1) return $"Il y a {Math.Floor(diff.TotalMinutes)} minute(s)";
        return "À l'instant";
    }

    private void GoToAppointment(int appointmentId)
    {
        Navigation.NavigateTo($"/doctor/appointments/{appointmentId}");
    }

    public class DoctorNotification
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public int AppointmentId { get; set; }
        public bool IsUrgent { get; set; }
        public bool IsRead { get; set; }
        public DateTime SentAt { get; set; }
    }
}
