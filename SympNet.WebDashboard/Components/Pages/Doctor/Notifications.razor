@page "/doctor/notifications"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject IConfiguration Config
@inject NavigationManager Navigation

<div class="notifications-page">
    <div class="page-header">
        <div class="header-content">
            <h1>Mes Notifications</h1>
            <p>Gérez vos alertes et mises à jour système.</p>
        </div>
        <div class="header-actions">
            <button class="btn-secondary" @onclick="MarkAllAsRead" disabled="@(!notifications.Any(n => !n.IsRead))">
                <i class="fas fa-check-double"></i> Tout marquer comme lu
            </button>
            <button class="btn-danger" @onclick="ClearAll" disabled="@(!notifications.Any())">
                <i class="fas fa-trash-alt"></i> Tout effacer
            </button>
        </div>
    </div>

    <div class="notifications-container">
        <div class="filter-bar">
            <div class="filter-tabs">
                <button class="filter-tab @(filter == "all" ? "active" : "")" @onclick='() => filter = "all"'>
                    Toutes <span>@notifications.Count</span>
                </button>
                <button class="filter-tab @(filter == "unread" ? "active" : "")" @onclick='() => filter = "unread"'>
                    Non lues <span>@notifications.Count(n => !n.IsRead)</span>
                </button>
            </div>
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Rechercher une notification..." @bind="searchQuery" @bind:event="oninput" />
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Chargement de vos notifications...</p>
            </div>
        }
        else if (!FilteredNotifications.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="far fa-bell-slash"></i>
                </div>
                <h3>Aucune notification</h3>
                <p>Vous n'avez aucune notification @(filter == "unread" ? "non lue" : "") pour le moment.</p>
            </div>
        }
        else
        {
            <div class="notifications-list">
                @foreach (var notif in FilteredNotifications)
                {
                    <div class="notification-card @(notif.IsRead ? "read" : "unread") @(notif.IsUrgent ? "urgent" : "")">
                        <div class="notif-icon-wrapper">
                            <i class="@GetIcon(notif)"></i>
                        </div>
                        <div class="notif-body">
                            <div class="notif-header">
                                <h3>@notif.Title</h3>
                                <span class="notif-time">@GetTimeAgo(notif.SentAt)</span>
                            </div>
                            <p class="notif-message">@notif.Message</p>
                            
                            @if (notif.AppointmentId > 0)
                            {
                                <div class="notif-actions">
                                    <button class="btn-action" @onclick="() => GoToAppointment(notif.AppointmentId)">
                                        Voir le rendez-vous <i class="fas fa-arrow-right"></i>
                                    </button>
                                </div>
                            }
                        </div>
                        <div class="notif-controls">
                            @if (!notif.IsRead)
                            {
                                <button class="btn-icon-check" @onclick="() => MarkAsRead(notif.Id)" title="Marquer comme lu">
                                    <i class="fas fa-check"></i>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .notifications-page {
        max-width: 1000px;
        margin: 0 auto;
        padding-bottom: 40px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 32px;
    }

    .header-content h1 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 32px;
        font-weight: 800;
        color: #1F2937;
        margin-bottom: 8px;
    }

    .header-content p {
        color: #6B7280;
        font-size: 16px;
    }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    .btn-secondary {
        background: white;
        border: 1px solid #E5E7EB;
        color: #374151;
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-secondary:hover:not(:disabled) {
        background: #F9FAFB;
        border-color: #D1D5DB;
    }

    .btn-danger {
        background: white;
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #EF4444;
        padding: 10px 20px;
        border-radius: 12px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-danger:hover:not(:disabled) {
        background: rgba(239, 68, 68, 0.05);
        border-color: #EF4444;
    }

    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .notifications-container {
        background: white;
        border-radius: 24px;
        border: 1px solid rgba(13, 148, 136, 0.1);
        box-shadow: 0 4px 25px rgba(0, 0, 0, 0.03);
        overflow: hidden;
    }

    .filter-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 32px;
        border-bottom: 1px solid #F3F4F6;
        background: #F9FAFB;
    }

    .filter-tabs {
        display: flex;
        gap: 8px;
    }

    .filter-tab {
        background: none;
        border: none;
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        color: #6B7280;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .filter-tab span {
        background: #E5E7EB;
        color: #4B5563;
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .filter-tab.active {
        background: white;
        color: #0D9488;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .filter-tab.active span {
        background: #0D9488;
        color: white;
    }

    .search-box {
        position: relative;
        width: 300px;
    }

    .search-box i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #9CA3AF;
        font-size: 14px;
    }

    .search-box input {
        width: 100%;
        padding: 10px 14px 10px 40px;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        font-size: 14px;
        transition: all 0.2s;
    }

    .search-box input:focus {
        outline: none;
        border-color: #0D9488;
        box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
    }

    .notifications-list {
        display: flex;
        flex-direction: column;
    }

    .notification-card {
