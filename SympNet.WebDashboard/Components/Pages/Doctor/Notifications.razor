        gap: 20px;
        padding: 24px 32px;
        border-bottom: 1px solid #F3F4F6;
        transition: all 0.2s;
        position: relative;
    }

    .notification-card:last-child {
        border-bottom: none;
    }

    .notification-card:hover {
        background: #F9FAFB;
    }

    .notification-card.unread {
        background: rgba(13, 148, 136, 0.02);
    }

    .notification-card.unread::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
