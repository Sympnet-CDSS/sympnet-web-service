@page "/doctor/consultations"
@layout SympNet.WebDashboard.Components.Layout.DoctorLayout
@using System.Text.Json
@using SympNet.WebDashboard.DTOs
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Mes consultations</PageTitle>

<div class="page-container">
    <div class="page-header-controls">
        <div class="header-text">
            <h1>Mes consultations</h1>
            <p>Retrouvez l'historique complet de vos consultations.</p>
        </div>
        <button class="btn-primary" @onclick="GoToNewConsultation">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Nouvelle consultation
        </button>
    </div>

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert-success">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            @successMessage
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert-error">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            @errorMessage
        </div>
    }

    <div class="table-container">
        <div class="table-controls">
            <div class="search-box">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <input type="text" placeholder="Rechercher par patient ou diagnostic..." @bind="searchTerm" @bind:event="oninput" />
            </div>
            <button class="filter-btn" @onclick="ToggleFilter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                Trier: @(sortAscending ? "Plus ancien" : "Plus récent")
            </button>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Chargement des consultations...</p>
            </div>
        }
        else if (filteredConsultations.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-folder-open"></i></div>
                <h3>Aucune consultation</h3>
                <p>@(string.IsNullOrEmpty(searchTerm) ? "Vous n'avez pas encore effectué de consultations." : "Aucun résultat ne correspond à votre recherche.")</p>
                @if (string.IsNullOrEmpty(searchTerm))
                {
                    <button class="btn-primary mt-3" @onclick="GoToNewConsultation">Démarrer une consultation</button>
                }
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>DATE</th>
                        <th>PATIENT</th>
                        <th>DIAGNOSTIC</th>
                        <th>STATUT</th>
                        <th style="text-align: right;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in filteredConsultations.Take(displayCount))
                    {
                        <tr>
                            <td>
                                <div class="c-date">@c.CreatedAt.ToString("dd MMM yyyy")</div>
                                <div class="c-time">@c.CreatedAt.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <div class="patient-avatar">@GetInitials(c.PatientName)</div>
                                    <div class="p-name"><strong>@c.PatientName</strong></div>
                                </div>
                            </td>
                            <td>
                                <div class="d-value">@(!string.IsNullOrEmpty(c.Diagnosis) ? c.Diagnosis : "Non spécifié")</div>
                            </td>
                            <td>
                                <span class="status-badge"><i class="fas fa-check-circle"></i> @c.Status</span>
                            </td>
                            <td style="text-align: right;">
                                <div class="action-icons">
                                    <button class="icon-btn" title="Voir les détails" @onclick="() => GoToConsultation(c.Id)">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    </button>
                                    <button class="icon-btn text-danger" title="Supprimer" @onclick="() => ConfirmDelete(c.Id)">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (filteredConsultations.Count > displayCount)
            {
                <div style="text-align: center; padding: 20px; border-top: 1px solid #F1F5F9;">
                    <button class="filter-btn" style="margin: 0 auto;" @onclick="LoadMore">Voir plus de consultations</button>
                </div>
            }
        }
    </div>
</div>

@if (showDeleteConfirm)
{
    <div class="modal-overlay">
        <div class="modal-confirm">
            <div class="modal-icon text-danger">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            </div>
            <h3>Confirmer la suppression</h3>
            <p>Êtes-vous sûr de vouloir supprimer cette consultation ? Cette action est irréversible.</p>
            <div class="modal-actions">
                <button class="btn-cancel" @onclick="() => showDeleteConfirm = false">Annuler</button>
                <button class="btn-danger" @onclick="DeleteConsultation">Supprimer</button>
            </div>
        </div>
    </div>
}

<style>
    .page-container {
        padding: 24px;
        max-width: 1200px;
        margin: 0 auto;
        animation: fadeIn 0.4s ease;
    }
    
    .page-header-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }
    
    .header-text h1 {
        margin: 0 0 4px;
        font-size: 24px;
        font-weight: 700;
        color: #111827;
    }
    
    .header-text p {
        margin: 0;
        color: #6B7280;
        font-size: 14px;
    }
    
    .btn-primary {
        background: #0D9488;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }
    
    .btn-primary:hover {
        background: #0F766E;
    }

    .alert-success { background: #ECFDF5; color: #065F46; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; border: 1px solid #A7F3D0; }
    .alert-error { background: #FEF2F2; color: #991B1B; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; border: 1px solid #FECACA; }
    
    .table-container {
        background: white;
        border-radius: 16px;
        border: 1px solid #E5E7EB;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
    }
    
    .table-controls {
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #F3F4F6;
    }
    
    .search-box { position: relative; width: 300px; }
    .search-box svg { position: absolute; left: 14px; top: 11px; }
    .search-box input { width: 100%; padding: 10px 14px 10px 40px; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; outline: none; transition: 0.2s; }
    .search-box input:focus { border-color: #0D9488; box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1); }
    
    .filter-btn { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: white; border: 1px solid #E5E7EB; border-radius: 8px; font-size: 14px; font-weight: 600; color: #374151; cursor: pointer; transition: 0.2s; }
    .filter-btn:hover { background: #F9FAFB; }
    
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .data-table th {
        text-align: left;
        padding: 16px 24px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        color: #6B7280;
        background: #F9FAFB;
        border-bottom: 1px solid #E5E7EB;
    }
    
    .data-table td {
        padding: 16px 24px;
        border-bottom: 1px solid #F3F4F6;
        vertical-align: middle;
    }
    
    .data-table tr:hover td { background: #F9FAFB; }
    .data-table tr:last-child td { border-bottom: none; }
    
    .c-date { font-size: 14px; font-weight: 600; color: #111827; }
    .c-time { font-size: 13px; color: #6B7280; }
    
    .patient-avatar { width: 40px; height: 40px; border-radius: 12px; background: #0D9488; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; }
    .p-name { font-size: 15px; color: #111827; }
    
    .d-value { font-size: 14px; color: #4B5563; font-weight: 500; }
    
    .status-badge { background: #ECFDF5; color: #059669; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; border: 1px solid #A7F3D0; }
    
    .action-icons { display: flex; align-items: center; justify-content: flex-end; gap: 12px; }
    .icon-btn { background: none; border: none; padding: 8px; color: #6B7280; cursor: pointer; border-radius: 8px; display: flex; align-items: center; justify-content: center; transition: 0.2s; }
    .icon-btn:hover { background: #E5E7EB; color: #111827; }
    .icon-btn.text-danger:hover { background: #FEF2F2; color: #DC2626; }
    
    .loading-state { text-align: center; padding: 60px; color: #6B7280; }
    .spinner { width: 40px; height: 40px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto 16px; animation: spin 1s linear infinite; }
    
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-icon { font-size: 48px; color: #D1D5DB; margin-bottom: 16px; }
    .empty-state h3 { margin: 0 0 8px; font-size: 18px; color: #111827; }
    .empty-state p { margin: 0; color: #6B7280; font-size: 14px; }
    .mt-3 { margin-top: 16px; }

    /* Delete Confirm Modal */
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(17, 24, 39, 0.6); backdrop-filter: blur(4px); display: flex; align-items: center; justify-content: center; z-index: 1000; animation: fadeIn 0.2s ease; }
    .modal-confirm { background: white; border-radius: 16px; padding: 32px; width: 100%; max-width: 400px; text-align: center; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); animation: slideUp 0.3s ease; }
    .modal-icon { display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; border-radius: 50%; background: #FEF2F2; color: #DC2626; margin-bottom: 16px; }
    .modal-confirm h3 { margin: 0 0 8px; font-size: 18px; font-weight: 700; color: #111827; }
    .modal-confirm p { margin: 0 0 24px; color: #4B5563; font-size: 14px; line-height: 1.5; }
    .modal-actions { display: flex; gap: 12px; }
    .btn-cancel { flex: 1; background: white; border: 1px solid #D1D5DB; color: #374151; padding: 10px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-cancel:hover { background: #F3F4F6; }
    .btn-danger { flex: 1; background: #DC2626; color: white; border: none; padding: 10px; border-radius: 8px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-danger:hover { background: #B91C1C; }
    
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<ConsultationDto> consultations = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private string successMessage = "";
    private string errorMessage = "";
    private int displayCount = 5;
    private void LoadMore() => displayCount += 5;
    
    private bool showDeleteConfirm = false;
    private int consultationToDeleteId = 0;

    private void GoToNewConsultation() => Navigation.NavigateTo("/doctor/consultations/new");
    private void GoToConsultation(int id) => Navigation.NavigateTo($"/doctor/consultation/{id}");

    private bool sortAscending = false;

    private List<ConsultationDto> filteredConsultations 
    {
        get 
        {
            var query = consultations.Where(c => string.IsNullOrEmpty(searchTerm) ||
                       c.PatientName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                       (!string.IsNullOrEmpty(c.Diagnosis) && c.Diagnosis.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)));
            
            return sortAscending ? query.OrderBy(c => c.CreatedAt).ToList() : query.OrderByDescending(c => c.CreatedAt).ToList();
        }
    }

    private void ToggleFilter()
    {
        sortAscending = !sortAscending;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadConsultations();
        }
    }

    private async Task LoadConsultations()
    {
        isLoading = true;
        StateHasChanged();
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                consultations = await Http.GetFromJsonAsync<List<ConsultationDto>>($"{baseUrl}/api/consultations") ?? new();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur de chargement des consultations.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ConfirmDelete(int id)
    {
        consultationToDeleteId = id;
        showDeleteConfirm = true;
    }

    private async Task DeleteConsultation()
    {
        try
        {
            showDeleteConfirm = false;
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            
            var response = await Http.DeleteAsync($"{baseUrl}/api/consultations/{consultationToDeleteId}");
            if (response.IsSuccessStatusCode)
            {
                consultations.RemoveAll(c => c.Id == consultationToDeleteId);
                successMessage = "Consultation supprimée avec succès.";
                await ClearMessages();
            }
            else
            {
                errorMessage = "Erreur lors de la suppression.";
                await ClearMessages();
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur réseau.";
            Console.WriteLine(ex.Message);
        }
    }

    private async Task ClearMessages()
    {
        await Task.Delay(4000);
        successMessage = "";
        errorMessage = "";
        StateHasChanged();
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0].Substring(0, 1).ToUpper();
        return (parts[0].Substring(0, 1) + parts[parts.Length - 1].Substring(0, 1)).ToUpper();
    }

}
