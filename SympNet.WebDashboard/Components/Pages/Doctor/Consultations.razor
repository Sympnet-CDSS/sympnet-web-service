@page "/doctor/consultations"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Mes consultations</PageTitle>

<style>
    .consultations-container { max-width: 1400px; margin: 0 auto; padding: 20px; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .page-header h1 { font-size: 28px; font-weight: 800; color: #1F2937; margin: 0; }
    .page-header h1 i { color: #0D9488; margin-right: 12px; }
    .btn-primary { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(13,148,136,0.3); }
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 20px 24px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .stat-label { font-size: 13px; color: #6B7280; margin-top: 4px; }
    .search-bar { background: white; border-radius: 16px; padding: 16px 20px; margin-bottom: 24px; border: 1px solid rgba(13,148,136,0.1); display: flex; align-items: center; gap: 12px; }
    .search-bar i { color: #9CA3AF; font-size: 18px; }
    .search-bar input { flex: 1; border: none; outline: none; font-size: 14px; padding: 8px 0; }
    .consultations-table { background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; width: 100%; border-collapse: collapse; }
    .consultations-table th { text-align: left; padding: 16px 20px; background: #F9FAFB; font-size: 13px; font-weight: 600; color: #6B7280; border-bottom: 1px solid #E5E7EB; }
    .consultations-table td { padding: 16px 20px; font-size: 14px; color: #1F2937; border-bottom: 1px solid #F3F4F6; cursor: pointer; }
    .consultations-table tr:hover { background: #F9FAFB; }
    .confidence-bar { width: 80px; height: 6px; background: #E5E7EB; border-radius: 3px; overflow: hidden; display: inline-block; margin-right: 8px; }
    .confidence-fill { height: 100%; background: linear-gradient(90deg, #0D9488, #14B8A6); border-radius: 3px; }
    .status-completed { background: #D1FAE5; color: #10B981; padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; display: inline-block; }
    .empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); }
    .loading-spinner { text-align: center; padding: 60px; }
    .spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto; animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="consultations-container">
    <div class="page-header">
        <h1><i class="fas fa-stethoscope"></i> Mes consultations</h1>
        <button class="btn-primary" style="margin-top: 16px;" @onclick="GoToAIDiagnosis">
            <i class="fas fa-plus"></i> Nouvelle consultation
        </button>
    </div>

    <div class="stats-row">
        <div class="stat-card"><div class="stat-number">@consultations.Count</div><div class="stat-label">Total consultations</div></div>
        <div class="stat-card"><div class="stat-number">@consultations.Count(c => c.Status == "Terminée")</div><div class="stat-label">Terminées</div></div>
        <div class="stat-card"><div class="stat-number">@consultations.Count(c => c.ConfidenceScore > 0.8)</div><div class="stat-label">Haute confiance</div></div>
        <div class="stat-card"><div class="stat-number">@patientsCount</div><div class="stat-label">Patients uniques</div></div>
    </div>

    <div class="search-bar">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Rechercher un patient..." @bind="searchTerm" @bind:event="oninput" />
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner"><div class="spinner"></div></div>
    }
    else if (filteredConsultations.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-folder-open" style="font-size: 64px; color: #D1D5DB; margin-bottom: 16px;"></i>
            <h3>Aucune consultation trouvée</h3>
            <p style="color: #6B7280;">Commencez par analyser des symptômes avec l'IA</p>
            <button class="btn-primary" style="margin-top: 16px;" @onclick="GoToAIDiagnosis">
                <i class="fas fa-microphone-alt"></i> Nouvelle consultation IA
            </button>
        </div>
    }
    else
    {
        <table class="consultations-table">
            <thead>
                <tr><th>Patient</th><th>Diagnostic</th><th>Confiance</th><th>Date</th><th>Statut</th></tr>
            </thead>
            <tbody>
                @foreach (var c in filteredConsultations)
                {
                    <tr @onclick="() => GoToConsultation(c.Id)">
                        <td><strong>@c.PatientName</strong><br/><small style="color:#6B7280;">@c.PatientEmail</small></td>
                        <td style="color:#0D9488; font-weight:600;">@c.Diagnosis</td>
                        <td><div class="confidence-bar"><div class="confidence-fill" style="width:@(c.ConfidenceScore*100)%"></div></div>@(c.ConfidenceScore*100)%</td>
                        <td>@c.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td><span class="status-completed">✓ Terminée</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<ConsultationDto> consultations = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private int patientsCount = 0;

    private void GoToAIDiagnosis() => Navigation.NavigateTo("/doctor/ai-diagnosis");
    private void GoToConsultation(int id) => Navigation.NavigateTo($"/doctor/consultation/{id}");

    private List<ConsultationDto> filteredConsultations => consultations
        .Where(c => string.IsNullOrEmpty(searchTerm) ||
                   c.PatientName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   c.PatientEmail.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                   c.Diagnosis.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadConsultations();
        }
    }

    private async Task LoadConsultations()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                consultations = await Http.GetFromJsonAsync<List<ConsultationDto>>($"{baseUrl}/api/consultations") ?? new();
                patientsCount = consultations.Select(c => c.PatientEmail).Distinct().Count();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class ConsultationDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string PatientEmail { get; set; } = "";
        public string Diagnosis { get; set; } = "";
        public double ConfidenceScore { get; set; }
        public string Status { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}
