@page "/doctor/consultations"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>SympNet — Mes Consultations</PageTitle>

<style>
    .consultations-container { max-width: 1400px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .page-header h1 { font-size: 28px; font-weight: 800; color: #1F2937; margin: 0; }
    .page-header h1 i { color: #0D9488; margin-right: 12px; }
    .btn-primary { background: linear-gradient(135deg, #0D9488, #14B8A6); color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 600; cursor: pointer; display: inline-flex; align-items: center; gap: 10px; transition: all 0.2s; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(13,148,136,0.3); }
    .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 20px 24px; border: 1px solid rgba(13,148,136,0.1); }
    .stat-number { font-size: 32px; font-weight: 800; color: #0D9488; }
    .stat-label { font-size: 13px; color: #6B7280; margin-top: 4px; }
    .consultations-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 20px; }
    .consultation-card { background: white; border-radius: 20px; padding: 20px; border: 1px solid rgba(13,148,136,0.1); transition: all 0.2s; cursor: pointer; }
    .consultation-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.08); border-color: #0D9488; }
    .consultation-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
    .patient-name { font-size: 18px; font-weight: 700; color: #1F2937; margin: 0; }
    .patient-name i { color: #0D9488; margin-right: 8px; }
    .status-badge { padding: 4px 12px; border-radius: 100px; font-size: 12px; font-weight: 600; }
    .status-completed { background: #D1FAE5; color: #10B981; }
    .status-pending { background: #FEF3C7; color: #F59E0B; }
    .consultation-date { font-size: 12px; color: #9CA3AF; margin-bottom: 12px; }
    .consultation-diagnosis { background: #F9FAFB; border-radius: 12px; padding: 12px; margin-bottom: 12px; }
    .consultation-diagnosis .label { font-size: 11px; color: #6B7280; text-transform: uppercase; }
    .consultation-diagnosis .value { font-size: 14px; font-weight: 600; color: #0D9488; margin-top: 4px; }
    .consultation-confidence { display: flex; align-items: center; gap: 8px; margin-top: 12px; }
    .confidence-bar { flex: 1; height: 6px; background: #E5E7EB; border-radius: 3px; overflow: hidden; }
    .confidence-fill { height: 100%; background: linear-gradient(90deg, #0D9488, #14B8A6); border-radius: 3px; }
    .loading-spinner { text-align: center; padding: 60px; }
    .spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 0 auto; animation: spin 1s linear infinite; }
    .empty-state { text-align: center; padding: 80px 20px; background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="consultations-container">
    <div class="page-header">
        <h1><i class="fas fa-stethoscope"></i> Mes Consultations</h1>
        <button class="btn-primary" @onclick="GoToNewConsultation">
            <i class="fas fa-plus"></i> Nouvelle consultation IA
        </button>
    </div>

    <div class="stats-row">
        <div class="stat-card"><div class="stat-number">@consultations.Count</div><div class="stat-label">Total consultations</div></div>
        <div class="stat-card"><div class="stat-number">@consultations.Count(c => c.Status == "Terminée")</div><div class="stat-label">Terminées</div></div>
        <div class="stat-card"><div class="stat-number">@consultations.Count(c => c.Status == "En attente")</div><div class="stat-label">En attente</div></div>
        <div class="stat-card"><div class="stat-number">@consultations.Count(c => c.ConfidenceScore > 0.8)</div><div class="stat-label">Haute confiance</div></div>
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner"><div class="spinner"></div></div>
    }
    else if (consultations.Count == 0)
    {
        <div class="empty-state">
            <i class="fas fa-folder-open" style="font-size: 64px; color: #D1D5DB; margin-bottom: 16px;"></i>
            <h3 style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">Aucune consultation</h3>
            <p style="color: #6B7280;">Cliquez sur "Nouvelle consultation IA" pour commencer</p>
        </div>
    }
    else
    {
        <div class="consultations-grid">
            @foreach (var c in consultations)
            {
                <div class="consultation-card" @onclick="() => GoToConsultationDetail(c.Id)">
                    <div class="consultation-header">
                        <h3 class="patient-name"><i class="fas fa-user-circle"></i> @c.PatientName</h3>
                        <span class="status-badge @(c.Status == "Terminée" ? "status-completed" : "status-pending")">
                            @(c.Status == "Terminée" ? "✓ Terminée" : "⏳ En attente")
                        </span>
                    </div>
                    <div class="consultation-date">
                        <i class="fas fa-calendar-alt"></i> @c.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </div>
                    <div class="consultation-diagnosis">
                        <div class="label">Diagnostic</div>
                        <div class="value">@c.Diagnosis</div>
                    </div>
                    <div class="consultation-confidence">
                        <span style="font-size: 12px; color: #6B7280;">Confiance:</span>
                        <div class="confidence-bar">
                            <div class="confidence-fill" style="width: @(c.ConfidenceScore * 100)%"></div>
                        </div>
                        <span style="font-size: 12px; font-weight: 600; color: #0D9488;">@(c.ConfidenceScore * 100)%</span>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ConsultationDto> consultations = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadConsultations();
    }

    private void GoToNewConsultation()
    {
        Navigation.NavigateTo("/doctor/ai-diagnosis");
    }

    private void GoToConsultationDetail(int id)
    {
        Navigation.NavigateTo($"/doctor/consultation/{id}");
    }

    private async Task LoadConsultations()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                consultations = await Http.GetFromJsonAsync<List<ConsultationDto>>("http://localhost:5000/api/consultations") ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public class ConsultationDto
    {
        public int Id { get; set; }
        public string PatientName { get; set; } = "";
        public string PatientEmail { get; set; } = "";
        public string Diagnosis { get; set; } = "";
        public double ConfidenceScore { get; set; }
        public string Status { get; set; } = "";
        public DateTime CreatedAt { get; set; }
    }
}