@page "/doctor/dashboard"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation   // ← AJOUTE CETTE LIGNE

<PageTitle>SympNet — Dashboard Médecin</PageTitle>

<style>
    .dashboard-container { max-width: 1400px; margin: 0 auto; }
    .welcome-banner { background: linear-gradient(135deg, #0D9488, #14B8A6); border-radius: 24px; padding: 32px; color: white; margin-bottom: 32px; }
    .welcome-banner h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
    .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 24px; border: 1px solid rgba(13,148,136,0.1); transition: all 0.3s; cursor: pointer; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1); }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 12px; }
    .stat-icon.patients { background: rgba(13,148,136,0.1); color: #0D9488; }
    .stat-icon.today { background: rgba(245,158,11,0.1); color: #F59E0B; }
    .stat-icon.total { background: rgba(59,130,246,0.1); color: #3B82F6; }
    .stat-value { font-size: 32px; font-weight: 800; color: #1F2937; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: #6B7280; }
    .loading-spinner { width: 48px; height: 48px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 60px auto; animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

<div class="dashboard-container">
    @if (isLoading)
    {
        <div class="loading-spinner"></div>
    }
    else
    {
        <div class="welcome-banner">
            <h1>Bonjour, Dr. @doctorName</h1>
            <p>Bienvenue sur votre espace médecin SympNet</p>
            <small>@DateTime.Now.ToString("dddd dd MMMM yyyy")</small>
        </div>

        <div class="stats-grid">
            <div class="stat-card" @onclick="GoToPatients">
                <div class="stat-icon patients"><i class="fas fa-users"></i></div>
                <div class="stat-value">@stats.TotalPatients</div>
                <div class="stat-label">Mes patients</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon today"><i class="fas fa-calendar-day"></i></div>
                <div class="stat-value">@stats.TodayConsultations</div>
                <div class="stat-label">Consultations aujourd'hui</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon total"><i class="fas fa-stethoscope"></i></div>
                <div class="stat-value">@stats.TotalConsultations</div>
                <div class="stat-label">Total consultations</div>
            </div>
        </div>
    }
</div>

@code {
    private string doctorName = "Médecin";
    private DoctorStatsDto stats = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
    }

    private async Task LoadStats()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                
                var profile = await Http.GetFromJsonAsync<DoctorProfileDto>("http://localhost:5000/api/doctorprofile");
                if (profile != null)
                {
                    doctorName = profile.FirstName;
                }
                
                stats = await Http.GetFromJsonAsync<DoctorStatsDto>("http://localhost:5000/api/doctorprofile/stats") ?? new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GoToPatients()
    {
        Navigation.NavigateTo("/doctor/patients");
    }

    public class DoctorStatsDto
    {
        public int TotalPatients { get; set; }
        public int TodayConsultations { get; set; }
        public int TotalConsultations { get; set; }
    }

    public class DoctorProfileDto
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Speciality { get; set; } = "";
    }
}