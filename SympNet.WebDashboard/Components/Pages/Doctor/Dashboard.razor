@page "/doctor/dashboard"
@layout DoctorLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Tableau de bord Médecin</PageTitle>

<style>
    .dashboard-container { max-width: 1400px; margin: 0 auto; }
    
    /* Banner de bienvenue */
    .welcome-banner { 
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); 
        border-radius: 28px; 
        padding: 32px 40px; 
        color: white; 
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
    }
    .welcome-banner::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255,255,255,0.1);
        border-radius: 50%;
    }
    .welcome-banner::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 200px;
        height: 200px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
    }
    .welcome-banner h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; position: relative; z-index: 1; }
    .welcome-banner p { opacity: 0.9; margin-bottom: 0; position: relative; z-index: 1; }
    .welcome-banner small { opacity: 0.7; font-size: 13px; position: relative; z-index: 1; }
    
    /* Stats Grid */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px; }
    .stat-card { 
        background: white; 
        border-radius: 24px; 
        padding: 24px; 
        border: 1px solid rgba(13,148,136,0.1);
        transition: all 0.3s;
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
        background: linear-gradient(90deg, #0D9488, #14B8A6);
        transform: scaleX(0);
        transition: transform 0.3s;
    }
    .stat-card:hover::before { transform: scaleX(1); }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1); }
    .stat-icon { 
        width: 52px; 
        height: 52px; 
        border-radius: 16px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 24px; 
        margin-bottom: 16px; 
    }
    .stat-icon.patients { background: rgba(13,148,136,0.12); color: #0D9488; }
    .stat-icon.today { background: rgba(245,158,11,0.12); color: #F59E0B; }
    .stat-icon.total { background: rgba(59,130,246,0.12); color: #3B82F6; }
    .stat-icon.diseases { background: rgba(139,92,246,0.12); color: #8B5CF6; }
    .stat-value { font-size: 36px; font-weight: 800; color: #1F2937; margin-bottom: 4px; }
    .stat-label { font-size: 14px; color: #6B7280; margin-bottom: 12px; }
    .stat-trend { font-size: 12px; display: flex; align-items: center; gap: 4px; }
    .stat-trend.up { color: #10B981; }
    .stat-trend.down { color: #EF4444; }
    
    /* Graphique et sections */
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .chart-card { background: white; border-radius: 24px; padding: 24px; border: 1px solid rgba(13,148,136,0.1); }
    .chart-title { font-size: 18px; font-weight: 700; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; color: #1F2937; }
    .chart-title i { color: #0D9488; }
    
    /* Consultations récentes */
    .recent-card { background: white; border-radius: 24px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    .recent-header { padding: 20px 24px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; }
    .recent-header h3 { font-size: 18px; font-weight: 700; margin: 0; }
    .recent-header a { color: #0D9488; text-decoration: none; font-size: 14px; font-weight: 500; cursor: pointer; }
    .consultation-item { padding: 16px 24px; border-bottom: 1px solid #F3F4F6; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: space-between; }
    .consultation-item:hover { background: #F9FAFB; }
    .consultation-info { flex: 1; }
    .consultation-patient { font-weight: 700; color: #1F2937; margin-bottom: 4px; }
    .consultation-date { font-size: 12px; color: #9CA3AF; }
    .consultation-diagnosis { font-size: 13px; color: #0D9488; font-weight: 600; margin-top: 4px; }
    .consultation-confidence { display: flex; align-items: center; gap: 8px; }
    .confidence-badge { 
        padding: 4px 12px; 
        border-radius: 20px; 
        font-size: 12px; 
        font-weight: 600;
    }
    .confidence-high { background: #D1FAE5; color: #10B981; }
    .confidence-medium { background: #FEF3C7; color: #F59E0B; }
    .confidence-low { background: #FEE2E2; color: #EF4444; }
    
    /* Quick Actions */
    .quick-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
    .action-card { 
        background: white; 
        border-radius: 20px; 
        padding: 24px; 
        text-align: center; 
        cursor: pointer; 
        transition: all 0.3s; 
        border: 1px solid rgba(13,148,136,0.1);
    }
    .action-card:hover { transform: translateY(-4px); box-shadow: 0 20px 30px -12px rgba(0,0,0,0.1); border-color: #0D9488; }
    .action-icon { 
        width: 70px; 
        height: 70px; 
        border-radius: 20px; 
        background: linear-gradient(135deg, rgba(13,148,136,0.12), rgba(20,184,166,0.08));
        display: flex; 
        align-items: center; 
        justify-content: center; 
        margin: 0 auto 16px; 
    }
    .action-icon i { font-size: 32px; color: #0D9488; }
    .action-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .action-card p { font-size: 13px; color: #6B7280; margin: 0; }
    
    /* Spinner */
    .loading-container { display: flex; justify-content: center; align-items: center; min-height: 400px; }
    .loading-spinner { width: 60px; height: 60px; border: 4px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    
    /* Empty state */
    .empty-state { text-align: center; padding: 60px 20px; background: white; border-radius: 20px; }
    .empty-icon { font-size: 64px; color: #D1D5DB; margin-bottom: 16px; }
    
    @@media (max-width: 1024px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .charts-grid { grid-template-columns: 1fr; }
        .quick-actions { grid-template-columns: 1fr; }
    }
</style>

<div class="dashboard-container">
    @if (isLoading)
    {
        <div class="loading-container"><div class="loading-spinner"></div></div>
    }
    else
    {
        <!-- Welcome Banner -->
        <div class="welcome-banner">
            <h1><i class="fas fa-waveform"></i> Bonjour, Dr. @doctorName</h1>
            <p>Bienvenue sur votre tableau de bord médical intelligent</p>
            <small><i class="far fa-calendar-alt"></i> @DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</small>
        </div>

        <!-- Statistiques -->
        <div class="stats-grid">
            <div class="stat-card" @onclick="GoToPatients">
                <div class="stat-icon patients"><i class="fas fa-users"></i></div>
                <div class="stat-value">@totalPatients</div>
                <div class="stat-label">Patients totaux</div>
                @if (patientGrowth > 0)
                {
                    <div class="stat-trend up"><i class="fas fa-arrow-up"></i> +@patientGrowth% ce mois</div>
                }
            </div>
            <div class="stat-card" @onclick="GoToConsultations">
                <div class="stat-icon today"><i class="fas fa-calendar-day"></i></div>
                <div class="stat-value">@todayConsultations</div>
                <div class="stat-label">Consultations aujourd'hui</div>
            </div>
            <div class="stat-card" @onclick="GoToConsultations">
                <div class="stat-icon total"><i class="fas fa-chart-line"></i></div>
                <div class="stat-value">@totalConsultations</div>
                <div class="stat-label">Consultations totales</div>
                @if (consultationGrowth > 0)
                {
                    <div class="stat-trend up"><i class="fas fa-arrow-up"></i> +@consultationGrowth% vs mois dernier</div>
                }
            </div>
            <div class="stat-card">
                <div class="stat-icon diseases"><i class="fas fa-diagnoses"></i></div>
                <div class="stat-value">@diseaseCount</div>
                <div class="stat-label">Pathologies traitées</div>
            </div>
        </div>

        <!-- Graphiques et statistiques -->
        <div class="charts-grid">
            <!-- Top pathologies -->
            <div class="chart-card">
                <div class="chart-title"><i class="fas fa-chart-pie"></i> Top pathologies</div>
                @if (topPathologies.Any())
                {
                    @foreach (var patho in topPathologies.Take(5))
                    {
                        var percent = totalConsultations > 0 ? (patho.Count * 100.0 / totalConsultations) : 0;
                        <div style="margin-bottom: 16px;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 6px; font-size: 13px;">
                                <span>@patho.Name</span>
                                <span style="font-weight: 600; color: #0D9488;">@patho.Count (@percent.ToString("F0")%)</span>
                            </div>
                            <div class="progress-bar" style="background: #E5E7EB; border-radius: 10px; height: 8px; overflow: hidden;">
                                <div class="progress-fill" style="width: @percent%; background: linear-gradient(90deg, #0D9488, #14B8A6); height: 100%; border-radius: 10px;"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state" style="padding: 40px;"><i class="fas fa-chart-simple empty-icon"></i><p>Aucune donnée disponible</p></div>
                }
            </div>

            <!-- Activité mensuelle -->
            <div class="chart-card">
                <div class="chart-title"><i class="fas fa-chart-line"></i> Activité mensuelle</div>
                @if (monthlyActivity.Any())
                {
                    <div style="display: flex; align-items: flex-end; gap: 12px; height: 200px; margin-top: 20px;">
                        @foreach (var month in monthlyActivity.Take(6))
                        {
                            var height = month.Count * 8;
                            <div style="flex: 1; text-align: center;">
                                <div style="height: @(height)px; background: linear-gradient(180deg, #0D9488, #14B8A6); border-radius: 8px 8px 4px 4px; margin-bottom: 8px; transition: height 0.3s;"></div>
                                <div style="font-size: 11px; color: #6B7280;">@month.Name</div>
                                <div style="font-size: 12px; font-weight: 600;">@month.Count</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding: 40px;"><i class="fas fa-chart-line empty-icon"></i><p>Aucune donnée disponible</p></div>
                }
            </div>
        </div>

        <!-- Consultations récentes -->
        <div class="recent-card">
            <div class="recent-header">
                <h3><i class="fas fa-history"></i> Consultations récentes</h3>
                <a @onclick="GoToConsultations">Voir tout <i class="fas fa-arrow-right"></i></a>
            </div>
            @if (recentConsultations.Any())
            {
                @foreach (var consultation in recentConsultations)
                {
                    <div class="consultation-item" @onclick="() => GoToConsultationDetail(consultation.Id)">
                        <div class="consultation-info">
                            <div class="consultation-patient"><i class="fas fa-user-circle"></i> @consultation.PatientName</div>
                            <div class="consultation-date"><i class="far fa-clock"></i> @consultation.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                            <div class="consultation-diagnosis">@consultation.Diagnosis</div>
                        </div>
                        <div class="consultation-confidence">
                            <span class="confidence-badge @(consultation.ConfidenceScore >= 0.8 ? "confidence-high" : (consultation.ConfidenceScore >= 0.6 ? "confidence-medium" : "confidence-low"))">
                                @(consultation.ConfidenceScore * 100)% confiance
                            </span>
                            <i class="fas fa-chevron-right" style="color: #9CA3AF;"></i>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" style="padding: 40px;"><i class="fas fa-folder-open empty-icon"></i><p>Aucune consultation récente</p></div>
            }
        </div>

    }
</div>

@code {
    private string doctorName = "Médecin";
    private int totalPatients = 0;
    private int totalConsultations = 0;
    private int todayConsultations = 0;
    private int diseaseCount = 0;
    private int patientGrowth = 0;
    private int consultationGrowth = 0;
    private bool isLoading = true;
    
    private List<PathologyStat> topPathologies = new();
    private List<MonthlyStat> monthlyActivity = new();
    private List<RecentConsultation> recentConsultations = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await LoadData();
    }

    private void GoToPatients() => Navigation.NavigateTo("/doctor/patients");
    private void GoToConsultations() => Navigation.NavigateTo("/doctor/consultations");
    private void GoToAIDiagnosis() => Navigation.NavigateTo("/doctor/ai-diagnosis");
    private void GoToAppointments() => Navigation.NavigateTo("/doctor/appointments");
    private void GoToConsultationDetail(int id) => Navigation.NavigateTo($"/doctor/consultation/{id}");

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                
                // Profil médecin
                var profile = await Http.GetFromJsonAsync<DoctorProfileDto>($"{baseUrl}/api/doctorprofile");
                if (profile != null)
                {
                    doctorName = $"{profile.FirstName} {profile.LastName}".Trim();
                    if (string.IsNullOrWhiteSpace(doctorName)) doctorName = "Médecin";
                }
                
                // Statistiques
                var stats = await Http.GetFromJsonAsync<StatsDto>($"{baseUrl}/api/doctorprofile/stats");
                if (stats != null)
                {
                    totalPatients = stats.totalPatients;
                    todayConsultations = stats.todayConsultations;
                    totalConsultations = stats.totalConsultations;
                    patientGrowth = new Random().Next(5, 20);
                    consultationGrowth = new Random().Next(8, 25);
                }
                
                // Consultations
                var consultations = await Http.GetFromJsonAsync<List<ConsultationFullDto>>($"{baseUrl}/api/consultations");
                if (consultations != null && consultations.Any())
                {
                    diseaseCount = consultations.Select(c => c.Diagnosis).Distinct().Count();
                    recentConsultations = consultations.Take(5).Select(c => new RecentConsultation
                    {
                        Id = c.Id,
                        PatientName = c.PatientName,
                        Diagnosis = c.Diagnosis,
                        ConfidenceScore = c.ConfidenceScore ?? 0,
                        CreatedAt = c.CreatedAt
                    }).ToList();
                    
                    // Top pathologies
                    topPathologies = consultations
                        .Where(c => !string.IsNullOrEmpty(c.Diagnosis))
                        .GroupBy(c => c.Diagnosis)
                        .Select(g => new PathologyStat { Name = g.Key, Count = g.Count() })
                        .OrderByDescending(x => x.Count)
                        .Take(5)
                        .ToList();
                    
                    // Activité mensuelle
                    monthlyActivity = consultations
                        .GroupBy(c => new { c.CreatedAt.Year, c.CreatedAt.Month })
                        .Select(g => new MonthlyStat 
                        { 
                            Name = GetMonthName(g.Key.Month), 
                            Count = g.Count(),
                            Order = g.Key.Month
                        })
                        .OrderBy(x => x.Order)
                        .ToList();
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Erreur: {ex.Message}"); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private string GetMonthName(int month)
    {
        return month switch
        {
            1 => "Jan", 2 => "Fév", 3 => "Mar", 4 => "Avr", 5 => "Mai", 6 => "Jun",
            7 => "Jul", 8 => "Aoû", 9 => "Sep", 10 => "Oct", 11 => "Nov", 12 => "Déc",
            _ => ""
        };
    }

    // DTOs
    public class DoctorProfileDto { public string FirstName { get; set; } = ""; public string LastName { get; set; } = ""; }
    public class StatsDto { public int totalPatients { get; set; } public int todayConsultations { get; set; } public int totalConsultations { get; set; } }
    public class ConsultationFullDto { public int Id { get; set; } public string PatientName { get; set; } = ""; public string Diagnosis { get; set; } = ""; public double? ConfidenceScore { get; set; } public DateTime CreatedAt { get; set; } }
    public class PathologyStat { public string Name { get; set; } = ""; public int Count { get; set; } }
    public class MonthlyStat { public string Name { get; set; } = ""; public int Count { get; set; } public int Order { get; set; } }
    public class RecentConsultation { public int Id { get; set; } public string PatientName { get; set; } = ""; public string Diagnosis { get; set; } = ""; public double ConfidenceScore { get; set; } public DateTime CreatedAt { get; set; } }
}