@page "/admin/notifications/{MessageId:int}"
@layout AdminLayout
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="notif-detail-page">
    <div class="breadcrumb">
        <a @onclick='() => Navigation.NavigateTo("/admin/notifications")'>Notifications</a>
        <i class="fas fa-chevron-right"></i>
        <span>Détails du message</span>
    </div>

    @if (loading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <p>Chargement du message...</p>
        </div>
    }
    else if (message == null)
    {
        <div class="error-state">
            <i class="fas fa-exclamation-circle"></i>
            <h3>Message non trouvé</h3>
            <p>Le message que vous recherchez n'existe pas ou a été supprimé.</p>
            <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/admin/notifications")'>Retour aux notifications</button>
        </div>
    }
    else
    {
        <div class="detail-card">
            <div class="detail-header">
                <div class="sender-info">
                    <div class="avatar">@message.FirstName[0]@message.LastName[0]</div>
                    <div>
                        <h2>@message.FirstName @message.LastName</h2>
                        <p>@message.Email • @(string.IsNullOrEmpty(message.Phone) ? "Pas de téléphone" : message.Phone)</p>
                    </div>
                </div>
                <div class="message-meta">
                    <span class="status-badge @(message.IsRead ? "read" : "unread")">
                        @(message.IsRead ? "Lu" : "Nouveau")
                    </span>
                    <span class="date">@message.CreatedAt.ToString("f")</span>
                </div>
            </div>

            <div class="detail-content">
                <div class="info-group">
                    <label>Sujet</label>
                    <div class="topic-tag">@GetTopicLabel(message.Topic)</div>
                </div>

                <div class="info-group">
                    <label>Message</label>
                    <div class="message-text">@message.Message</div>
                </div>
            </div>

            <div class="detail-footer">
                <button class="btn-secondary" @onclick='() => Navigation.NavigateTo("/admin/notifications")'>Retour</button>
                @if (!message.IsRead)
                {
                    <button class="btn-primary" @onclick="MarkAsRead">Marquer comme traité</button>
                }
            </div>
        </div>
    }
</div>

<style>
    .notif-detail-page { max-width: 800px; margin: 0 auto; }
    .breadcrumb { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; color: #6B7280; font-size: 14px; }
    .breadcrumb a { color: #0D9488; cursor: pointer; text-decoration: none; font-weight: 500; }
    .breadcrumb i { font-size: 10px; }
    
    .detail-card { background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
    .detail-header { padding: 32px; border-bottom: 1px solid #F3F4F6; display: flex; justify-content: space-between; align-items: flex-start; }
    
    .sender-info { display: flex; gap: 20px; align-items: center; }
    .avatar { width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); color: white; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; }
    .sender-info h2 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 22px; font-weight: 700; color: #111827; margin: 0; }
    .sender-info p { font-size: 14px; color: #6B7280; margin-top: 4px; }
    
    .message-meta { text-align: right; }
    .status-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; margin-bottom: 8px; }
    .status-badge.unread { background: #FEF3C7; color: #D97706; }
    .status-badge.read { background: #F0FDF4; color: #16A34A; }
    .date { display: block; font-size: 12px; color: #9CA3AF; }
    
    .detail-content { padding: 32px; }
    .info-group { margin-bottom: 24px; }
    .info-group label { display: block; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #9CA3AF; margin-bottom: 12px; }
    .topic-tag { display: inline-block; padding: 6px 14px; background: #F3F4F6; border-radius: 8px; font-size: 14px; font-weight: 600; color: #4B5563; }
    .message-text { font-size: 16px; color: #374151; line-height: 1.6; background: #F9FAFB; padding: 24px; border-radius: 16px; white-space: pre-wrap; }
    
    .detail-footer { padding: 24px 32px; background: #F9FAFB; border-top: 1px solid #F3F4F6; display: flex; justify-content: flex-end; gap: 16px; }
    
    .btn-primary { background: #0D9488; color: white; border: none; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { background: #0F766E; transform: translateY(-1px); }
    .btn-secondary { background: white; border: 1px solid #E5E7EB; padding: 12px 24px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-secondary:hover { background: #F9FAFB; border-color: #D1D5DB; }

    .loading-state, .error-state { padding: 100px 40px; text-align: center; }
    .spinner { width: 40px; height: 40px; border: 3px solid #F3F4F6; border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    [Parameter] public int MessageId { get; set; }
    private ContactMessage? message;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMessage();
    }

    private async Task LoadMessage()
    {
        loading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                message = await Http.GetFromJsonAsync<ContactMessage>($"{baseUrl}/api/ContactMessages/{MessageId}");
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        finally { loading = false; }
    }

    private async Task MarkAsRead()
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PutAsync($"{baseUrl}/api/ContactMessages/{MessageId}/read", null);
            if (response.IsSuccessStatusCode && message != null)
            {
                message.IsRead = true;
                StateHasChanged();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
    }

    private string GetTopicLabel(string topic) => topic switch {
        "support" => "Support Technique",
        "billing" => "Facturation & Abonnements",
        "partnership" => "Partenariat",
        "other" => "Autre",
        _ => topic
    };

    public class ContactMessage {
        public int Id { get; set; }
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Phone { get; set; } = "";
        public string Topic { get; set; } = "";
        public string Message { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public bool IsRead { get; set; }
    }
}
