    private void ViewNotif(AdminNotification notif)
    {
        var t = notif.Title.ToLower();
        if (t.Contains("newsletter"))
        {
            Navigation.NavigateTo($"/admin/notifications/{notif.Id}");
        }
        else if (t.Contains("rendez-vous") || t.Contains("rdv") || t.Contains("appointment"))
        {
            Navigation.NavigateTo("/admin/notifications");
        }
        else if (t.Contains("message") || t.Contains("contact"))
        {
            Navigation.NavigateTo("/admin/notifications");
        }
        else if (!string.IsNullOrEmpty(notif.ActionUrl))
        {
            Navigation.NavigateTo(notif.ActionUrl);
        }
        else
        {
            Navigation.NavigateTo($"/admin/notifications/{notif.Id}");
        }
    }

