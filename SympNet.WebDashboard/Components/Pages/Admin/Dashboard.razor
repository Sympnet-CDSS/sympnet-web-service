@page "/admin/dashboard"
@layout AdminLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>SympNet — Dashboard Admin</PageTitle>

<style>
    .dashboard-container { max-width: 1400px; margin: 0 auto; }
    .welcome-banner { background: linear-gradient(135deg, #0D9488, #14B8A6); border-radius: 24px; padding: 32px; color: white; margin-bottom: 32px; }
    .welcome-banner h1 { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px; }
    .stat-card { background: white; border-radius: 20px; padding: 24px; border: 1px solid rgba(13,148,136,0.1); transition: all 0.3s; cursor: pointer; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 12px 24px rgba(0,0,0,0.1); }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: 12px; }
    .stat-icon.doctors { background: rgba(13,148,136,0.1); color: #0D9488; }
    .stat-icon.patients { background: rgba(16,185,129,0.1); color: #10B981; }
    .stat-icon.users { background: rgba(59,130,246,0.1); color: #3B82F6; }
    .stat-icon.active { background: rgba(34,197,94,0.1); color: #22C55E; }
    .stat-value { font-size: 32px; font-weight: 800; color: #1F2937; margin-bottom: 4px; }
    .stat-label { font-size: 13px; color: #6B7280; }
    .quick-actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 24px; }
    .action-btn { background: #F9FAFB; border: 1px solid rgba(13,148,136,0.1); border-radius: 12px; padding: 16px; text-align: center; cursor: pointer; transition: all 0.2s; }
    .action-btn:hover { background: white; border-color: #0D9488; transform: translateY(-2px); }
    .action-btn i { font-size: 24px; color: #0D9488; margin-bottom: 8px; display: block; }
    .loading-spinner { width: 50px; height: 50px; border: 3px solid #E5E7EB; border-top-color: #0D9488; border-radius: 50%; margin: 60px auto; animation: spin 1s linear infinite; }
    .error-message { background: #FEF2F2; color: #EF4444; padding: 16px; border-radius: 12px; text-align: center; margin: 20px; }
    @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    @@media (max-width: 768px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } .quick-actions { grid-template-columns: 1fr; } }
</style>

<div class="dashboard-container">
    @if (isLoading)
    {
        <div class="loading-spinner"></div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="error-message">
            <i class="fas fa-exclamation-triangle"></i> @errorMessage
        </div>
    }
    else
    {
        <div class="welcome-banner">
            <h1>Bonjour, @adminName</h1>
            <p>Bienvenue sur votre espace d'administration SympNet</p>
            <small>@DateTime.Now.ToString("dddd dd MMMM yyyy")</small>
        </div>

        <div class="stats-grid">
            <div class="stat-card" @onclick="GoToDoctors">
                <div class="stat-icon doctors"><i class="fas fa-user-md"></i></div>
                <div class="stat-value">@(stats?.totalDoctors ?? 0)</div>
                <div class="stat-label">Médecins</div>
            </div>
            <div class="stat-card" @onclick="GoToPatients">
                <div class="stat-icon patients"><i class="fas fa-users"></i></div>
                <div class="stat-value">@(stats?.totalPatients ?? 0)</div>
                <div class="stat-label">Patients</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon users"><i class="fas fa-user-friends"></i></div>
                <div class="stat-value">@(stats?.totalUsers ?? 0)</div>
                <div class="stat-label">Total utilisateurs</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon active"><i class="fas fa-check-circle"></i></div>
                <div class="stat-value">@(stats?.activeUsers ?? 0)</div>
                <div class="stat-label">Comptes actifs</div>
            </div>
        </div>

        <div class="quick-actions">
            <div class="action-btn" @onclick="GoToDoctors">
                <i class="fas fa-user-md"></i>
                <span>Gérer les médecins</span>
            </div>
            <div class="action-btn" @onclick="GoToPatients">
                <i class="fas fa-users"></i>
                <span>Gérer les patients</span>
            </div>
            <div class="action-btn" @onclick="GoToProfile">
                <i class="fas fa-user-cog"></i>
                <span>Mon profil</span>
            </div>
        </div>
    }
</div>

@code {
    private string adminName = "Admin";
    private StatsData? stats;
    private bool isLoading = true;
    private string? errorMessage = null;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
        }
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        errorMessage = null;
        
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            var userEmail = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_email");
            
            if (!string.IsNullOrEmpty(userEmail))
            {
                adminName = userEmail.Split('@')[0];
            }
            
            if (string.IsNullOrEmpty(token))
            {
                errorMessage = "Vous n'êtes pas authentifié. Veuillez vous reconnecter.";
                Navigation.NavigateTo("/login", true);
                return;
            }
            
            // Configuration du header Authorization
            Http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            // Appel API pour les statistiques
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var apiUrl = $"{baseUrl}/api/admin/stats";
            var response = await Http.GetFromJsonAsync<ApiStatsResponse>(apiUrl);
            
            if (response != null)
            {
                stats = new StatsData
                {
                    totalUsers = response.totalUsers,
                    totalDoctors = response.totalDoctors,
                    totalPatients = response.totalPatients,
                    totalAdmins = response.totalAdmins,
                    activeUsers = response.activeUsers,
                    inactiveUsers = response.inactiveUsers
                };
                
                Console.WriteLine($"📊 Stats chargées: {stats.totalDoctors} médecins, {stats.totalPatients} patients");
            }
            else
            {
                errorMessage = "Impossible de charger les statistiques.";
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"Erreur HTTP: {ex.Message}");
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            errorMessage = $"Impossible de contacter l'API. Vérifiez que l'API est démarrée sur {baseUrl}";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur: {ex.Message}");
            errorMessage = $"Erreur lors du chargement des données: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void GoToDoctors()
    {
        Navigation.NavigateTo("/admin/doctors");
    }

    private void GoToPatients()
    {
        Navigation.NavigateTo("/admin/patients");
    }

    private void GoToProfile()
    {
        Navigation.NavigateTo("/admin/profile");
    }

    // Classes pour la désérialisation JSON
    public class ApiStatsResponse
    {
        public int totalUsers { get; set; }
        public int totalDoctors { get; set; }
        public int totalPatients { get; set; }
        public int totalAdmins { get; set; }
        public int activeUsers { get; set; }
        public int inactiveUsers { get; set; }
        public List<MonthlyStat> monthlyStats { get; set; } = new();
    }

    public class MonthlyStat
    {
        public string Month { get; set; } = "";
        public int Count { get; set; }
    }

    public class StatsData
    {
        public int totalUsers { get; set; }
        public int totalDoctors { get; set; }
        public int totalPatients { get; set; }
        public int totalAdmins { get; set; }
        public int activeUsers { get; set; }
        public int inactiveUsers { get; set; }
    }
}
