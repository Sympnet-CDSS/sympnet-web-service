@page "/admin/notifications"
@layout AdminLayout
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="notifications-page">
    <div class="page-header">
        <div>
            <h1>Centre de Notifications</h1>
            <p>Gérez vos alertes et messages système</p>
        </div>
        <div class="header-actions">
            <button class="btn-secondary" @onclick="MarkAllAsRead">Tout marquer comme lu</button>
        </div>
    </div>

    <div class="notifications-container">
        <div class="notifications-list">
            @if (loading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>Chargement des notifications...</p>
                </div>
            }
            else if (!notifications.Any())
            {
                <div class="empty-state">
                    <i class="far fa-bell-slash"></i>
                    <h3>Aucune notification</h3>
                    <p>Vous n'avez pas encore de notifications.</p>
                </div>
            }
            else
            {
                @foreach (var notif in notifications)
                {
                    <div class="notif-card @(notif.IsRead ? "read" : "unread")" @onclick="() => ViewDetail(notif)">
                        <div class="notif-icon-wrapper">
                            <i class="fas fa-info-circle"></i>
                        </div>
                        <div class="notif-body">
                            <div class="notif-header">
                                <h3>@notif.Title</h3>
                                <span class="notif-time">@notif.CreatedAt.ToString("g")</span>
                            </div>
                            <p>@notif.Message</p>
                        </div>
                        @if (!notif.IsRead)
                        {
                            <div class="unread-dot"></div>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    .notifications-page { max-width: 1000px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .page-header h1 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 28px; font-weight: 800; color: #111827; }
    .page-header p { color: #6B7280; font-size: 14px; }
    
    .notifications-container { background: white; border-radius: 20px; border: 1px solid rgba(13,148,136,0.1); overflow: hidden; }
    .notif-card { display: flex; gap: 20px; padding: 24px; border-bottom: 1px solid #F3F4F6; cursor: pointer; transition: 0.2s; position: relative; }
    .notif-card:hover { background: #F9FAFB; }
    .notif-card.unread { background: rgba(13,148,136,0.02); }
    
    .notif-icon-wrapper { width: 48px; height: 48px; border-radius: 12px; background: rgba(13,148,136,0.1); color: #0D9488; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .notif-body { flex: 1; }
    .notif-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .notif-header h3 { font-size: 16px; font-weight: 700; color: #111827; }
    .notif-time { font-size: 12px; color: #9CA3AF; }
    .notif-body p { font-size: 14px; color: #4B5563; line-height: 1.5; }
    
    .unread-dot { width: 10px; height: 10px; border-radius: 50%; background: #0D9488; position: absolute; right: 24px; top: 50%; transform: translateY(-50%); }
    
    .btn-secondary { background: white; border: 1px solid #E5E7EB; padding: 10px 20px; border-radius: 10px; font-size: 14px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-secondary:hover { background: #F9FAFB; border-color: #D1D5DB; }
    
    .loading-state, .empty-state { padding: 80px 40px; text-align: center; color: #9CA3AF; }
    .spinner { width: 40px; height: 40px; border: 3px solid #F3F4F6; border-top-color: #0D9488; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .empty-state i { font-size: 48px; margin-bottom: 16px; opacity: 0.5; }
    .empty-state h3 { color: #111827; margin-bottom: 8px; }
</style>

@code {
    private List<Notification> notifications = new();
    private bool loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadNotifications();
            StateHasChanged();
        }
    }

    private async Task LoadNotifications()
    {
        loading = true;
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                var result = await Http.GetFromJsonAsync<List<Notification>>($"{baseUrl}/api/admin/notifications");
                if (result != null) notifications = result;
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
        finally { loading = false; }
    }

    private async Task MarkAllAsRead()
    {
        // API call to be added
    }

    private void ViewDetail(Notification notif)
    {
        if (!string.IsNullOrEmpty(notif.ActionUrl))
        {
            Navigation.NavigateTo(notif.ActionUrl);
        }
    }

    public class Notification
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string ActionUrl { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
