@page "/services"
@layout SympNet.WebDashboard.Components.Layout.EmptyLayout
@inject NavigationManager Navigation

<PageTitle>Nos Services - SympNet</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Instrument Sans', sans-serif; background: #F8FAFC; color: #1F2937; line-height: 1.5; }
    
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    
    /* Navbar */
    .navbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; max-width: 1200px; margin: 0 auto; }
    .logo { font-family: 'Bricolage Grotesque', sans-serif; font-size: 24px; font-weight: 800; color: #0D9488; display: flex; align-items: center; gap: 8px; }
    .nav-links { display: flex; gap: 24px; font-weight: 500; font-size: 15px; }
    .nav-links a { text-decoration: none; color: #4B5563; transition: 0.2s; }
    .nav-links a:hover, .nav-links a.active { color: #0D9488; }
    .nav-actions { display: flex; align-items: center; gap: 16px; }
    
    .doctor-logo-icon {
        width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: white;
    }
    
    .btn-primary { 
        background: #0D9488; 
        color: white; 
        border: none; 
        padding: 10px 20px; 
        border-radius: 8px; 
        font-size: 14px; 
        font-weight: 600; 
        cursor: pointer; 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        transition: 0.2s; 
    }
    .btn-primary:hover { background: #0F766E; }

    /* Services Header */
    .services-hero {
        background: #0D9488;
        padding: 80px 0 100px;
        text-align: center;
        color: white;
    }
    .services-hero h1 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 48px;
        font-weight: 800;
        margin-bottom: 20px;
    }
    .services-hero p {
        font-size: 18px;
        max-width: 700px;
        margin: 0 auto;
        opacity: 0.9;
        line-height: 1.6;
    }

    /* Grid Section */
    .services-grid-wrapper {
        margin-top: -60px;
        padding-bottom: 80px;
    }
    .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
    }
    .service-card {
        background: white;
        border-radius: 20px;
        padding: 40px;
        border: 1px solid #E2E8F0;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        transition: transform 0.3s, box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }
    .service-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(13, 148, 136, 0.1);
        border-color: rgba(13, 148, 136, 0.2);
    }
    .icon-box {
        width: 56px;
        height: 56px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 24px;
    }
    .icon-box.green { background: #F0FDF4; color: #10B981; }
    .icon-box.purple { background: #FAF5FF; color: #A855F7; }
    .icon-box.blue { background: #EFF6FF; color: #3B82F6; }
    .icon-box.soft-green { background: #F0FDF4; color: #0D9488; }
    .icon-box.red { background: #FEF2F2; color: #EF4444; }
    .icon-box.orange { background: #FFF7ED; color: #F97316; }
    .icon-box.indigo { background: #EEF2FF; color: #6366F1; }
    .icon-box.gray { background: #F8FAFC; color: #64748B; }

    .service-card h2 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 16px;
    }
    .service-card .desc {
        color: #64748B;
        font-size: 15px;
        margin-bottom: 24px;
        line-height: 1.5;
    }
    .features-list {
        list-style: none;
        margin-top: auto;
    }
    .features-list li {
        font-size: 13px;
        color: #64748B;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }
    .features-list li::before {
        content: '';
        width: 4px;
        height: 4px;
        background: #CBD5E1;
        border-radius: 50%;
    }

    /* CTA Section */
    .cta-section {
        background: #0D9488;
        padding: 80px 0;
        text-align: center;
        color: white;
    }
    .cta-section h2 {
        font-family: 'Bricolage Grotesque', sans-serif;
        font-size: 36px;
        font-weight: 800;
        margin-bottom: 16px;
    }
    .cta-section p {
        font-size: 18px;
        margin-bottom: 40px;
        opacity: 0.9;
    }
    .cta-btns {
        display: flex;
        justify-content: center;
        gap: 20px;
    }
    .btn-white {
        background: white;
        color: #0D9488;
        border: none;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
    }
    .btn-white:hover {
        background: #F8FAFC;
        transform: translateY(-2px);
    }
    .btn-outline-white {
        background: transparent;
        color: white;
        border: 2px solid white;
        padding: 14px 32px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 16px;
        cursor: pointer;
        transition: 0.2s;
    }
    .btn-outline-white:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-2px);
    }


</style>

<header>
    <nav class="navbar">
        <div class="logo">
           <div class="doctor-logo-icon"><i class="fas fa-stethoscope"></i></div>
            SympNet
        </div>
        <div class="nav-links">
            <a href="/">Accueil</a>
            <a href="/services" class="active">Services</a>
            <a href="/contact">Contactez-nous</a>
            <a href="/help">Aide</a>
            <a href="#">Blog</a>
        </div>
        <div class="nav-actions">
            <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>Connexion</button>
        </div>
    </nav>
</header>

<main>
    <section class="services-hero">
        <div class="container">
            <h1>Nos Services</h1>
            <p>SympNet offre une suite complète de services médicaux numériques pour patients et professionnels de santé</p>
        </div>
    </section>

    <section class="container services-grid-wrapper">
        <div class="services-grid">
            <!-- 1. Corps 3D Interactif -->
            <div class="service-card">
                <div class="icon-box green">
                    <i class="fas fa-wave-square"></i>
                </div>
                <h2>Corps 3D Interactif</h2>
                <p class="desc">Localisez précisément vos symptômes sur un modèle corporel 3D pour un diagnostic plus précis</p>
                <ul class="features-list">
                    <li>Sélection précise de la zone douloureuse</li>
                    <li>Interface intuitive</li>
                    <li>Compatible mobile</li>
                </ul>
            </div>

            <!-- 2. Diagnostic IA Multi-Agents -->
            <div class="service-card">
                <div class="icon-box purple">
                    <i class="fas fa-brain"></i>
                </div>
                <h2>Diagnostic IA Multi-Agents</h2>
                <p class="desc">Système d'intelligence artificielle avancé avec plusieurs agents spécialisés</p>
                <ul class="features-list">
                    <li>Analyse sémantique NLP</li>
                    <li>Score de confiance</li>
                    <li>Explicabilité totale (XAI)</li>
                </ul>
            </div>

            <!-- 3. Géolocalisation GPS -->
            <div class="service-card">
                <div class="icon-box blue">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <h2>Géolocalisation GPS</h2>
                <p class="desc">Trouvez les médecins spécialistes les plus proches de votre position</p>
                <ul class="features-list">
                    <li>Carte interactive</li>
                    <li>Filtrage par spécialité</li>
                    <li>Calcul d'itinéraire</li>
                </ul>
            </div>

            <!-- 4. Messagerie Sécurisée -->
            <div class="service-card">
                <div class="icon-box soft-green">
                    <i class="fas fa-comment-dots"></i>
                </div>
                <h2>Messagerie Sécurisée</h2>
                <p class="desc">Communiquez en toute sécurité avec votre médecin via chat texte, audio et vidéo</p>
                <ul class="features-list">
                    <li>Chat temps réel</li>
                    <li>Envoi de fichiers</li>
                    <li>Historique chiffré</li>
                </ul>
            </div>

            <!-- 5. Téléconsultation -->
            <div class="service-card">
                <div class="icon-box red">
                    <i class="fas fa-video"></i>
                </div>
                <h2>Téléconsultation</h2>
                <p class="desc">Consultez votre médecin à distance par appel vidéo HD</p>
                <ul class="features-list">
                    <li>Vidéo HD</li>
                    <li>Partage d'écran</li>
                    <li>Enregistrement sécurisé</li>
                </ul>
            </div>

            <!-- 6. Ordonnances Numériques -->
            <div class="service-card">
                <div class="icon-box orange">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h2>Ordonnances Numériques</h2>
                <p class="desc">Recevez et gérez vos ordonnances directement dans l'application</p>
                <ul class="features-list">
                    <li>Format PDF</li>
                    <li>Rappels de prise</li>
                    <li>Export facile</li>
                </ul>
            </div>

            <!-- 7. Dashboard Médecin -->
            <div class="service-card">
                <div class="icon-box indigo">
                    <i class="fas fa-users"></i>
                </div>
                <h2>Dashboard Médecin</h2>
                <p class="desc">Interface professionnelle pour les médecins avec gestion complète des patients</p>
                <ul class="features-list">
                    <li>Gestion d'agenda</li>
                    <li>Statistiques IA</li>
                    <li>Validation diagnostics</li>
                </ul>
            </div>

            <!-- 8. Sécurité & Conformité -->
            <div class="service-card">
                <div class="icon-box gray">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h2>Sécurité & Conformité</h2>
                <p class="desc">Vos données de santé sont protégées selon les normes les plus strictes</p>
                <ul class="features-list">
                    <li>Chiffrement end-to-end</li>
                    <li>RGPD compliant</li>
                    <li>Authentification 2FA</li>
                </ul>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container">
            <h2>Prêt à commencer ?</h2>
            <p>Rejoignez des milliers d'utilisateurs qui font confiance à SympNet</p>
            <div class="cta-btns">
                <button class="btn-white" @onclick='() => Navigation.NavigateTo("/login")'>Créer un compte</button>
                <button class="btn-outline-white" @onclick='() => Navigation.NavigateTo("/contact")'>En savoir plus</button>
            </div>
        </div>
    </section>
</main>

<Footer />

