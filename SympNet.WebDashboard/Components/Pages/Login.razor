@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@inject IConfiguration Config
@using System.Text.Json

<PageTitle>SympNet • Connexion</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
:root{
  --b:#3ABFB8;--bd:#1A9E97;--bdd:#0D6E6A;--bddd:#084E4B;--bl:#6DD4CE;
  --bp:#E6F8F7;--bm:#F0FBFA;--w:#fff;--off:#F4FAFA;
  --bor:#DFF0EF;--bor2:#C5E8E7;
  --ink:#0B2D2C;--inm:#2E5554;--ind:#5E8584;--inf:#9DBDBC;
  --re:#EF4444;--reb:#FEF2F2;--gr:#22C55E;--grb:#F0FDF4;
  --ea:cubic-bezier(.22,1,.36,1);--sp:cubic-bezier(.34,1.56,.64,1);
  --fh:'Bricolage Grotesque',sans-serif;--fb:'Instrument Sans',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--off);color:var(--ink);min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased}
button{cursor:pointer;font-family:var(--fb);border:none;background:none}
input{font-family:var(--fb);outline:none}
a{text-decoration:none;color:inherit}

.page{display:flex;min-height:100vh;background:var(--w)}

/* LEFT */
.ll{flex:1;min-width:0;padding:52px 56px;
  background:linear-gradient(148deg,var(--bddd) 0%,var(--bdd) 40%,var(--bd) 70%,var(--b) 100%);
  display:flex;flex-direction:column;position:relative;overflow:hidden}
.ll::before{content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 18% 22%,rgba(255,255,255,.07),transparent 55%),
             radial-gradient(circle at 80% 75%,rgba(255,255,255,.04),transparent 50%);pointer-events:none}
.ll::after{content:'';position:absolute;inset:0;
  background-image:radial-gradient(circle,rgba(255,255,255,.065) 1px,transparent 1px);
  background-size:30px 30px;pointer-events:none}
.arc{position:absolute;border-radius:50%;border:1px solid rgba(255,255,255,.07);pointer-events:none}
.arc1{width:620px;height:620px;right:-220px;top:-200px}
.arc2{width:360px;height:360px;right:-80px;bottom:-100px}
.arc3{width:200px;height:200px;left:60px;bottom:130px}
.ll-logo{display:flex;align-items:center;gap:13px;margin-bottom:52px;position:relative;z-index:2}
.doctor-logo-icon {
    width: 46px; height: 46px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
    border-radius: 12px; display: flex; align-items: center; justify-content: center;
    font-size: 22px; color: white; border: 1px solid rgba(255,255,255,0.2);
}
.ll-nm{font-family:var(--fh);font-size:27px;font-weight:800;color:#fff;letter-spacing:-.5px;line-height:1}
.ll-tg{font-size:10px;color:rgba(255,255,255,.5);margin-top:4px}
.ll-center{flex:1;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:2}
.pill-wrap{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:999px;padding:6px 14px 6px 8px;margin-bottom:22px;backdrop-filter:blur(6px)}
.pill-dot{width:7px;height:7px;border-radius:50%;background:#4ade80}
.pill-txt{font-size:12px;font-weight:600;color:rgba(255,255,255,.85)}
.ll-h{font-family:var(--fh);font-size:clamp(36px,4vw,54px);font-weight:800;color:#fff;line-height:1.05;letter-spacing:-1.5px;margin-bottom:16px}
.ll-h em{font-style:normal;color:var(--bl)}
.ll-p{font-size:15px;color:rgba(255,255,255,.55);line-height:1.75;max-width:380px;margin-bottom:36px}
.feats{display:flex;flex-direction:column;gap:13px}
.feat{display:flex;align-items:center;gap:12px}
.fic{width:32px;height:32px;border-radius:9px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px}
.fic svg{width:16px;height:16px;color:rgba(255,255,255,.8)}
.ftxt{font-size:13.5px;color:rgba(255,255,255,.7)}
.ftxt b{color:#fff}

/* RIGHT */
.lr{width:520px;flex-shrink:0;background:var(--w);display:flex;align-items:center;justify-content:center;padding:52px}
.lcard{width:100%;max-width:390px}

/* Role switcher */
.role-switch{display:flex;gap:6px;background:var(--bm);border:1.5px solid var(--bor);border-radius:12px;padding:5px;margin-bottom:28px}
.role-btn{flex:1;padding:9px 12px;border-radius:8px;font-size:13px;font-weight:600;color:var(--ind);transition:all .2s var(--ea);display:flex;align-items:center;justify-content:center;gap:7px;cursor:pointer;border:none;background:none;font-family:var(--fb)}
.role-btn.active{background:var(--w);color:var(--bdd);box-shadow:0 2px 8px rgba(10,80,78,.1)}
.role-btn svg{width:14px;height:14px}
.role-btn.active svg{color:var(--bdd)}

/* Badge */
.role-badge{border-radius:12px;padding:13px 16px;display:flex;align-items:center;gap:12px;margin-bottom:24px;border:1.5px solid}
.role-badge.admin{background:linear-gradient(135deg,var(--bp),var(--bm));border-color:var(--bor2)}
.role-badge.doctor{background:linear-gradient(135deg,#EFF6FF,#F0F9FF);border-color:#BFDBFE}
.rb-icon{width:36px;height:36px;border-radius:9px;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.rb-icon.admin{background:linear-gradient(135deg,var(--bdd),var(--b))}
.rb-icon.doctor{background:linear-gradient(135deg,#1D4ED8,#60A5FA)}
.rb-icon svg{width:18px;height:18px;color:white}
.rb-txt{font-size:13px}
.rb-txt.admin .badge-title{font-weight:700;color:var(--bdd)}
.rb-txt.doctor .badge-title{font-weight:700;color:#1D4ED8}
.badge-sub{font-size:11.5px;color:var(--inf);margin-top:2px}

.form-title{font-family:var(--fh);font-size:24px;font-weight:800;color:var(--ink);letter-spacing:-.6px;margin-bottom:4px}
.form-sub{font-size:13.5px;color:var(--inf);margin-bottom:24px}

.fld{margin-bottom:15px}
.fld label{display:block;font-size:12.5px;font-weight:600;color:var(--inm);margin-bottom:7px}
.ish{position:relative;display:flex;align-items:center}
.iico{position:absolute;left:13px;width:16px;height:16px;color:var(--inf);pointer-events:none}
.ish input{width:100%;padding:12px 13px 12px 40px;border:1.5px solid var(--bor2);border-radius:10px;font-size:14px;color:var(--ink);background:var(--w);transition:border-color .18s,box-shadow .18s}
.ish input:focus{border-color:var(--b);box-shadow:0 0 0 3px rgba(58,191,184,.13)}
.ish input::placeholder{color:var(--inf)}
.eyebtn{position:absolute;right:12px;color:var(--inf);padding:3px;border-radius:4px;display:flex;align-items:center;transition:color .15s;cursor:pointer;background:none;border:none}
.eyebtn:hover{color:var(--bd)}.eyebtn svg{width:16px;height:16px}

.forgot-link{text-align:right;margin-top:-8px;margin-bottom:16px}
.forgot-link a{font-size:12.5px;font-weight:600;color:var(--bd);transition:color .15s}
.forgot-link a:hover{color:var(--bdd)}

.btn-login{width:100%;padding:13.5px;background:linear-gradient(135deg,var(--bdd),var(--b));color:#fff;border-radius:10px;font-size:14.5px;font-weight:700;display:flex;align-items:center;justify-content:center;gap:9px;box-shadow:0 6px 20px rgba(26,158,151,.3);transition:all .22s var(--ea);margin-bottom:14px;border:none;cursor:pointer;font-family:var(--fb)}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 10px 28px rgba(26,158,151,.38)}
.btn-login:disabled{opacity:.6;transform:none;cursor:not-allowed}

.bsp{width:17px;height:17px;border:2px solid rgba(255,255,255,.35);border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite;flex-shrink:0}
@@keyframes spin{to{transform:rotate(360deg)}}

.lerr{padding:11px 14px;background:var(--reb);border:1px solid #FECACA;border-radius:10px;font-size:13px;color:var(--re);display:flex;align-items:center;gap:8px;margin-bottom:12px}
.lerr svg{width:15px;height:15px;flex-shrink:0}

@@media(max-width:820px){.ll{display:none}.lr{width:100%}}
</style>

<div class="page">
  <!-- LEFT -->
  <div class="ll">
    <div class="arc arc1"></div><div class="arc arc2"></div><div class="arc arc3"></div>
    <div class="ll-logo">
      <div class="doctor-logo-icon">
        <i class="fas fa-stethoscope"></i>
      </div>
      <div><div class="ll-nm">SympNet</div><div class="ll-tg">Système Intelligent de Support Décisionnel Clinique</div></div>
    </div>
    <div class="ll-center">
      <div class="pill-wrap"><div class="pill-dot"></div><span class="pill-txt" id="pill-txt">Admin Portal</span></div>
      <h1 class="ll-h">Platform<br/><em>Control</em><br/>Center</h1>
      <p class="ll-p">Gérez les médecins, supervisez la plateforme et surveillez l'activité clinique de SympNet.</p>
      <div class="feats">
        <div class="feat"><div class="fic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></div><div class="ftxt"><b>Gestion des médecins</b> → Créer, activer et désactiver</div></div>
        <div class="feat"><div class="fic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/><path d="M12 6v6l4 2"/></svg></div><div class="ftxt"><b>Statistiques</b> → Tableaux de bord en temps réel</div></div>
        <div class="feat"><div class="fic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div><div class="ftxt"><b>Sécurité</b> → Accès protégé par JWT</div></div>
      </div>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="lr">
    <div class="lcard">

      <!-- Role Switch -->
      <div class="role-switch">
        <button class="role-btn @(role == "admin" ? "active" : "")" @onclick='() => SwitchRole("admin")'>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4v16M8 8l4-4 4 4M8 16l4 4 4-4"/></svg>
          Administrateur
        </button>
        <button class="role-btn @(role == "doctor" ? "active" : "")" @onclick='() => SwitchRole("doctor")'>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9-4-18-3 9H2"/></svg>
          Médecin
        </button>
      </div>

      <!-- Badge -->
      <div class="role-badge @role">
        <div class="rb-icon @role">
          @if (role == "admin")
          {
            <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          }
          else
          {
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm0 0v8m-4-4h8"/><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/></svg>
          }
        </div>
        <div class="rb-txt @role">
          <div class="badge-title">@(role == "admin" ? "Accès Administrateur" : "Accès Médecin")</div>
          <div class="badge-sub">@(role == "admin" ? "Réservé aux comptes administrateurs" : "Identifiants envoyés par l'admin SympNet")</div>
        </div>
      </div>

      <div class="form-title">@(role == "admin" ? "Bienvenue" : "Connexion Médecin")</div>
      <div class="form-sub">@(role == "admin" ? "Connectez-vous au tableau de bord Admin" : "Accédez à votre tableau de bord clinique")</div>

      <!-- Email -->
      <div class="fld">
        <label>Adresse email</label>
        <div class="ish">
          <svg class="iico" viewBox="0 0 20 20" fill="currentColor"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/></svg>
          <input type="email" @bind="email" @bind:event="oninput" placeholder="@(role == "admin" ? "admin@sympnet.com" : "doctor@sympnet.com")" autocomplete="email"/>
        </div>
      </div>

      <!-- Password -->
      <div class="fld">
        <label>Mot de passe</label>
        <div class="ish">
          <svg class="iico" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
          <input type="@(showPassword ? "text" : "password")" @bind="password" @bind:event="oninput" placeholder="••••••••" autocomplete="current-password"/>
          <button class="eyebtn" type="button" @onclick="() => showPassword = !showPassword">
            <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/></svg>
          </button>
        </div>
      </div>

      <div class="forgot-link">
        <a href="/forgot-password">Mot de passe oublié ?</a>
      </div>

      @if (errorMsg != null)
      {
        <div class="lerr">
          <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          @errorMsg
        </div>
      }

      <button class="btn-login @(role == "admin" ? "admin-btn" : "doctor-btn")" @onclick="HandleLogin" disabled="@loading">
        @if (loading)
        {
          <div class="bsp"></div>
        }
        else
        {
          <svg viewBox="0 0 20 20" fill="currentColor" width="17" height="17"><path fill-rule="evenodd" d="M3 3a1 1 0 011 1v12a1 1 0 11-2 0V4a1 1 0 011-1zm7.707 3.293a1 1 0 010 1.414L9.414 9H17a1 1 0 110 2H9.414l1.293 1.293a1 1 0 01-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <span>@(role == "admin" ? "Se connecter en tant qu'Admin" : "Se connecter en tant que Médecin")</span>
        }
      </button>

    </div>
  </div>
</div>

@code {
    private string role = "admin";
    private string email = "";
    private string password = "";
    private string? errorMsg = null;
    private bool loading = false;
    private bool showPassword = false;

    private void SwitchRole(string r)
    {
        role = r;
        errorMsg = null;
        email = "";
        password = "";
    }

    private async Task HandleLogin()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMsg = "Veuillez remplir tous les champs.";
            return;
        }

        loading = true;
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var apiUrl = $"{baseUrl}/api/auth/login";
            
            var response = await Http.PostAsJsonAsync(apiUrl, new { email, password });
            var data = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                try
                {
                    var json = JsonDocument.Parse(data);
                    errorMsg = json.RootElement.TryGetProperty("message", out var msg) ? msg.GetString() : "Identifiants incorrects.";
                }
                catch (JsonException)
                {
                    errorMsg = $"Erreur {(int)response.StatusCode}: Le serveur API est injoignable ou l'URL Ngrok est invalide.";
                }
                return;
            }

            var result = JsonDocument.Parse(data);
            var returnedRole = result.RootElement.GetProperty("role").GetString()?.ToLower();
            var token = result.RootElement.GetProperty("token").GetString();

            if (returnedRole != role)
            {
                errorMsg = $"Ce compte est {returnedRole}. Sélectionnez le bon onglet.";
                return;
            }

            // Stocker le token et le rôle dans localStorage
            await JS.InvokeVoidAsync("localStorage.setItem", "sympnet_token", token);
            await JS.InvokeVoidAsync("localStorage.setItem", "sympnet_email", email);
            await JS.InvokeVoidAsync("localStorage.setItem", "sympnet_role", result.RootElement.GetProperty("role").GetString());
            
            // Redirection
            if (returnedRole == "doctor")
            {
                Nav.NavigateTo("/doctor/dashboard", true);
            }
            else
            {
                Nav.NavigateTo("/admin/dashboard", true);
            }
        }
        catch (Exception ex)
        {
            errorMsg = $"Erreur de connexion: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }
}