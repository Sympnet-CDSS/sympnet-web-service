@using System.Net.Http.Json
@implements IDisposable
@inject HttpClient Http
@inject IJSRuntime JS

<div class="chatbot-wrapper @(isOpen ? "open" : "")">
    @if (isOpen)
    {
        <div class="chatbot-window">
            <div class="chatbot-header">
                <div class="header-info">
                    <div class="bot-avatar">
                        <i class="fas fa-robot"></i>
                    </div>
                    <div>
                        <h4>SympNet AI</h4>
                        <span class="status"><i class="fas fa-circle online-dot"></i> En ligne</span>
                    </div>
                </div>
                <button class="close-btn" @onclick="ToggleChat"><i class="fas fa-times"></i></button>
            </div>
            
            <div class="chatbot-messages" id="chatbot-messages">
                <div class="message received">
                    <div class="msg-bubble">
                        Bonjour ! Je suis l'assistant IA de SympNet. Comment puis-je vous aider aujourd'hui ?
                    </div>
                </div>
                
                @foreach (var msg in messages)
                {
                    <div class="message @(msg.IsUser ? "sent" : "received")">
                        <div class="msg-bubble">
                            @if (!string.IsNullOrEmpty(msg.Content))
                            {
                                @((MarkupString)msg.Content.Replace("\n", "<br>"))
                            }
                        </div>
                    </div>
                }
                
                @if (isTyping)
                {
                    <div class="message received typing">
                        <div class="msg-bubble">
                            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                        </div>
                    </div>
                }
            </div>
            
            <div class="chatbot-input">
                <button class="mic-btn @(isRecording ? "recording" : "")" @onclick="ToggleRecording" disabled="@isTyping">
                    <i class="fas @(isRecording ? "fa-stop" : "fa-microphone")"></i>
                </button>
                <input id="chatbot-input-field" type="text" placeholder="Posez votre question médicale..." 
                       @bind="userInput" @bind:event="oninput" @onkeypress="HandleKeyPress" />
                <button class="send-btn" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(userInput) || isTyping)">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    }
    
    <button class="chatbot-launcher" @onclick="ToggleChat">
        @if (isOpen)
        {
            <i class="fas fa-times"></i>
        }
        else
        {
            <i class="fas fa-comment-medical"></i>
        }
    </button>
</div>

<style>
    .chatbot-wrapper {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 9999;
        font-family: 'Inter', sans-serif;
    }
    
    .chatbot-launcher {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0D9488, #14B8A6);
        color: white;
        border: none;
        box-shadow: 0 10px 25px rgba(13,148,136,0.4);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .chatbot-launcher:hover {
        transform: scale(1.1);
        box-shadow: 0 15px 30px rgba(13,148,136,0.5);
    }
    
    .chatbot-window {
        position: absolute;
        bottom: 80px;
        right: 0;
        width: 350px;
        height: 500px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1), 0 5px 15px rgba(0,0,0,0.05);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.5);
        transform-origin: bottom right;
        animation: popUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    @@keyframes popUp {
        0% { opacity: 0; transform: scale(0.5); }
        100% { opacity: 1; transform: scale(1); }
    }
    
    .chatbot-header {
        background: linear-gradient(135deg, #0D9488, #14B8A6);
        padding: 16px 20px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .header-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .bot-avatar {
        width: 40px;
        height: 40px;
        background: white;
        color: #0D9488;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }
    
    .header-info h4 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
    }
    
    .header-info .status {
        font-size: 12px;
        opacity: 0.9;
        display: flex;
        align-items: center;
        gap: 4px;
    }
    
    .online-dot {
        font-size: 8px;
        color: #10B981;
    }
    
    .close-btn {
        background: none;
        border: none;
        color: white;
        font-size: 18px;
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.2s;
    }
    
    .close-btn:hover {
        opacity: 1;
    }
    
    .chatbot-messages {
        flex: 1;
        padding: 20px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: #F9FAFB;
    }
    
    .message {
        display: flex;
        max-width: 85%;
    }
    
    .message.sent {
        align-self: flex-end;
    }
    
    .message.received {
        align-self: flex-start;
    }
    
    .msg-bubble {
        padding: 12px 16px;
        border-radius: 18px;
        font-size: 14px;
        line-height: 1.4;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
    
    .message.sent .msg-bubble {
        background: #0D9488;
        color: white;
        border-bottom-right-radius: 4px;
    }
    
    .message.received .msg-bubble {
        background: white;
        color: #1F2937;
        border-bottom-left-radius: 4px;
        border: 1px solid #E5E7EB;
    }
    
    .typing .msg-bubble {
        display: flex;
        gap: 4px;
        align-items: center;
        padding: 16px 18px;
    }
    
    .dot {
        width: 6px;
        height: 6px;
        background: #9CA3AF;
        border-radius: 50%;
        animation: wave 1.3s linear infinite;
    }
    
    .dot:nth-child(2) { animation-delay: -1.1s; }
    .dot:nth-child(3) { animation-delay: -0.9s; }
    
    @@keyframes wave {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-4px); }
    }
    
    .chatbot-input {
        padding: 16px;
        background: white;
        border-top: 1px solid #E5E7EB;
        display: flex;
        gap: 8px;
        align-items: center;
    }
    
    .mic-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #F3F4F6;
        color: #4B5563;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        flex-shrink: 0;
    }
    
    .mic-btn:hover:not(:disabled) {
        background: #E5E7EB;
    }
    
    .mic-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .mic-btn.recording {
        background: #EF4444;
        color: white;
        animation: pulse-red 1.5s infinite;
    }
    
    @@keyframes pulse-red {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }
    
    .chatbot-input input {
        flex: 1;
        border: 1px solid #E5E7EB;
        border-radius: 20px;
        padding: 10px 16px;
        font-size: 14px;
        outline: none;
        transition: all 0.2s;
    }
    
    .chatbot-input input:focus {
        border-color: #0D9488;
        box-shadow: 0 0 0 3px rgba(13,148,136,0.1);
    }
    
    .send-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #0D9488;
        color: white;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    
    .send-btn:hover:not(:disabled) {
        background: #0F766E;
        transform: scale(1.05);
    }
    
    .send-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
    
    .chatbot-messages::-webkit-scrollbar {
        width: 4px;
    }
    .chatbot-messages::-webkit-scrollbar-track {
        background: transparent;
    }
    .chatbot-messages::-webkit-scrollbar-thumb {
        background: #D1D5DB;
        border-radius: 4px;
    }
</style>

@code {
    private bool isOpen = false;
    private string userInput = "";
    private bool isTyping = false;
    private bool isRecording = false;
    private List<ChatMessage> messages = new();
    private DotNetObjectReference<ChatbotBubble>? objRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            { 
                objRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("initAudioRecorder", objRef); 
            } 
            catch { }
        }
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }

    [JSInvokable]
    public void UpdateUserInput(string text)
    {
        userInput = initialTextBeforeRecording + (string.IsNullOrEmpty(initialTextBeforeRecording) ? "" : " ") + text;
        InvokeAsync(StateHasChanged);
    }

    private string initialTextBeforeRecording = "";

    private async Task ToggleRecording()
    {
        if (isRecording)
        {
            await JS.InvokeVoidAsync("stopRecording", true);
            isRecording = false;
        }
        else
        {
            initialTextBeforeRecording = userInput;
            await JS.InvokeVoidAsync("resetTranscribedText");
            if (objRef == null) objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("startRecording", objRef);
            isRecording = true;
        }
        StateHasChanged();
    }

    private async Task ToggleChat()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;

        var messageText = userInput;
        userInput = "";
        
        messages.Add(new ChatMessage { Content = messageText, IsUser = true });
        isTyping = true;
        await ScrollToBottom();
        StateHasChanged();

        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            
            // Call the AI Service
            var response = await Http.PostAsJsonAsync("http://localhost:5057/api/ai/chat", new { message = messageText });
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AIResponse>();
                messages.Add(new ChatMessage { Content = result?.Reply ?? "Je n'ai pas pu comprendre. Réessayez.", IsUser = false });
            }
            else
            {
                messages.Add(new ChatMessage { Content = "Erreur de connexion au service IA.", IsUser = false });
            }
        }
        catch (Exception)
        {
            messages.Add(new ChatMessage { Content = "Une erreur s'est produite lors de la connexion à l'IA.", IsUser = false });
        }
        finally
        {
            isTyping = false;
            await ScrollToBottom();
            StateHasChanged();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
        await JS.InvokeVoidAsync("eval", "var el = document.getElementById('chatbot-messages'); if(el) el.scrollTop = el.scrollHeight;");
    }

    private class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
    }
    
    private class AIResponse
    {
        public string Reply { get; set; } = "";
    }
}
