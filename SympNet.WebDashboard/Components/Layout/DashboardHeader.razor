@inject IJSRuntime JS

<div class="dashboard-header-banner">
    <div class="banner-content">
        <div class="banner-welcome">
            <div class="welcome-icon">
                <i class="fas fa-@(HideWelcome ? "user-circle" : "sun")"></i>
            </div>
            @if (!HideWelcome)
            {
                <div class="welcome-text">
                    <h1>Bonjour, @UserName</h1>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        @if (!string.IsNullOrEmpty(UserEmail))
                        {
                            <small style="opacity: 0.8; font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 6px;">
                                <i class="fas fa-envelope" style="font-size: 11px;"></i> @UserEmail
                            </small>
                        }
                        <p style="margin: 0;">Bienvenue sur votre espace @(IsAdmin ? "d'administration" : "médical") SympNet</p>
                    </div>
                </div>
            }
            else
            {
                <div class="welcome-text">
                    <h1>Mon Profil</h1>
                    <p>Gérez vos informations personnelles et de sécurité</p>
                </div>
            }
        </div>
        <div class="banner-date">
            <i class="fas fa-calendar-alt"></i>
            <span>@currentDate</span>
        </div>
    </div>
</div>

<style>
    .dashboard-header-banner {
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: 24px;
        padding: 32px 40px;
        color: white;
        margin-bottom: 32px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(13, 148, 136, 0.15);
    }

    .dashboard-header-banner::before {
        content: '';
        position: absolute;
        right: -50px;
        top: -50px;
        width: 200px;
        height: 200px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
    }

    .dashboard-header-banner::after {
        content: '';
        position: absolute;
        left: -30px;
        bottom: -30px;
        width: 150px;
        height: 150px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 50%;
    }

    .banner-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: relative;
        z-index: 1;
    }

    .banner-welcome {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .welcome-icon {
        width: 48px;
        height: 48px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .welcome-text h1 {
        font-size: 28px;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .welcome-text p {
        margin: 4px 0 0;
        font-size: 14px;
        opacity: 0.9;
        font-weight: 500;
    }

    .banner-date {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(0, 0, 0, 0.1);
        padding: 8px 16px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .banner-content {
            flex-direction: column;
            align-items: flex-start;
            gap: 20px;
        }
        .banner-date {
            align-self: flex-start;
        }
    }
</style>

@code {
    [Parameter] public string UserName { get; set; } = "Utilisateur";
    [Parameter] public string UserEmail { get; set; } = "";
    [Parameter] public bool IsAdmin { get; set; } = false;
    [Parameter] public bool HideWelcome { get; set; } = false;

    private string currentDate = "";

    protected override void OnInitialized()
    {
        var culture = new System.Globalization.CultureInfo("fr-FR");
        currentDate = DateTime.Now.ToString("dddd d MMMM yyyy", culture);
    }
}
