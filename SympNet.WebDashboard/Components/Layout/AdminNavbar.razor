@inject NavigationManager Navigation
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS

<div class="admin-navbar">
    <div class="navbar-search">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Rechercher un message, un médecin..." @bind="searchQuery" @bind:event="oninput" />
    </div>

    <div class="navbar-actions">
        <div class="notification-container">
            <div class="notification-icon @(showNotifications ? "active" : "")" @onclick="ToggleNotifications">
                <i class="far fa-bell"></i>
                @if (unreadNotifications > 0)
                {
                    <span class="notification-badge">@unreadNotifications</span>
                }
            </div>

            @if (showNotifications)
            {
                <div class="notification-dropdown">
                    <div class="notification-header">
                        <h4>Notifications</h4>
                        <div class="notification-actions">
                            <span class="mark-all-read" @onclick="MarkAllAsRead">Tout marquer comme lu</span>
                        </div>
                    </div>
                    <div class="notification-tabs">
                        <button class="notif-tab @(filter == "all" ? "active" : "")" @onclick='() => filter = "all"'>Toutes</button>
                        <button class="notif-tab @(filter == "unread" ? "active" : "")" @onclick='() => filter = "unread"'>Non lues</button>
                    </div>
                    <div class="notification-list">
                        @foreach (var notif in FilteredNotifications)
                        {
                            <div class="notification-item @(notif.IsRead ? "read" : "unread")" @onclick="() => HandleNotificationClick(notif)">
                                <div class="notification-icon-wrapper @notif.Type">
                                    <i class="@GetNotificationIcon(notif.Type)"></i>
                                </div>
                                <div class="notification-content">
                                    <p class="notification-title">@notif.Title</p>
                                    <p class="notification-desc">@notif.Message</p>
                                    <span class="notification-time">@GetTimeAgo(notif.CreatedAt)</span>
                                </div>
                                @if (!notif.IsRead)
                                {
                                    <div class="notification-dot"></div>
                                }
                            </div>
                        }
                        @if (!FilteredNotifications.Any())
                        {
                            <div class="notification-empty">
                                <i class="far fa-bell-slash"></i>
                                <p>Aucune notification trouvée.</p>
                            </div>
                        }
                    </div>
                    <div class="notification-footer" @onclick="GoToAllNotifications">
                        Voir toutes les notifications <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
            }
        </div>

        <div class="user-profile" @onclick="OnProfileClick">
            <div class="user-avatar">@AdminInitial</div>
            <div class="user-info">
                <span class="user-name">@AdminName</span>
                <span class="user-role">Administrateur</span>
            </div>
            <i class="fas fa-chevron-down profile-chevron"></i>
        </div>
    </div>
</div>

<style>
    .admin-navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 32px;
        background: white;
        border-bottom: 1px solid rgba(13,148,136,0.1);
        position: sticky;
        top: 0;
        z-index: 90;
        box-shadow: 0 4px 20px rgba(0,0,0,0.02);
    }

    .navbar-search { position: relative; width: 400px; }
    .navbar-search i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #9CA3AF; }
    .navbar-search input {
        width: 100%; padding: 12px 16px 12px 40px; border: 1px solid #E5E7EB;
        border-radius: 12px; background: #F9FAFB; font-family: inherit; font-size: 14px;
        color: #1F2937; transition: all 0.2s;
    }
    .navbar-search input:focus { outline: none; border-color: #0D9488; background: white; box-shadow: 0 0 0 3px rgba(13,148,136,0.1); }

    .navbar-actions { display: flex; align-items: center; gap: 24px; }
    .notification-container { position: relative; }
    .notification-icon {
        width: 44px; height: 44px; border-radius: 12px; background: #F3F4F6;
        display: flex; align-items: center; justify-content: center; color: #6B7280;
        font-size: 18px; cursor: pointer; position: relative; transition: all 0.2s;
    }
    .notification-icon:hover, .notification-icon.active { background: rgba(13,148,136,0.1); color: #0D9488; }
    .notification-badge {
        position: absolute; top: 8px; right: 8px; background: #EF4444; color: white;
        font-size: 10px; font-weight: 700; width: 16px; height: 16px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center; border: 2px solid white;
    }

    .notification-dropdown {
        position: absolute; top: calc(100% + 12px); right: -80px; width: 380px;
        background: white; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        border: 1px solid #E5E7EB; overflow: hidden; animation: slideDown 0.2s ease-out;
    }
    @@keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

    .notification-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #E5E7EB; }
    .notification-header h4 { margin: 0; font-size: 16px; font-weight: 700; color: #1F2937; }
    .mark-all-read { font-size: 12px; color: #0D9488; cursor: pointer; font-weight: 600; }
    .notification-tabs { display: flex; padding: 0 20px; border-bottom: 1px solid #E5E7EB; background: #F9FAFB; }
    .notif-tab { background: none; border: none; padding: 12px 16px; font-size: 13px; font-weight: 600; color: #6B7280; cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.2s; }
    .notif-tab.active { color: #0D9488; border-bottom-color: #0D9488; }

    .notification-list { max-height: 400px; overflow-y: auto; }
    .notification-item { display: flex; gap: 16px; padding: 16px 20px; border-bottom: 1px solid #F3F4F6; position: relative; transition: background 0.2s; cursor: pointer; }
    .notification-item:hover { background: #F9FAFB; }
    .notification-item.unread { background: rgba(13,148,136,0.03); }
    .notification-icon-wrapper { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
    .notification-icon-wrapper.General { background: rgba(59,130,246,0.1); color: #3B82F6; }
    .notification-content { flex: 1; }
    .notification-title { font-size: 14px; font-weight: 600; color: #1F2937; margin: 0 0 4px 0; }
    .notification-desc { font-size: 12px; color: #6B7280; margin: 0 0 8px 0; line-height: 1.4; }
    .notification-time { font-size: 11px; color: #9CA3AF; }
    .notification-dot { width: 8px; height: 8px; border-radius: 50%; background: #0D9488; position: absolute; right: 20px; top: 20px; }
    .notification-empty { padding: 40px 20px; text-align: center; color: #9CA3AF; }
    .notification-footer { padding: 12px; text-align: center; background: #F9FAFB; border-top: 1px solid #E5E7EB; font-size: 13px; font-weight: 600; color: #0D9488; cursor: pointer; }

    .user-profile { display: flex; align-items: center; gap: 12px; cursor: pointer; padding: 6px; border-radius: 12px; transition: background 0.2s; }
    .user-profile:hover { background: #F3F4F6; }
    .user-avatar { width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 16px; color: white; box-shadow: 0 4px 10px rgba(13,148,136,0.2); }
    .user-info { display: flex; flex-direction: column; }
    .user-name { font-size: 14px; font-weight: 600; color: #1F2937; }
    .user-role { font-size: 12px; color: #6B7280; }
    .profile-chevron { font-size: 12px; color: #9CA3AF; margin-left: 4px; }
</style>

@code {
    [Parameter] public string AdminName { get; set; } = "Admin";
    [Parameter] public string AdminInitial { get; set; } = "A";
    [Parameter] public EventCallback OnProfileClick { get; set; }

    private string searchQuery = "";
    private bool showNotifications = false;
    private string filter = "all";
    private List<Notification> notifications = new();

    private IEnumerable<Notification> FilteredNotifications => 
        notifications.Where(n => (filter == "all" || (filter == "unread" && !n.IsRead)));

    private int unreadNotifications => notifications.Count(n => !n.IsRead);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadNotifications();
            StateHasChanged();
        }
    }

    private async Task LoadNotifications()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                var result = await Http.GetFromJsonAsync<List<Notification>>($"{baseUrl}/api/admin/notifications");
                if (result != null) notifications = result;
            }
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
    }

    private async Task ToggleNotifications()
    {
        showNotifications = !showNotifications;
        if (showNotifications) await LoadNotifications();
    }

    private async Task MarkAllAsRead()
    {
        // To be implemented
    }

    private void HandleNotificationClick(Notification notif)
    {
        if (!string.IsNullOrEmpty(notif.ActionUrl))
        {
            Navigation.NavigateTo(notif.ActionUrl);
            showNotifications = false;
        }
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.UtcNow - dateTime;
        if (diff.TotalDays >= 1) return $"Il y a {Math.Floor(diff.TotalDays)} j";
        if (diff.TotalHours >= 1) return $"Il y a {Math.Floor(diff.TotalHours)} h";
        if (diff.TotalMinutes >= 1) return $"Il y a {Math.Floor(diff.TotalMinutes)} m";
        return "À l'instant";
    }

    private string GetNotificationIcon(string type) => "fas fa-info-circle";

    private void GoToAllNotifications() { showNotifications = false; Navigation.NavigateTo("/admin/notifications"); }

    public class Notification
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "General";
        public string ActionUrl { get; set; } = "";
        public bool IsRead { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
