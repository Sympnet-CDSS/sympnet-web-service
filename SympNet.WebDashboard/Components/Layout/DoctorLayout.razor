@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject HttpClient Http
@inject IJSRuntime JS
@inject IConfiguration Config
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json

<PageTitle>SympNet — Médecin</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet"/>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Instrument Sans', sans-serif; background: #F9FAFB; min-height: 100vh; color: #1F2937; }
    .doctor-app { display: flex; min-height: 100vh; }
    .doctor-sidebar {
        position: fixed; left: 0; top: 0; width: 280px; height: 100vh;
        background: #FFFFFF; border-right: 1px solid rgba(13,148,136,0.1);
        display: flex; flex-direction: column; z-index: 100;
    }
    .doctor-sidebar-header { padding: 28px 24px; border-bottom: 1px solid rgba(13,148,136,0.1); }
    .doctor-logo { display: flex; align-items: center; gap: 12px; }
    .doctor-logo-icon {
        width: 40px; height: 40px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: white;
    }
    .doctor-logo-text h2 {
        font-family: 'Bricolage Grotesque', sans-serif; font-size: 20px; font-weight: 700;
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        margin: 0;
    }
    .doctor-logo-text p { font-size: 11px; color: #6B7280; margin-top: 2px; }
    .doctor-sidebar-nav { flex: 1; padding: 24px 16px; overflow-y: auto; }
    .doctor-nav-label {
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;
        color: #9CA3AF; padding: 0 12px; margin-bottom: 12px;
    }
    .doctor-nav-item {
        display: flex; align-items: center; gap: 12px; padding: 10px 16px; margin: 4px 0;
        border-radius: 12px; color: #6B7280; text-decoration: none;
        font-size: 14px; font-weight: 500; cursor: pointer;
    }
    .doctor-nav-item i { width: 20px; font-size: 16px; }
    .doctor-nav-item:hover { background: rgba(13,148,136,0.05); color: #0D9488; }
    .doctor-nav-item.active {
        background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        color: white;
    }
    .doctor-sidebar-footer { padding: 20px 16px; border-top: 1px solid rgba(13,148,136,0.1); }
    .doctor-user-info {
        display: flex; align-items: center; gap: 12px; padding: 12px;
        border-radius: 12px; background: rgba(13,148,136,0.05); margin-bottom: 12px;
        cursor: pointer;
    }
    .doctor-user-avatar {
        width: 44px; height: 44px; background: linear-gradient(135deg, #0D9488 0%, #14B8A6 100%);
        border-radius: 12px; display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 16px; color: white;
    }
    .doctor-user-details h4 { font-size: 14px; font-weight: 600; margin: 0; color: #1F2937; }
    .doctor-user-details p { font-size: 11px; color: #6B7280; margin: 2px 0 0; }
    .doctor-logout-btn {
        width: 100%; padding: 10px; background: none; border: 1px solid rgba(239,68,68,0.2);
        border-radius: 12px; color: #EF4444; font-size: 13px; font-weight: 500;
        cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
        transition: all 0.2s;
    }
    .doctor-logout-btn:hover { background: rgba(239,68,68,0.1); border-color: #EF4444; }
    .doctor-main-content { margin-left: 280px; min-height: 100vh; background: #F9FAFB; padding: 24px 32px; width: calc(100% - 280px); }
    
    @@media (max-width: 768px) {
        .doctor-sidebar { transform: translateX(-100%); }
        .doctor-main-content { margin-left: 0; width: 100%; padding: 16px; }
    }
</style>

<div class="doctor-app">
    <aside class="doctor-sidebar">
        <div class="doctor-sidebar-header">
            <div class="doctor-logo">
                <div class="doctor-logo-icon"><i class="fas fa-stethoscope"></i></div>
                <div class="doctor-logo-text"><h2>SympNet</h2><p>Espace Médecin</p></div>
            </div>
        </div>
        <div class="doctor-sidebar-nav">
            <div class="doctor-nav-label">Vue Générale</div>
            <div class="doctor-nav-item @(IsActive("/doctor/dashboard") ? "active" : "")" @onclick="GoToDashboard">
                <i class="fas fa-chart-line"></i><span>Tableau de bord</span>
            </div>
            <div class="doctor-nav-label">Consultations</div>
            <div class="doctor-nav-item @(IsActive("/doctor/ai-diagnostics") ? "active" : "")" @onclick="GoToAIDiagnostics">
                <i class="fas fa-brain"></i><span>Diagnostics IA</span>
            </div>
            <div class="doctor-nav-item @(IsActive("/doctor/consultations") ? "active" : "")" @onclick="GoToConsultations">
                <i class="fas fa-stethoscope"></i><span>Mes consultations</span>
            </div>
            <div class="doctor-nav-item @(IsActive("/doctor/prescriptions") ? "active" : "")" @onclick="GoToPrescriptions">
                <i class="fas fa-file-prescription"></i><span>Mes ordonnances</span>
            </div>
            <div class="doctor-nav-label">Communication</div>
<div class="doctor-nav-item @(IsActive("/doctor/chat") ? "active" : "")" @onclick="GoToChat">
    <i class="fas fa-comments"></i><span>Messagerie</span>
    @if (unreadCount > 0)
    {
        <span class="badge">@unreadCount</span>
    }
</div>
<div class="doctor-nav-item @(IsActive("/doctor/video-call") ? "active" : "")" @onclick="GoToVideoCall">
    <i class="fas fa-video"></i><span>Téléconsultation</span>
</div>
            <div class="doctor-nav-label">Planification</div>
<div class="doctor-nav-item @(IsActive("/doctor/agenda") ? "active" : "")" @onclick="GoToAgenda">
    <i class="fas fa-calendar-alt"></i><span>Mon agenda</span>
</div>
            <div class="doctor-nav-label">Gestion</div>
            <div class="doctor-nav-item @(IsActive("/doctor/patients") ? "active" : "")" @onclick="GoToPatients">
                <i class="fas fa-users"></i><span>Mes patients</span>
            </div>
            <div class="doctor-nav-label">Compte</div>
            <div class="doctor-nav-item @(IsActive("/doctor/profile") ? "active" : "")" @onclick="GoToProfile">
                <i class="fas fa-user-md"></i><span>Mon profil</span>
            </div>
        </div>
        <div class="doctor-sidebar-footer">
            <div class="doctor-user-info" @onclick="GoToProfile">
                <div class="doctor-user-avatar">@doctorInitial</div>
                <div class="doctor-user-details">
                    <h4>Dr. @doctorName</h4>
                    <p>@doctorSpeciality</p>
                </div>
            </div>
            <button class="doctor-logout-btn" @onclick="Logout">
                <i class="fas fa-sign-out-alt"></i> Déconnexion
            </button>
        </div>
    </aside>
    <div class="doctor-main-content">@Body</div>
    <ChatbotBubble />
</div>

<div class="toast-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 10000; display: flex; flex-direction: column; gap: 12px;">
    @foreach (var toast in toasts)
    {
        <div class="toast @toast.Type" style="background: white; border-radius: 16px; padding: 16px 24px; display: flex; align-items: center; gap: 14px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.15); min-width: 320px; border-left: 5px solid @(toast.Type == "error" ? "#EF4444" : "#F59E0B");">
            <div class="toast-content" style="flex: 1;">
                <div class="toast-title" style="font-weight: 700; font-size: 14px; margin-bottom: 2px;">@toast.Title</div>
                <div class="toast-message" style="font-size: 13px; color: #6B7280;">@toast.Message</div>
            </div>
            <button class="toast-close" style="background: none; border: none; cursor: pointer; font-size: 16px;" @onclick="() => RemoveToast(toast.Id)">×</button>
        </div>
    }
</div>

@code {
    private string doctorName = "Médecin";
    private string doctorInitial = "M";
    private string doctorSpeciality = "Médecin généraliste";
    private int unreadCount = 0; 
    private HubConnection? _hubConnection;
    private List<ToastMessage> toasts = new();
    private int nextToastId = 1;

    public class ToastMessage
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "info";
    }

    private void ShowToast(string title, string message, string type = "info")
    {
        var toast = new ToastMessage { Id = nextToastId++, Title = title, Message = message, Type = type };
        toasts.Add(toast);
        StateHasChanged();
        Task.Delay(5000).ContinueWith(_ => { InvokeAsync(() => RemoveToast(toast.Id)); });
    }

    private void RemoveToast(int id)
    {
        var toast = toasts.FirstOrDefault(t => t.Id == id);
        if (toast != null) { toasts.Remove(toast); StateHasChanged(); }
    } 


    private async Task LoadDoctorInfo()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                var profile = await Http.GetFromJsonAsync<DoctorInfoDto>($"{baseUrl}/api/doctorprofile");
                if (profile != null)
                {
                    doctorName = $"{profile.FirstName} {profile.LastName}".Trim();
                    if (string.IsNullOrWhiteSpace(doctorName)) doctorName = "Médecin";
                    doctorInitial = doctorName.Length > 0 ? doctorName[0].ToString().ToUpper() : "M";
                    doctorSpeciality = !string.IsNullOrEmpty(profile.Speciality) ? profile.Speciality : "Médecin généraliste";
                }
            }
        }
        catch (Exception ex) { Console.WriteLine($"Erreur: {ex.Message}"); }
    }

    private bool IsActive(string path)
    {
        return Navigation.Uri.Contains(path, StringComparison.OrdinalIgnoreCase);
    }
     
private bool _initialized = false;

protected override async Task OnAfterRenderAsync(bool firstRender)
{
    if (firstRender && !_initialized)
    {
        _initialized = true;
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("/login", true);
            return;
        }
        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        await LoadDoctorInfo();
        await LoadUnreadCount();
        await InitializeSignalR(token);
        StateHasChanged();
    }
}

private async Task InitializeSignalR(string token)
{
    try
    {
        var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
        _hubConnection = new HubConnectionBuilder()
            .WithUrl($"{baseUrl}/hubs/notifications", options =>
            {
                options.AccessTokenProvider = () => Task.FromResult(token)!;
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<JsonElement>("ReceiveAlert", (result) =>
        {
            var summary = result.GetProperty("summary").GetString();
            var severity = "warning";
            InvokeAsync(() =>
            {
                ShowToast("⚠️ Alerte Ordonnance (DrugBank)", summary ?? "Interaction détectée", severity);
            });
        });

        await _hubConnection.StartAsync();
        Console.WriteLine("DoctorLayout NotificationHub connected");
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error starting SignalR: {ex.Message}");
    }
}
private async Task LoadUnreadCount()
{
    var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
    
    try
    {
        var result = await Http.GetFromJsonAsync<JsonElement>($"{baseUrl}/api/chat/unread-count");
        unreadCount = result.TryGetProperty("unreadCount", out var prop) ? prop.GetInt32() : 0;
        
        // Optionnel: Log de succès en mode développement
        #if DEBUG
        Console.WriteLine($"✅ Messages non lus: {unreadCount}");
        #endif
    }
    catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
    {
        // L'endpoint n'existe pas - c'est normal, on ignore
        #if DEBUG
        Console.WriteLine("ℹ️ Endpoint chat non encore implémenté");
        #endif
        unreadCount = 0;
    }
    catch (Exception ex)
    {
        // Autres erreurs réseau (hors ligne, serveur indisponible, etc.)
        #if DEBUG
        Console.WriteLine($"⚠️ Erreur chargement messages: {ex.Message}");
        #endif
        unreadCount = 0;
    }
}

    private void GoToDashboard() => Navigation.NavigateTo("/doctor/dashboard");
    private void GoToAIDiagnostics() => Navigation.NavigateTo("/doctor/ai-diagnostics");
    private void GoToConsultations() => Navigation.NavigateTo("/doctor/consultations");
    private void GoToPrescriptions() => Navigation.NavigateTo("/doctor/prescriptions/new");
    private void GoToPatients() => Navigation.NavigateTo("/doctor/patients");
    private void GoToProfile() => Navigation.NavigateTo("/doctor/profile");
    private void GoToAgenda() => Navigation.NavigateTo("/doctor/agenda");
    private void GoToChat() => Navigation.NavigateTo("/doctor/chat");
    private void GoToVideoCall() => Navigation.NavigateTo("/doctor/video-call");

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "sympnet_token");
        Navigation.NavigateTo("/login", true);
    }

    public class DoctorInfoDto 
    { 
        public string FirstName { get; set; } = ""; 
        public string LastName { get; set; } = ""; 
        public string Speciality { get; set; } = "";
    }
}