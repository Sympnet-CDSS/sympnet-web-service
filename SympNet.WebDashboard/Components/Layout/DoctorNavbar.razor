</style>

@code {
    [Parameter] public string DoctorName { get; set; } = "Médecin";
    [Parameter] public string DoctorInitial { get; set; } = "M";
    [Parameter] public string DoctorSpeciality { get; set; } = "Généraliste";
    [Parameter] public EventCallback OnProfileClick { get; set; }

    private string searchQuery = "";
    private string notifSearchQuery = "";
    private bool showNotifications = false;
    private string filter = "all";
    
    private List<NotificationItem> notifications = new();

    private IEnumerable<NotificationItem> FilteredNotifications => 
        notifications.Where(n => 
            (filter == "all" || (filter == "unread" && !n.IsRead)) &&
            (string.IsNullOrWhiteSpace(notifSearchQuery) || 
             n.Title.Contains(notifSearchQuery, StringComparison.OrdinalIgnoreCase) || 
             n.Description.Contains(notifSearchQuery, StringComparison.OrdinalIgnoreCase))
        ).OrderByDescending(n => n.Id);

    private int unreadNotifications => notifications.Count(n => !n.IsRead);

    protected override async Task OnInitializedAsync()
    {
        await LoadNotifications();
    }

    private async Task LoadNotifications()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "sympnet_token");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
                var result = await Http.GetFromJsonAsync<List<DoctorNotificationDto>>($"{baseUrl}/api/notifications");
                if (result != null)
                {
                    notifications = result.Select(n => new NotificationItem 
                    { 
                        Id = n.Id, 
                        Title = n.Title, 
                        Description = n.Message, 
                        Time = GetTimeAgo(n.SentAt), 
                        Type = n.AppointmentId > 0 ? "appointment" : "system",
                        IsRead = n.IsRead,
                        AppointmentId = n.AppointmentId
                    }).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading notifications: {ex.Message}");
        }
    }

    private string GetTimeAgo(DateTime dateTime)
    {
        var diff = DateTime.UtcNow - dateTime;
        if (diff.TotalDays >= 1) return $"Il y a {Math.Floor(diff.TotalDays)} j";
        if (diff.TotalHours >= 1) return $"Il y a {Math.Floor(diff.TotalHours)} h";
        if (diff.TotalMinutes >= 1) return $"Il y a {Math.Floor(diff.TotalMinutes)} m";
        return "À l'instant";
    }

    private async Task ToggleNotifications()
    {
        showNotifications = !showNotifications;
        if (showNotifications)
        {
            await LoadNotifications();
        }
    }

    private async Task MarkAllAsRead()
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PatchAsync($"{baseUrl}/api/notifications/read-all", null);
            if (response.IsSuccessStatusCode)
            {
                foreach (var notif in notifications)
                {
                    notif.IsRead = true;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking all as read: {ex.Message}");
        }
    }

    private async Task MarkAsRead(NotificationItem notif)
    {
        try
        {
            var baseUrl = Config["ApiSettings:BaseUrl"] ?? "http://localhost:5057";
            var response = await Http.PatchAsync($"{baseUrl}/api/notifications/{notif.Id}/read", null);
            if (response.IsSuccessStatusCode)
            {
                notif.IsRead = true;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as read: {ex.Message}");
        }
    }

    private void AcceptAppointment(NotificationItem notif)
    {
        notif.IsAccepted = true;
        notif.IsRead = true;
        notif.Description = "Rendez-vous accepté.";
        // Navigation or API call could be added here
    }

    private void DeclineAppointment(NotificationItem notif)
    {
        notif.IsAccepted = true;
        notif.IsRead = true;
        notif.Description = "Rendez-vous refusé.";
    }

    private string GetNotificationIcon(string type)
    {
        return type switch
        {
            "appointment" => "far fa-calendar-check",
            "message" => "far fa-envelope",
            _ => "fas fa-info-circle"
        };
    }

    private void GoToAllNotifications()
    {
        showNotifications = false;
        Navigation.NavigateTo("/doctor/notifications");
    }

    public class NotificationItem
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Time { get; set; } = "";
        public string Type { get; set; } = "system";
        public bool IsRead { get; set; }
        public bool IsAccepted { get; set; }
        public int AppointmentId { get; set; }
    }

    public class DoctorNotificationDto
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public int AppointmentId { get; set; }
        public bool IsUrgent { get; set; }
        public bool IsRead { get; set; }
        public DateTime SentAt { get; set; }
    }
}
