@inject NavigationManager Navigation
@inject HttpClient Http
@inject IConfiguration Config
@inject IJSRuntime JS

<div class="doctor-navbar">
    <div class="navbar-search">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Rechercher une fonctionnalité, un patient..." @bind="searchQuery" @bind:event="oninput" />
    </div>

    <div class="navbar-actions">
        <div class="notification-container">
            <div class="notification-icon @(showNotifications ? "active" : "")" @onclick="ToggleNotifications">
                <i class="far fa-bell"></i>
                @if (unreadNotifications > 0)
                {
                    <span class="notification-badge">@unreadNotifications</span>
                }
            </div>

            @if (showNotifications)
            {
                <div class="notification-dropdown">
                    <div class="notification-header">
                        <h4>Notifications</h4>
                        <div class="notification-actions">
                            <span class="mark-all-read" @onclick="MarkAllAsRead">Tout marquer comme lu</span>
                        </div>
                    </div>
                    <div class="notification-tabs">
                        <button class="notif-tab @(filter == "all" ? "active" : "")" @onclick='() => filter = "all"'>Toutes</button>
                        <button class="notif-tab @(filter == "unread" ? "active" : "")" @onclick='() => filter = "unread"'>Non lues</button>
                    </div>
                    <div class="notification-search">
                        <i class="fas fa-search"></i>
                        <input type="text" placeholder="Rechercher une notification..." @bind="notifSearchQuery" @bind:event="oninput" />
                    </div>
                    <div class="notification-list">
                        @foreach (var notif in FilteredNotifications)
                        {
                            <div class="notification-item @(notif.IsRead ? "read" : "unread")">
                                <div class="notification-icon-wrapper @notif.Type">
                                    <i class="@GetNotificationIcon(notif.Type)"></i>
                                </div>
                                <div class="notification-content">
                                    <p class="notification-title">@notif.Title</p>
                                    <p class="notification-desc">@notif.Description</p>
                                    <span class="notification-time">@notif.Time</span>
                                    
                                    @if (notif.Type == "appointment" && !notif.IsAccepted)
                                    {
                                        <div class="appointment-actions">
                                            <button class="btn-accept" @onclick="() => AcceptAppointment(notif)"><i class="fas fa-check"></i> Accepter</button>
                                            <button class="btn-decline" @onclick="() => DeclineAppointment(notif)"><i class="fas fa-times"></i> Refuser</button>
                                        </div>
                                    }
                                </div>
                                @if (!notif.IsRead)
                                {
                                    <div class="notification-dot" @onclick="() => MarkAsRead(notif)" title="Marquer comme lu"></div>
                                }
                            </div>
                        }
                        @if (!FilteredNotifications.Any())
                        {
                            <div class="notification-empty">
                                <i class="far fa-bell-slash"></i>
                                <p>Aucune notification trouvée.</p>
                            </div>
                        }
                    </div>
                    <div class="notification-footer" @onclick="GoToAllNotifications">
                        Voir toutes les notifications <i class="fas fa-arrow-right"></i>
                    </div>
                </div>
            }
        </div>

        <div class="user-profile" @onclick="OnProfileClick">
            <div class="user-avatar">@DoctorInitial</div>
            <div class="user-info">
                <span class="user-name">Dr. @DoctorName</span>
                <span class="user-role">@DoctorSpeciality</span>
            </div>
            <i class="fas fa-chevron-down profile-chevron"></i>
        </div>
    </div>
</div>

<style>
