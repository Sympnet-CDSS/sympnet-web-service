    }

    .notification-search {
        padding: 12px 20px;
        border-bottom: 1px solid #E5E7EB;
        background: #F9FAFB;
        position: relative;
    }

    .notification-search i {
        position: absolute;
        left: 32px;
        top: 50%;
        transform: translateY(-50%);
